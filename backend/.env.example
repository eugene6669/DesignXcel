# DesignXcel Backend Quickstart Example (local development)
# This is intentionally minimal. For complete options, see `.env.template`.

NODE_ENV=development
PORT=5000

# Database (local)
DB_SERVER=localhost
DB_DATABASE=DesignXcellDB
DB_USERNAME=your_database_user
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Auth
SESSION_SECRET=replace_with_strong_session_secret
JWT_SECRET=replace_with_strong_jwt_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_EXPIRES_IN=24h

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Google Sign-In (customers) — create OAuth 2.0 Web client in Google Cloud Console
# Authorized redirect URI must match GOOGLE_CALLBACK_URL (or default below).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; default: http://localhost:5000/api/auth/google/callback (see routes.js buildGoogleCustomerCallbackUrl)
GOOGLE_CALLBACK_URL=
# Optional; public API origin if different from localhost (production)
# PUBLIC_API_URL=https://api.yourdomain.com

# Payments / Email (fill as needed)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
OTP_EMAIL_USER=your_email@example.com
OTP_EMAIL_PASS=your_email_app_password
