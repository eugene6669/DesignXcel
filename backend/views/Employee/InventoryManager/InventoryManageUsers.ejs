                    // Function to permanently delete customer (updated with better error handling)
                    async function deleteCustomer(customerId, fullName) {
                        try {
                            const response = await fetch('/Employee/InventoryManager/InventoryManageUsers/Customers/Delete/' + customerId, {
                                method: 'DELETE',
                                headers: {
                                    'Content-Type': 'application/json'
                                }
                            });

                            // Check if response is ok
                            if (!response.ok) {
                                const errorText = await response.text();
                                console.error('Delete customer failed:', response.status, errorText);
                                alert('Failed to delete customer: ' + (response.status === 404 ? 'Customer not found' : response.statusText));
                                return;
                            }

                            // Try to parse as JSON regardless of content-type (backend sometimes returns wrong content-type)
                            let result;
                            try {
                                const text = await response.text();
                                // Check if the text looks like JSON
                                if (text.trim().startsWith('{') || text.trim().startsWith('[')) {
                                    result = JSON.parse(text);
                                } else {
                                    // If it's HTML, try to extract JSON from it
                                    console.error('Received non-JSON response:', text.substring(0, 200));
                                    alert('Error deleting customer: Invalid response format');
                                    return;
                                }
                            } catch (parseError) {
                                console.error('Error parsing response:', parseError);
                                alert('Error deleting customer: Failed to parse server response');
                                return;
                            }

                            if (result.success) {
                                showCustomPopup('Customer "' + fullName + '" permanently deleted!');
                                // Reload customer accounts
                                setTimeout(() => {
                                    loadCustomerAccounts();
                                }, 1500);
                            } else {
                                const errorMsg = result.message || 'Unknown error';
                                if (errorMsg.includes('not found')) {
                                    showCustomPopup('Customer not found. It may have already been deleted.', 'error');
                                    // Reload to refresh the list
                                    setTimeout(() => {
                                        loadCustomerAccounts();
                                    }, 1500);
                                } else {
                                    alert('Failed to delete customer: ' + errorMsg);
                                }
                            }
                        } catch (error) {
                            console.error('Error deleting customer:', error);
                            alert('Error deleting customer: ' + (error.message || 'Unknown error'));
                        }
                    }



