                    // Load user permissions
                    async function loadUserPermissions(userId) {
                        try {
                            console.log('Loading permissions for user ID:', userId);
                            console.log('Making request to:', '/Employee/Admin/ManageUsers/Permissions/' + userId + '');

                            const response = await fetch('/Employee/Admin/ManageUsers/Permissions/' + userId + '', {
