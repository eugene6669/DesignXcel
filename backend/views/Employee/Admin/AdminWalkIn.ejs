                async function searchCity() {
                    const query = document.getElementById('modalCity')?.value;
                    const dropdown = document.getElementById('cityDropdown');
                    if (!dropdown) return;
                    
                    if (!query || query.length < 2) {
                        dropdown.style.display = 'none';
                        return;
                    }
                    
                    try {
                        const res = await fetch(`/api/address/search?q=${encodeURIComponent(query)}`);
                        const data = await res.json();
                        if (data.success && data.results && data.results.length > 0) {
                            citySearchResults = data.results;
                            dropdown.innerHTML = citySearchResults.slice(0, 10).map((result, idx) => {
                                // Escape for use in onclick attribute
                                const safeCity = (result.city || '').replace(/'/g, "&#39;").replace(/"/g, '&quot;');
                                const safeProvince = (result.province || '').replace(/'/g, "&#39;").replace(/"/g, '&quot;');
                                const safeRegion = (result.region || '').replace(/'/g, "&#39;").replace(/"/g, '&quot;');
                                const safePostalCode = (result.postalCode || '').replace(/'/g, "&#39;").replace(/"/g, '&quot;');
                                return `<div style="padding:10px;cursor:pointer;border-bottom:1px solid #e5e7eb;" onclick="selectCity('${safeCity}', '${safeProvince}', '${safeRegion}', '${safePostalCode}')">${result.city}${result.province ? ', ' + result.province : ''}${result.region ? ' (' + result.region + ')' : ''}</div>`;
                            }).join('');
                            dropdown.style.display = 'block';
                        } else {
                            dropdown.style.display = 'none';
                        }
                    } catch (err) {
                        console.error('Failed to search cities:', err);
                    }
                }

                async function autoFillLocationFromCity(forceExact = false) {
                    const cityInput = document.getElementById('modalCity');
                    const provinceSelect = document.getElementById('modalProvince');
                    const regionSelect = document.getElementById('modalRegion');
                    const postalCodeInput = document.getElementById('modalPostalCode');
                    if (!cityInput || !provinceSelect || !regionSelect) return;

                    const cityQuery = (cityInput.value || '').trim();
                    if (!cityQuery || cityQuery.length < 2) return;

                    try {
                        const res = await fetch(`/api/address/search?q=${encodeURIComponent(cityQuery)}`);
                        const data = await res.json();
                        if (!data.success || !Array.isArray(data.results) || data.results.length === 0) return;

                        const normalizedQuery = cityQuery.toLowerCase();
                        const exact = data.results.find(r => String(r.city || '').toLowerCase() === normalizedQuery);
                        const selected = exact || (!forceExact ? data.results[0] : null);
                        if (!selected) return;

                        const nextRegion = resolveRegionValue(selected.region || '');
                        const nextProvince = selected.province || '';
                        const nextPostal = selected.postalCode || '';

                        if (nextRegion) {
                            regionSelect.value = nextRegion;
                            await loadProvinces(nextProvince);
                        } else if (nextProvince) {
                            const extraOption = document.createElement('option');
                            extraOption.value = nextProvince;
                            extraOption.textContent = nextProvince;
                            provinceSelect.appendChild(extraOption);
                            provinceSelect.value = nextProvince;
                        }

                        if (nextPostal && postalCodeInput) {
                            postalCodeInput.value = nextPostal;
                        }
                    } catch (err) {
                        console.error('Failed to auto-fill location from city:', err);
                    }
                }
                
                async function selectCity(city, province, region, postalCode) {
                    // Values are already escaped in the onclick, just use them directly
                    const cityInput = document.getElementById('modalCity');
                    const provinceSelect = document.getElementById('modalProvince');
                    const regionSelect = document.getElementById('modalRegion');
                    const postalCodeInput = document.getElementById('modalPostalCode');
                    
                    if (cityInput) cityInput.value = city || '';
                    if (region && regionSelect) {
                        regionSelect.value = resolveRegionValue(region);
                        await loadProvinces(province || '');
                    } else if (province && provinceSelect) {
                        const extraOption = document.createElement('option');
                        extraOption.value = province;
                        extraOption.textContent = province;
                        provinceSelect.appendChild(extraOption);
                        provinceSelect.value = province;
                    }
                    if (postalCode && postalCodeInput) {
                        postalCodeInput.value = postalCode;
                    }
                    const dropdown = document.getElementById('cityDropdown');
                    if (dropdown) dropdown.style.display = 'none';
                }
                
