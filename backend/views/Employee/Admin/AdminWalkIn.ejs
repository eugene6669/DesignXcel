                    const province = document.getElementById('modalProvince')?.value;
                    if (!province) return;
                    
                    try {
                        const res = await fetch(`/api/address/cities/${encodeURIComponent(province)}`);
                        const data = await res.json();
                        if (data.success) {
                            // Cities are available but we use search instead
                        }
                    } catch (err) {
                        console.error('Failed to load cities:', err);
                    }
