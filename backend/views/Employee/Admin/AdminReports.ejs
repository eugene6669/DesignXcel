        function renderUsersTable(data) {
            const tbody = document.getElementById('users-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No users found</td></tr>';
                return;
            }

            const formatDateManila = (value) => {
                if (!value) return null;
                const d = new Date(value);
                if (Number.isNaN(d.getTime())) return null;
                return d.toLocaleDateString('en-US', { timeZone: 'Asia/Manila' });
            };

            tbody.innerHTML = data.map(item => {
                const statusClass = item.IsActive ? 'badge-success' : 'badge-danger';
                const statusText = item.IsActive ? 'Active' : 'Inactive';
                
                return `
                    <tr>
                        <td>${item.FullName || 'N/A'}</td>
                        <td>${item.Email || 'N/A'}</td>
                        <td>${item.RoleName || 'N/A'}</td>
                        <td><span class="badge ${statusClass}">${statusText}</span></td>
                        <td>${formatDateManila(item.CreatedAt) || 'N/A'}</td>
                        <td>${formatDateManila(item.LastLogin) || 'Never'}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderCustomersTable(data) {
            const tbody = document.getElementById('customers-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No customer accounts found</td></tr>';
                return;
            }

            const formatDateManila = (value) => {
                if (!value) return null;
                const d = new Date(value);
                if (Number.isNaN(d.getTime())) return null;
                return d.toLocaleDateString('en-US', { timeZone: 'Asia/Manila' });
            };

            tbody.innerHTML = data.map(item => {
                const statusClass = item.IsActive ? 'badge-success' : 'badge-danger';
                const statusText = item.IsActive ? 'Active' : 'Inactive';
                const customerID = item.CustomerID && item.CustomerID > 0 ? item.CustomerID : '-';
                
                return `
                    <tr>
                        <td>${customerID}</td>
                        <td>${item.FullName || 'N/A'}</td>
                        <td>${item.Email || 'N/A'}</td>
                        <td>${item.PhoneNumber || '-'}</td>
                        <td>${formatDateManila(item.CreatedAt) || 'N/A'}</td>
                        <td><span class="badge ${statusClass}">${statusText}</span></td>
                    </tr>
                `;
            }).join('');
        }

