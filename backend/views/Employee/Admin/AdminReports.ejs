        function renderInventoryChart(stats) {
            const canvas = document.getElementById('inventory-chart');
            if (!canvas || !stats) return;

            const ctx = canvas.getContext('2d');
            const maxValue = Math.max(
                stats.totalProducts || 0,
                stats.activeProducts || 0,
                stats.totalRawMaterials || 0,
                stats.activeRawMaterials || 0,
                stats.lowStock || 0,
                stats.lowStockRawMaterials || 0,
                1 // Minimum value to prevent division by zero
            );

            // Get container width for responsive sizing
            const container = canvas.parentElement;
            const width = container.clientWidth || 800;
            const height = 250;
            
            // Set canvas size
            canvas.width = width;
            canvas.height = height;

            const padding = 60;
            const chartWidth = width - (padding * 2);
            const chartHeight = height - (padding * 2);
            const barWidth = chartWidth / 6;
            const spacing = barWidth * 0.2;

            // Clear canvas
            ctx.clearRect(0, 0, width, height);

            // Draw chart background
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(padding, padding, chartWidth, chartHeight);

            // Chart data
            const chartData = [
                { label: 'Total Products', value: stats.totalProducts || 0, color: '#F0B21B' },
                { label: 'Active Products', value: stats.activeProducts || 0, color: '#10b981' },
                { label: 'Low Stock Products', value: stats.lowStock || 0, color: '#f59e0b' },
                { label: 'Total Raw Materials', value: stats.totalRawMaterials || 0, color: '#3b82f6' },
                { label: 'Active Raw Materials', value: stats.activeRawMaterials || 0, color: '#14b8a6' },
                { label: 'Low Stock Raw Materials', value: stats.lowStockRawMaterials || 0, color: '#f97316' }
            ];

            // Draw bars
            chartData.forEach((item, index) => {
                const x = padding + (index * barWidth) + (spacing / 2);
                const barHeight = maxValue > 0 ? (item.value / maxValue) * chartHeight : 0;
                const y = padding + chartHeight - barHeight;

                // Draw bar
                ctx.fillStyle = item.color;
                ctx.fillRect(x, y, barWidth - spacing, barHeight);

                // Draw value label on top of bar
                if (item.value > 0) {
                    ctx.fillStyle = '#0f172a';
                    ctx.font = 'bold 12px Inter';
                    ctx.textAlign = 'center';
                    ctx.fillText(item.value.toString(), x + (barWidth - spacing) / 2, y - 5);
                }

                // Draw label below bar
                ctx.fillStyle = '#64748b';
                ctx.font = '10px Inter';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'top';
                const labelY = padding + chartHeight + 25;
                
                // Split label into multiple lines if too long
                const words = item.label.split(' ');
                const lineHeight = 12;
                const maxWidth = barWidth - spacing;
                
                let yOffset = 0;
                let currentLine = '';
                
                words.forEach((word, idx) => {
                    const testLine = currentLine + (idx > 0 ? ' ' : '') + word;
                    const metrics = ctx.measureText(testLine);
                    
                    if (metrics.width > maxWidth && currentLine !== '') {
                        ctx.fillText(currentLine, x + (barWidth - spacing) / 2, labelY + yOffset);
                        currentLine = word;
                        yOffset += lineHeight;
                    } else {
                        currentLine = testLine;
                    }
                });
                
                if (currentLine !== '') {
                    ctx.fillText(currentLine, x + (barWidth - spacing) / 2, labelY + yOffset);
                }
            });

            // Draw axes
            ctx.strokeStyle = '#e5e7eb';
            ctx.lineWidth = 1;
            
            // X axis
            ctx.beginPath();
            ctx.moveTo(padding, padding + chartHeight);
            ctx.lineTo(padding + chartWidth, padding + chartHeight);
            ctx.stroke();

            // Y axis
            ctx.beginPath();
            ctx.moveTo(padding, padding);
            ctx.lineTo(padding, padding + chartHeight);
            ctx.stroke();

            // Y axis labels
            ctx.fillStyle = '#64748b';
            ctx.font = '11px Inter';
            ctx.textAlign = 'right';
            ctx.textBaseline = 'middle';
            
            const ySteps = 5;
            for (let i = 0; i <= ySteps; i++) {
                const value = Math.round((maxValue / ySteps) * (ySteps - i));
                const y = padding + (chartHeight / ySteps) * i;
                ctx.fillText(value.toString(), padding - 10, y);
                
                // Draw grid line
                if (i > 0) {
                    ctx.strokeStyle = '#e5e7eb';
                    ctx.lineWidth = 0.5;
                    ctx.beginPath();
                    ctx.moveTo(padding, y);
                    ctx.lineTo(padding + chartWidth, y);
                    ctx.stroke();
                }
            }
        }

