    <script>
        // Tab switching
        function switchTab(tabName) {
            // Update tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');

            // Update tab content
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById(`${tabName}-tab`).classList.add('active');

            // Load data for the active tab
            loadTabData(tabName);
        }

        // Load data for each tab
        async function loadTabData(tabName) {
            switch(tabName) {
                case 'inventory':
                    await loadInventoryData();
                    break;
                case 'sales':
                    await loadSalesData();
                    break;
                case 'masterlist':
                    await loadMasterlistData();
                    break;
            }
        }

        // Inventory Report Functions
        let inventoryFilters = {};
        async function loadInventoryData() {
            try {
                const params = new URLSearchParams(inventoryFilters);
                const response = await fetch(`/Employee/Admin/Reports/Inventory/Data?${params}`);
                const data = await response.json();
                
                if (data.success) {
                    populateInventoryCategoryFilter(data.categories || []);
                    renderInventoryTable(data.data);
                    renderRawMaterialsTable(data.rawMaterials || []);
                    renderInventoryStats(data.stats);
                    renderInventoryChart(data.stats);
                } else {
                    document.getElementById('inventory-tbody').innerHTML = 
                        `<tr><td colspan="9" class="empty-state">${data.error || 'Error loading inventory data'}</td></tr>`;
                }
            } catch (error) {
                console.error('Error loading inventory:', error);
                document.getElementById('inventory-tbody').innerHTML = 
                    `<tr><td colspan="9" class="empty-state">Error loading inventory data</td></tr>`;
            }
        }

        function populateInventoryCategoryFilter(categories) {
            const select = document.getElementById('inv-category');
            if (!select) return;
            const current = select.value;
            select.innerHTML = '<option value="">All Categories</option>';
            (categories || []).forEach(function(cat) {
                if (!cat) return;
                const opt = document.createElement('option');
                opt.value = cat;
                opt.textContent = cat;
                select.appendChild(opt);
            });
            if (current) select.value = current;
        }

        function renderInventoryStatusBadge(status) {
            const normalizedStatus = String(status || '').toLowerCase();
            const statusClass = normalizedStatus.includes('out') ? 'badge-danger'
                : normalizedStatus.includes('low') ? 'badge-warning'
                : normalizedStatus.includes('no available') ? 'badge-info'
                : 'badge-success';
            return `<span class="badge ${statusClass}">${status || 'Active'}</span>`;
        }

        function renderInventoryTable(data) {
            const tbody = document.getElementById('inventory-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="empty-state">No inventory data found</td></tr>';
                return;
            }

            const parents = data.filter(item => (item.RowType || 'Parent') === 'Parent');
            const variationsByParent = {};
            data.filter(item => item.RowType === 'Variation').forEach(v => {
                const pid = v.InventoryProductID;
                if (!variationsByParent[pid]) variationsByParent[pid] = [];
                variationsByParent[pid].push(v);
            });

            const rowsHtml = [];
            parents.forEach(parent => {
                const pid = parent.InventoryProductID;
                const variations = variationsByParent[pid] || [];
                const hasChildren = parent.HasVariations && variations.length > 0;
                const toggleBtn = hasChildren
                    ? `<button type="button" class="inv-report-toggle" data-parent-id="${pid}" aria-expanded="false" title="Show variations" style="background:none;border:none;cursor:pointer;padding:0 6px 0 0;font-size:12px;line-height:1;">▶</button>`
                    : '<span style="display:inline-block;width:18px;"></span>';
                rowsHtml.push(`
                    <tr class="inv-parent-row" data-parent-id="${pid}">
                        <td><span class="badge badge-success">Parent</span></td>
                        <td>${toggleBtn}<strong>${parent.Name || 'N/A'}</strong>${hasChildren ? ` <span style="color:#6b7280;font-size:0.85em;">(${variations.length} variation${variations.length === 1 ? '' : 's'})</span>` : ''}</td>
                        <td>—</td>
                        <td>${parent.CategoryName || 'N/A'}</td>
                        <td>${parent.AvailableQuantity ?? 0}</td>
                        <td>${parent.StockQuantity || 0}</td>
                        <td>—</td>
                        <td>${renderInventoryStatusBadge(parent.Status)}</td>
                        <td>${parent.LastUpdated ? new Date(parent.LastUpdated).toLocaleDateString() : 'N/A'}</td>
                    </tr>
                `);
                if (hasChildren) {
                    variations.forEach(v => {
                        rowsHtml.push(`
                            <tr class="inv-var-row" data-parent-id="${pid}" style="display:none;">
                                <td><span class="badge badge-info">Variation</span></td>
                                <td><span style="padding-left:28px;color:#555;">↳ ${v.Name || 'N/A'}</span></td>
                                <td>${v.SKU || '—'}</td>
                                <td>${v.CategoryName || parent.CategoryName || 'N/A'}</td>
                                <td>${v.AvailableQuantity ?? 0}</td>
                                <td>${v.StockQuantity || 0}</td>
                                <td>₱${Number(v.Price || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                                <td>${renderInventoryStatusBadge(v.Status)}</td>
                                <td>${v.LastUpdated ? new Date(v.LastUpdated).toLocaleDateString() : 'N/A'}</td>
                            </tr>
                        `);
                    });
                }
            });

            tbody.innerHTML = rowsHtml.join('');

