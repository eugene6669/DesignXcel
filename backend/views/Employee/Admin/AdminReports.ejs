                    { label: 'Gross Revenue', key: 'grossRevenue', currency: true, compute: function(s) {
                        if (s.grossRevenue != null) return s.grossRevenue;
                        return Number(s.grossProductSales || s.grossSales || 0)
                            + Number(s.deliveryRevenueGross || s.deliveryRevenue || 0);
