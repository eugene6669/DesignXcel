        window.addEventListener('resize', function() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(function() {
                const activeTab = document.querySelector('.tab-content.active');
                if (activeTab && activeTab.id === 'inventory-tab') {
                    // Reload chart if inventory tab is active
                    if (typeof renderInventoryChart === 'function') {
                        const statsContainer = document.getElementById('inventory-stats');
                        if (statsContainer && statsContainer.innerHTML) {
                            // Extract stats from current display
                            const statsText = statsContainer.innerText;
                            // Trigger a reload of inventory data to get fresh stats
                            loadInventoryData();
                        }
                    }
                } else if (activeTab && activeTab.id === 'sales-tab') {
                    const statsContainer = document.getElementById('stats-table-container');
                    if (statsContainer && statsContainer.dataset.stats) {
                        const stats = JSON.parse(statsContainer.dataset.stats);
                        let revenueComposition = null;
                        try {
                            if (statsContainer.dataset.revenueComposition) {
                                revenueComposition = JSON.parse(statsContainer.dataset.revenueComposition);
                            }
                        } catch (e) {
                            revenueComposition = null;
                        }
                        renderSalesCharts(stats, revenueComposition);
                    } else {
                        loadSalesData();
                    }
                }
            }, 250);
        });

        // Date validation functions
        function setupDateValidation(startDateId, endDateId) {
            const startDateInput = document.getElementById(startDateId);
            const endDateInput = document.getElementById(endDateId);
            
            if (!startDateInput || !endDateInput) return;
            
            // When start date changes, update end date min attribute
            startDateInput.addEventListener('change', function() {
                const startDate = this.value;
                if (startDate) {
                    endDateInput.setAttribute('min', startDate);
                    // If end date is before start date, clear it
                    if (endDateInput.value && endDateInput.value < startDate) {
                        endDateInput.value = '';
                        alert('End date cannot be before start date. Please select a valid end date.');
                    }
                } else {
                    endDateInput.removeAttribute('min');
                }
            });
            
            // When end date changes, validate it's not before start date
            endDateInput.addEventListener('change', function() {
                const startDate = startDateInput.value;
                const endDate = this.value;
                
                if (startDate && endDate && endDate < startDate) {
                    this.value = '';
                    alert('End date cannot be before start date. Please select a valid end date.');
                }
            });
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadInventoryData();
            
            // Setup date validation for all report tabs
            setupDateValidation('inv-date-from', 'inv-date-to');
            setupDateValidation('sales-date-from', 'sales-date-to');
            setupDateValidation('ml-date-from', 'ml-date-to');
        });

        // Handle logout modal
        async function handleLogout(event) {
            event.preventDefault();
            if (confirm('Are you sure you want to log out?')) {
                try {
                    const response = await fetch('/logout', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    if (response.ok) {
                        window.location.href = '/login';
                    }
                } catch (error) {
                    console.error('Logout error:', error);
                }
            }
        }
    </script>
