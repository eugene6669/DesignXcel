        // Sales Report Functions
        let salesFilters = {};
        async function loadSalesData() {
            try {
                const params = new URLSearchParams(salesFilters);
                const response = await fetch(`/Employee/Admin/Reports/Sales/Data?${params}`);
                const data = await response.json();
                
                if (data.success) {
                    renderSalesTable(data.data);
                    renderSalesStats(data.stats);
                    const salesMeta = document.getElementById('stats-table-container');
                    if (salesMeta) {
                        salesMeta.dataset.stats = JSON.stringify(data.stats || {});
                        salesMeta.dataset.revenueComposition = JSON.stringify(data.revenueComposition || null);
                    }
                    renderSalesCharts(data.stats, data.revenueComposition);
                } else {
                    document.getElementById('sales-tbody').innerHTML = 
                        `<tr><td colspan="14" class="empty-state">${data.error || 'Error loading sales data'}</td></tr>`;
                }
                return data;
            } catch (error) {
                console.error('Error loading sales:', error);
                document.getElementById('sales-tbody').innerHTML = 
                    `<tr><td colspan="14" class="empty-state">Error loading sales data</td></tr>`;
                return { success: false };
            }
        }

        const ORDER_STATUS_LABELS_JS = {
            Pending: 'Pending Verification',
            Processing: 'Processing',
            'Processing (Pickup)': 'Processing (Pickup)',
            Shipping: 'Shipping',
            Delivery: 'Delivery',
            Received: 'Received',
            Completed: 'Completed',
            Cancelled: 'Cancelled',
            Returned: 'Returned',
            Return: 'Returned',
            Refunded: 'Completed Refunded',
            'Completed Returned': 'Replacement',
            Declined: 'Declined'
        };

        function formatSalesOrderStatus(status) {
            if (!status) return 'N/A';
            return ORDER_STATUS_LABELS_JS[status] || status;
        }

        function formatSalesSummaryValue(stats, key, opts = {}) {
            const v = stats[key];
            if (opts.percent) return `${Number(v || 0).toFixed(1)}%`;
            if (opts.currency) return '₱' + Number(v || 0).toLocaleString('en-US', { minimumFractionDigits: 2 });
            return String(v ?? 0);
        }

        function formatSalesSummaryRowValue(val, opts) {
            if (opts && opts.percent) return `${Number(val || 0).toFixed(1)}%`;
            if (opts && opts.currency) return '₱' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 2 });
            return String(val ?? 0);
        }

        const SALES_SUMMARY_ROWS = [
            { key: 'grossProductSales', alt: 'grossSales', currency: true, label: 'Gross Sales' },
            { key: 'totalDiscounts', currency: true, label: 'Discounts' },
            { key: 'netSales', alt: 'netProductSales', currency: true, label: 'Net Sales' },
            { label: 'Gross Revenue', currency: true, compute: function(stats) {
                if (stats.grossRevenue != null) return Number(stats.grossRevenue);
                return Number(stats.grossProductSales || stats.grossSales || 0)
                    + Number(stats.deliveryRevenueGross || stats.deliveryRevenue || 0);
            }},
            { key: 'deliveryRevenueGross', alt: 'deliveryRevenue', currency: true, label: 'Delivery Revenue' },
            { key: 'originalDeliveryCost', currency: true, label: 'Original Delivery Cost' },
            { key: 'returnPickupCost', currency: true, label: 'Return Pick-Up Cost' },
            { key: 'replacementDeliveryCost', currency: true, label: 'Replacement Delivery Cost' },
            { label: 'Total Delivery Expense', currency: true, compute: function(stats) {
                if (stats.totalDeliveryExpense != null) return Number(stats.totalDeliveryExpense);
                if (stats.deliveryExpense != null) return Number(stats.deliveryExpense);
                return Number(stats.originalDeliveryCost || 0)
                    + Number(stats.returnPickupCost || 0)
                    + Number(stats.replacementDeliveryCost || 0);
            }},
            { label: 'Refunds', currency: true, compute: function(stats) {
                return Number(stats.productRefunds || 0) + Number(stats.deliveryRefunds || 0);
            }},
            { key: 'netRevenue', currency: true, label: 'Net Revenue' },
            { key: 'cogs', currency: true, label: 'COGS' },
            { key: 'grossProfit', currency: true, label: 'Gross Profit' },
            { key: 'totalOrders', label: 'Total Orders' },
            { key: 'totalCustomers', label: 'Total Customers' },
            { key: 'averageOrderValue', currency: true, label: 'Average Order Value' }
        ];

        function resolveSalesSummaryValue(stats, row) {
            if (typeof row.compute === 'function') return row.compute(stats);
            if (stats[row.key] != null) return stats[row.key];
            if (row.alt && stats[row.alt] != null) return stats[row.alt];
            return 0;
        }

        function buildSalesSummaryTableRows(stats) {
            return SALES_SUMMARY_ROWS.map(function(row) {
                const val = resolveSalesSummaryValue(stats, row);
                return [
                    row.label,
                    formatSalesSummaryRowValue(val, { currency: row.currency, percent: row.percent })
                ];
            });
        }

        function renderSalesTable(data) {
            const tbody = document.getElementById('sales-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="14" class="empty-state">No sales data found</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(item => {
                const statusClass = item.Status === 'Completed' || item.Status === 'Received' ? 'badge-success' :
                                   item.Status === 'Cancelled' || item.Status === 'Returned' || (item.Status && (item.Status.toLowerCase() === 'returned' || item.Status.toLowerCase() === 'return')) ? 'badge-danger' :
                                   item.Status === 'Pending' ? 'badge-warning' : 'badge-info';
                
                // Use TotalDiscounts directly from API response (calculated from OrderItems)
                // If TotalDiscounts is not available, fallback to 0
                const discount = item.TotalDiscounts || 0;
                
                // Format order items count for display
                let orderItemsCount = item.TotalItems || 0;
                if (item.OrderItems && Array.isArray(item.OrderItems)) {
                    orderItemsCount = item.OrderItems.length;
                }
                
                // Format product names and quantities for display
                let productNamesQuantitiesHtml = 'N/A';
                
                if (item.OrderItems && Array.isArray(item.OrderItems) && item.OrderItems.length > 0) {
                    productNamesQuantitiesHtml = item.OrderItems.map(orderItem => {
                        const name = orderItem.name || orderItem.Name || 'Unknown Product';
                        const qty = orderItem.quantity || orderItem.Quantity || 0;
                        return `${name} (Qty: ${qty})`;
                    }).join('<br>');
                } else if (item.TotalItems && item.TotalItems > 0) {
                    // Fallback message if OrderItems array is not available
                    productNamesQuantitiesHtml = `${item.TotalItems} item(s) - Details not available`;
                } else if (item.OrderItems && !Array.isArray(item.OrderItems)) {
                    productNamesQuantitiesHtml = item.TotalItems ? `${item.TotalItems} item(s) - Details not available` : 'N/A';
                }
                
                return `
                    <tr>
                        <td>${item.OrderID || 'N/A'}</td>
                        <td>${item.ReferenceNumber || 'N/A'}</td>
                        <td>${item.CustomerName || 'N/A'}</td>
                        <td>${item.CustomerEmail || 'N/A'}</td>
                        <td>${item.OrderDate ? new Date(item.OrderDate).toLocaleDateString() : 'N/A'}</td>
                        <td><span class="badge ${statusClass}">${formatSalesOrderStatus(item.Status)}</span></td>
                        <td>${orderItemsCount}</td>
                        <td style="max-width: 300px; word-wrap: break-word; line-height: 1.5;">${productNamesQuantitiesHtml}</td>
                        <td>₱${Number(item.Subtotal || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(item.ExtraDeliveryFee || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(item.DeliveryCost || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(item.TotalAmount || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(discount).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>${item.PaymentMethod || 'N/A'}</td>
                    </tr>
                `;
            }).join('');
        }

