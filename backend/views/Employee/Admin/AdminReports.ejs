        function formatSalesFiltersSummary(filters) {
            if (!filters) return 'None';
            const parts = [];
            if (filters.search) parts.push(`Search: ${filters.search}`);
            if (filters.status) {
                parts.push(`Status: ${filters.status === 'Completed Returned' ? 'Replacement' : filters.status}`);
            }
            if (filters.payment) parts.push(`Payment: ${filters.payment}`);
            if (filters.dateFrom) parts.push(`From: ${filters.dateFrom}`);
            if (filters.dateTo) parts.push(`To: ${filters.dateTo}`);
            if (filters.amountMin) parts.push(`Min: ₱${Number(filters.amountMin).toLocaleString('en-US', { minimumFractionDigits: 2 })}`);
            if (filters.amountMax) parts.push(`Max: ₱${Number(filters.amountMax).toLocaleString('en-US', { minimumFractionDigits: 2 })}`);
            return parts.length ? parts.join(' · ') : 'None';
        }

        function countSalesTableRows() {
            const table = document.getElementById('sales-tbody');
            if (!table) return 0;
            return Array.from(table.querySelectorAll('tr')).filter(tr => !tr.querySelector('.empty-state')).length;
        }

        function refreshCSVPreviewData() {
            const statsContainer = document.getElementById('stats-table-container');
            let stats = null;
            try {
                stats = statsContainer && statsContainer.dataset.stats ? JSON.parse(statsContainer.dataset.stats) : null;
            } catch (e) {
                stats = null;
            }
            return {
                stats,
                rowCount: countSalesTableRows(),
                filters: { ...salesFilters }
            };
        }

        function isCSVPreviewOpen() {
            const modal = document.getElementById('csv-preview-modal');
            return modal && modal.style.display === 'flex';
        }

        async function refreshCSVPreviewIfOpen() {
            if (!isCSVPreviewOpen()) return;
            const previewBody = document.getElementById('csv-preview-body');
            if (previewBody) previewBody.innerHTML = '<p>Updating preview…</p>';
            csvPreviewData = refreshCSVPreviewData();
            displayCSVPreview();
        }

        // CSV Preview Modal
        let csvPreviewData = null;

        async function showCSVPreview() {
            ensureCSVPreviewModal();
            const csvModal = document.getElementById('csv-preview-modal');
            const previewBody = document.getElementById('csv-preview-body');
            csvModal.style.display = 'flex';
            previewBody.innerHTML = '<p>Loading preview…</p>';

            await loadSalesData();
            csvPreviewData = refreshCSVPreviewData();
            displayCSVPreview();
        }

        function ensureCSVPreviewModal() {
            if (document.getElementById('csv-preview-modal')) return;
            const modalHTML = `
                <div id="csv-preview-modal" class="csv-preview-overlay" style="display: none;">
                    <div class="csv-preview-content">
                        <div class="csv-preview-header">
                            <h2>CSV Export Preview</h2>
                            <button type="button" class="csv-preview-close" onclick="closeCSVPreview()" aria-label="Close">&times;</button>
                        </div>
                        <div class="csv-preview-body" id="csv-preview-body">
                            <p>Loading preview…</p>
                        </div>
                        <div class="csv-preview-footer">
                            <button type="button" class="btn-filter btn-filter-secondary" onclick="closeCSVPreview()">Cancel</button>
                            <button type="button" class="btn-filter btn-export" onclick="downloadCSV()">Download CSV</button>
                        </div>
                    </div>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', modalHTML);
        }

        function displayCSVPreview() {
            ensureCSVPreviewModal();
            const csvModal = document.getElementById('csv-preview-modal');
            const previewBody = document.getElementById('csv-preview-body');
            const filterSummary = formatSalesFiltersSummary(csvPreviewData?.filters);

            if (csvPreviewData && csvPreviewData.stats) {
                const stats = csvPreviewData.stats;
                const summaryRowsHtml = buildSalesSummaryTableRows(stats)
                    .map(function(cells) {
                        return '<tr><td>' + cells[0] + '</td><td style="text-align:right">' + cells[1] + '</td></tr>';
                    })
                    .join('');
                previewBody.innerHTML = `
                    <div class="csv-preview-section">
                        <h3>Summary (included in file)</h3>
                        <table class="csv-preview-table">
                            <thead><tr><th>Metric</th><th style="text-align:right">Value</th></tr></thead>
                            <tbody>${summaryRowsHtml}</tbody>
                        </table>
                    </div>
                    <div class="csv-preview-section">
                        <h3>Orders sheet</h3>
                        <p style="margin: 0 0 0.5rem 0; color: var(--text-light); font-size: 0.9rem;">
                            ${csvPreviewData.rowCount || 0} order(s): Order #, Reference, Date, Customer, Email, Status, Products, Subtotal, Discount, Extra Delivery, Delivery, Total, Payment, In Gross Sales, In Net Revenue
                        </p>
                        <p style="margin: 0; font-size: 0.85rem; color: var(--text-light);">
                            <strong>Format:</strong> CSV (UTF-8, opens in Excel) &nbsp;•&nbsp;
                            <strong>Filters:</strong> ${filterSummary}
                        </p>
                    </div>
                `;
            } else {
                previewBody.innerHTML = '<p>No data available for preview.</p>';
            }
            
            csvModal.style.display = 'flex';
        }

        function closeCSVPreview() {
            const csvModal = document.getElementById('csv-preview-modal');
            if (csvModal) {
                csvModal.style.display = 'none';
            }
        }

        function downloadCSV() {
            closeCSVPreview();
            const params = new URLSearchParams(salesFilters);
            params.set('format', 'csv');
            window.location.href = `/Employee/Admin/Reports/Sales/Export?${params}`;
        }

