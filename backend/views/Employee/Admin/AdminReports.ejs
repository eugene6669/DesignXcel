        function renderSalesCharts(stats, revenueComposition) {
            if (!stats) return;
            
            renderRevenueChart(stats);
            renderRevenueComposition(revenueComposition);
        }

        function escapeCompositionLabel(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function renderRevenueComposition(composition) {
            const canvas = document.getElementById('sales-composition-chart');
            const legendEl = document.getElementById('sales-composition-legend');
            const categoryEl = document.getElementById('sales-composition-by-category');
            if (!canvas || !legendEl || !categoryEl) return;

            const merch = composition ? parseFloat(composition.merchandise || 0) : 0;
            const delivery = composition ? parseFloat(composition.delivery || 0) : 0;
            const total = merch + delivery;

            const wrap = canvas.parentElement;
            const rawSize = (wrap && wrap.clientWidth ? Math.min(wrap.clientWidth - 240, 220) : 200);
            const size = Math.max(160, Math.min(220, rawSize > 0 ? rawSize : 200));
            canvas.width = size;
            canvas.height = size;

            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, size, size);

            const fmtPhp = (v) => '₱' + Number(v).toLocaleString('en-US', { minimumFractionDigits: 2 });
            const pct = (part) => (total > 0 ? ((part / total) * 100).toFixed(1) : '0.0');

            legendEl.innerHTML = `
                <li><span class="composition-swatch" style="background:#10b981"></span>Merchandise <strong>${pct(merch)}%</strong><div class="composition-legend-value">${fmtPhp(merch)} — subtotal (no delivery)</div></li>
                <li><span class="composition-swatch" style="background:#06b6d4"></span>Delivery &amp; extra <strong>${pct(delivery)}%</strong><div class="composition-legend-value">${fmtPhp(delivery)}</div></li>
            `;

            const cx = size / 2;
            const cy = size / 2;
            const outerR = Math.min(cx, cy) * 0.85;
            const innerR = outerR * 0.58;

            const drawArcSlice = (start, sweep, color) => {
                if (sweep <= 0 || total <= 0) return;
                const end = start + sweep;
                ctx.beginPath();
                ctx.arc(cx, cy, outerR, start, end);
                ctx.arc(cx, cy, innerR, end, start, true);
                ctx.closePath();
                ctx.fillStyle = color;
                ctx.fill();
            };

            if (total <= 0) {
                ctx.beginPath();
                ctx.arc(cx, cy, outerR, 0, Math.PI * 2);
                ctx.strokeStyle = '#e5e7eb';
                ctx.lineWidth = outerR - innerR;
                ctx.stroke();
                ctx.fillStyle = '#94a3b8';
                ctx.font = '12px Inter, sans-serif';
                ctx.textAlign = 'center';
                ctx.fillText('No revenue', cx, cy);
                categoryEl.innerHTML = '<p class="empty-state" style="margin:0;font-size:0.85rem;color:var(--text-light);">No category breakdown for this filter.</p>';
                return;
            }

            let angle = -Math.PI / 2;
            drawArcSlice(angle, (merch / total) * Math.PI * 2, '#10b981');
            angle += (merch / total) * Math.PI * 2;
            drawArcSlice(angle, (delivery / total) * Math.PI * 2, '#06b6d4');

            const byCat = (composition && Array.isArray(composition.byCategory)) ? composition.byCategory : [];
            if (!byCat.length) {
                categoryEl.innerHTML = '<p class="empty-state" style="margin:0;font-size:0.85rem;color:var(--text-light);">No category breakdown for this filter.</p>';
                return;
            }

            categoryEl.innerHTML = byCat.map(row => {
                const w = Math.min(100, Math.max(0, row.percent || 0));
                const label = escapeCompositionLabel(row.category || 'Uncategorized');
                return `
                    <div class="composition-cat-row">
                        <div class="composition-cat-label">${label}</div>
                        <div class="composition-cat-bar-wrap"><div class="composition-cat-bar" style="width:${w}%"></div></div>
                        <div class="composition-cat-meta">${Number(row.percent || 0).toFixed(1)}% · ${fmtPhp(row.revenue || 0)}</div>
                    </div>
                `;
            }).join('');
        }

        function renderRevenueChart(stats) {
            const canvas = document.getElementById('sales-revenue-chart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const container = canvas.parentElement;
            const width = container.clientWidth || 600;
            const height = 300;
            canvas.width = width;
            canvas.height = height;

            const padding = 60;
            const chartWidth = width - (padding * 2);
            const chartHeight = height - (padding * 2);

            ctx.clearRect(0, 0, width, height);

            // Chart data
            const revenueData = [
                { label: 'Gross Product', value: parseFloat(stats.grossProductSales || stats.grossSales || 0), color: '#F0B21B' },
                { label: 'Net Product', value: parseFloat(stats.netProductSales || 0), color: '#10b981' },
                { label: 'Recognized', value: parseFloat(stats.recognizedProductRevenue ?? stats.netSales ?? 0), color: '#8b5cf6' },
                { label: 'Net Revenue', value: parseFloat(stats.netRevenue || 0), color: '#3b82f6' },
                { label: 'Net Delivery', value: parseFloat(stats.netDeliveryRevenue || stats.deliveryRevenues || 0), color: '#06b6d4' }
            ];

            const maxValue = Math.max(...revenueData.map(d => d.value), 1);
            const barWidth = chartWidth / revenueData.length;
            const spacing = barWidth * 0.2;

            // Draw background
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(padding, padding, chartWidth, chartHeight);

            // Draw bars
            revenueData.forEach((item, index) => {
                const x = padding + (index * barWidth) + (spacing / 2);
                const barHeight = maxValue > 0 ? (item.value / maxValue) * chartHeight : 0;
                const y = padding + chartHeight - barHeight;

                // Draw bar
                ctx.fillStyle = item.color;
                ctx.fillRect(x, y, barWidth - spacing, barHeight);

                // Draw value label
                if (item.value > 0) {
                    ctx.fillStyle = '#0f172a';
                    ctx.font = 'bold 10px Inter';
                    ctx.textAlign = 'center';
                    const formattedValue = (item.value / 1000).toFixed(1) + 'K';
                    ctx.fillText(formattedValue, x + (barWidth - spacing) / 2, y - 5);
                }

                // Draw label
                ctx.fillStyle = '#64748b';
                ctx.font = '9px Inter';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'top';
                const labelY = padding + chartHeight + 20;
                
                // Split long labels
                const words = item.label.split(' ');
                let currentLine = '';
                let yOffset = 0;
                words.forEach((word, idx) => {
                    const testLine = currentLine + (idx > 0 ? ' ' : '') + word;
                    const metrics = ctx.measureText(testLine);
                    if (metrics.width > barWidth - spacing && currentLine !== '') {
                        ctx.fillText(currentLine, x + (barWidth - spacing) / 2, labelY + yOffset);
                        currentLine = word;
                        yOffset += 11;
                    } else {
                        currentLine = testLine;
                    }
                });
                if (currentLine !== '') {
                    ctx.fillText(currentLine, x + (barWidth - spacing) / 2, labelY + yOffset);
                }
            });

            // Draw axes
            ctx.strokeStyle = '#e5e7eb';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(padding, padding + chartHeight);
            ctx.lineTo(padding + chartWidth, padding + chartHeight);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(padding, padding);
            ctx.lineTo(padding, padding + chartHeight);
            ctx.stroke();

            // Y axis labels
            ctx.fillStyle = '#64748b';
            ctx.font = '10px Inter';
            ctx.textAlign = 'right';
            ctx.textBaseline = 'middle';
            const ySteps = 5;
            for (let i = 0; i <= ySteps; i++) {
                const value = (maxValue / ySteps) * (ySteps - i);
                const y = padding + (chartHeight / ySteps) * i;
                const formattedValue = (value / 1000).toFixed(1) + 'K';
                ctx.fillText(formattedValue, padding - 10, y);
                
                if (i > 0) {
                    ctx.strokeStyle = '#e5e7eb';
                    ctx.lineWidth = 0.5;
                    ctx.beginPath();
                    ctx.moveTo(padding, y);
                    ctx.lineTo(padding + chartWidth, y);
                    ctx.stroke();
                }
            }
        }


