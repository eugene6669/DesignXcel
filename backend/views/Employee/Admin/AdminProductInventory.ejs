                        <div>
                            <label for="variationColor">Color:</label>
                            <input type="text" id="variationColor" name="color">
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                        <div>
                            <label for="variationQuantity">Quantity:</label>
                            <input type="number" id="variationQuantity" name="quantity" min="1" required>
                            <small id="availableStockInfo" style="display: block; margin-top: 5px; color: #666; font-size: 0.85em;"></small>
                        </div>
                        <div>
                            <label for="variationPrice">Price:</label>
                            <input type="number" id="variationPrice" name="price" step="0.01" min="0" placeholder="0.00">
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
                        <div>
                            <label for="variationMainImage">Main Image:</label>
                            <input type="file" id="variationMainImage" class="variation-main-image" name="variationMainImage" accept="image/*">
                        </div>
                        <div>
                            <label for="variationThumbnails">Thumbnails (up to 4):</label>
                            <input type="file" id="variationThumbnails" class="variation-thumbnails" name="variationThumbnails" accept="image/*" multiple>
                        </div>
                        <div style="grid-column: span 2;">
                            <label for="variationModel3d">3D Model (GLB/GLTF):</label>
                            <input type="file" id="variationModel3d" class="variation-model3d" name="variationModel3d" accept=".glb,.gltf,model/gltf-binary,model/gltf+json">
                        </div>
                    </div>
                    <button type="submit" style="background: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer;">Add Variation</button>
                </form>
            </div>

            <!-- Variations List -->
            <div id="variationsList">
                <h4>Existing Variations</h4>
                <div id="variationsContainer">
                    <!-- Variations will be loaded here -->
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Variation Status Modal -->
    <div id="editVariationStatusModal" class="modal">
        <div class="modal-content">
            <span class="close-button" id="closeEditVariationStatusModal" onclick="if(window.closeEditVariationStatusModalFunc) window.closeEditVariationStatusModalFunc();">&times;</span>
            <h3>Edit Variation Status & Quantity</h3>
            <form id="editVariationStatusForm" method="POST" action="#" onsubmit="return false;">
                <input type="hidden" id="editVariationStatusVariationID" name="variationID">
                
                <div class="form-group">
                    <label for="editVariationStatusName">Variation Name:</label>
                    <input type="text" id="editVariationStatusName" readonly style="background-color: #f5f5f5;">
                </div>

                <div class="form-group">
                    <label for="editVariationStatusSelect">Status:</label>
                    <select id="editVariationStatusSelect" onchange="showVariationQuantityForStatus()" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 1em;">
                        <option value="">-- Select Status --</option>
                        <option value="available">Available</option>
                        <option value="damaged">Damaged</option>
                        <option value="repaired">Repaired</option>
                        <option value="disposed">Disposed</option>
                    </select>
                </div>

                <div id="variationStatusQuantityInputContainer" style="display: none;">
                    <div class="form-group">
                        <label for="editVariationStatusQuantityInput">Quantity:</label>
                        <input type="number" id="editVariationStatusQuantityInput" name="quantity" min="0" value="0" onchange="updateVariationQuantityForStatus()" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 1em;">
                    </div>
                </div>

                <!-- Hidden inputs to store all status quantities -->
                <input type="hidden" id="editVariationStatusAvailableQuantity" name="availableQuantity" value="0">
                <input type="hidden" id="editVariationStatusDamagedQuantity" name="damagedQuantity" value="0">
                <input type="hidden" id="editVariationStatusRepairedQuantity" name="repairedQuantity" value="0">
                <input type="hidden" id="editVariationStatusDisposedQuantity" name="disposedQuantity" value="0">

                <!-- Current quantities display -->
                <div style="margin: 15px 0; padding: 10px; background-color: #f8f9fa; border-radius: 4px; font-size: 0.9em;">
                    <strong>Current:</strong> Available: <span id="currentVariationStatusAvailableQty">0</span> | Damaged: <span id="currentVariationStatusDamagedQty">0</span> | Repaired: <span id="currentVariationStatusRepairedQty">0</span> | Disposed: <span id="currentVariationStatusDisposedQty">0</span>
                </div>

                <div class="form-group" style="padding: 12px; background: #f8f9fa; border-radius: 6px; border: 1px solid #dee2e6; margin-bottom: 12px;">
                    <strong>Variation Media</strong>
                    <div id="editVariationStatusMediaPreview" style="margin: 8px 0;"></div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px;">
                        <div>
                            <label for="editVariationStatusMainImage">Main Image</label>
                            <input type="file" id="editVariationStatusMainImage" accept="image/*">
                        </div>
                        <div>
                            <label for="editVariationStatusThumbnails">Thumbnails (up to 4)</label>
                            <input type="file" id="editVariationStatusThumbnails" accept="image/*" multiple>
                        </div>
                        <div style="grid-column: span 2;">
                            <label for="editVariationStatusModel3d">3D Model (GLB/GLTF)</label>
                            <input type="file" id="editVariationStatusModel3d" accept=".glb,.gltf,model/gltf-binary,model/gltf+json">
                        </div>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 10px; padding: 15px; border: 1px solid #dee2e6; border-radius: 6px; background: #f8f9fa;">
                    <h4 style="margin: 0 0 8px 0; font-size: 1em;">Raw Materials</h4>
                    <p style="color: #666; font-size: 0.85em; margin: 0 0 10px 0;">Qty per unit stocked or restocked. Saving updates raw materials; increasing stock deducts from Raw Materials stock.</p>
                    <div id="editVariationRecipeStatus" style="font-size: 0.9em; margin-bottom: 10px; color: #666;"><em>Loading raw materials…</em></div>
                    <div class="materials-section">
                        <div id="editVariationMaterialsContainer"></div>
                        <button type="button" id="addEditVariationMaterialBtn" class="add-material-btn">+ Add Material</button>
                        <div id="editVariationMaterialsSummary" style="margin-top: 10px; padding: 8px; background: #fff; border-radius: 4px; font-size: 0.9em;">
                            <strong>Raw Materials:</strong>
                            <div id="editVariationMaterialsSummaryList" style="margin-top: 4px; color: #666;"><em>None</em></div>
                        </div>
                    </div>
                    <input type="hidden" id="editVariationRecipeMaterials" name="recipeMaterials" value="">
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
                    <button type="button" id="cancelEditVariationStatus" onclick="if(window.closeEditVariationStatusModalFunc) window.closeEditVariationStatusModalFunc();" style="background: #6c757d; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer;">Cancel</button>
                    <button type="submit" id="submitEditVariationStatus" style="background: #007bff; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer;">Update Variation Status</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Inventory Changes Confirmation Modal -->
    <div id="inventoryConfirmationModal" class="inventory-confirmation-modal">
        <div class="inventory-confirmation-content">
            <h3>Confirm Inventory Changes</h3>
            <div id="inventoryChangesList" class="changes-list"></div>
            <p style="text-align: center; margin-bottom: 0; color: #666;">Proceed with these changes?</p>
            <div class="inventory-confirmation-buttons">
                <button class="inventory-cancel-btn" id="cancelInventoryChanges">Cancel</button>
                <button class="inventory-confirm-btn" id="confirmInventoryChanges">OK</button>
            </div>
        </div>
    </div>

    <% if (locals.error && locals.error.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= error %>', true);
        });
    </script>
    <% } %>
    <% if (locals.success && locals.success.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= success %>');
        });
    </script>
    <% } %>
</body>
</html>


