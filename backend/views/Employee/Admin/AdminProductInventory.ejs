</head>
<body class="page-inventory">
    <!-- Custom Success/Error Popup -->
    <div id="customPopup" class="custom-popup">
        <div class="custom-popup-content">
            <span class="custom-popup-icon">âœ“</span>
            <span class="custom-popup-message"></span>
        </div>
    </div>

    <div class="dashboard-container">
        <!-- Sidebar content -->
        <div class="sidebar">
            <%- include('partials/sidebar', { activePage: 'inventory' }) %>
        </div>
        <div class="main-content">
            <div class="header">
                <h2>Inventory Management</h2>
                <p class="products-list-hint">Step 2: build products from your listing — BOM bundles, raw materials, <strong>dimensions</strong>, variations, and stock. Then publish on the <a href="/Employee/Admin/Storefront">Storefront</a>.</p>
                <div class="product-workflow-steps" role="list">
                    <span><strong>1. Products Listing</strong> — plan</span>
                    <span>&rarr;</span>
                    <span><strong class="step-active">2. Inventory</strong> — build &amp; stock</span>
                    <span>&rarr;</span>
                    <span><strong>3. Storefront</strong> — customer-facing</span>
                </div>
            </div>

            <div class="tab-navigation" role="tablist">
                <button type="button" class="tab-button<%= (typeof activeTab !== 'undefined' && (activeTab === 'ProductInventory' || activeTab === 'products')) || (typeof activeTab === 'undefined') ? ' active' : '' %>" data-tab="ProductInventory" id="tabBtnProductInventory">Product Inventory</button>
                <button type="button" class="tab-button<%= typeof activeTab !== 'undefined' && activeTab === 'raw-materials' ? ' active' : '' %>" data-tab="raw-materials" id="tabBtnRawMaterials">Raw Materials</button>
                <button type="button" class="tab-button<%= typeof activeTab !== 'undefined' && (activeTab === 'rawmaterials-bundles' || activeTab === 'bom-bundles') ? ' active' : '' %>" data-tab="rawmaterials-bundles" id="tabBtnBomBundles">Raw Materials Bundles</button>
                <button type="button" class="tab-button<%= typeof activeTab !== 'undefined' && activeTab === 'stock-movement' ? ' active' : '' %>" data-tab="stock-movement" id="tabBtnStockMovement">Stock Movement</button>
            </div>

            <div id="productsTab" class="tab-content<%= (typeof activeTab === 'undefined' || activeTab === 'ProductInventory' || activeTab === 'products') ? ' active' : '' %>" data-search-filter="<%= (typeof listFilters !== 'undefined' && listFilters.search) ? String(listFilters.search).replace(/"/g, '&quot;') : '' %>">
            <div class="content-area">
                <% 
                    // Use allInventoryProducts directly from InventoryProducts table
                    // All products now have inventory data stored directly in InventoryProducts
                    const fmtDate = typeof formatInventoryDate === 'function'
                        ? formatInventoryDate
                        : function(v) { return v ? String(v) : 'N/A'; };
                    const allProductsList = typeof allInventoryProducts !== 'undefined' && allInventoryProducts.length > 0 
                        ? allInventoryProducts.map(product => ({
                            InventoryProductID: product.InventoryProductID,
                            InventoryProductName: product.InventoryProductName,
                            InventoryProductSKU: product.InventoryProductSKU,
                            InventoryProductCategory: product.InventoryProductCategory,
                            InventoryProductPrice: product.InventoryProductPrice,
                            InventoryProductCostPrice: product.InventoryProductCostPrice,
                            InventoryItemCostTotal: product.InventoryItemCostTotal || 0,
                            InventoryProductImageURL: product.InventoryProductImageURL,
                            InventoryProductSKU: product.InventoryProductSKU || '',
                            Dimensions: product.Dimensions || null,
                            LastDateAdded: product.LastDateAdded || product.DateAdded,
                            LastDateAddedLabel: fmtDate(product.LastDateAdded || product.DateAdded, 'N/A'),
                            TotalQuantity: product.TotalQuantity || 0,
                            AvailableQuantity: product.AvailableQuantity || 0,
                            DamagedQuantity: product.DamagedQuantity || 0,
                            ReturnedQuantity: product.ReturnedQuantity || 0,
                            RepairedQuantity: product.RepairedQuantity || 0,
                            DisposedQuantity: product.DisposedQuantity || 0,
                            InventoryStatus: product.InventoryStatus || 'no_stock',
                            ListingStage: product.ListingStage || 'built',
                            Notes: product.Notes || '',
                            hasInventory: (product.TotalQuantity || 0) > 0
                        }))
                        : [];
                    const buildFromInventoryProductId = typeof buildFromQuery !== 'undefined' ? buildFromQuery : '';
                    function formatListDate(val) {
                        return fmtDate(val, 'N/A');
                    }
                    function formatDimensionsCompact(val) {
                        if (!val) return '—';
                        try {
                            const d = typeof val === 'string' ? JSON.parse(val) : val;
                            const fmt = function(v) {
                                if (v == null || v === '') return null;
                                const n = Number(v);
                                return isNaN(n) ? String(v) : (Number.isInteger(n) ? String(n) : n.toFixed(1));
                            };
                            const l = fmt(d.length);
                            const w = fmt(d.width);
                            const h = fmt(d.height);
                            if (l == null && w == null && h == null) return '—';
                            return (l != null ? l : '—') + '×' + (w != null ? w : '—') + '×' + (h != null ? h : '—');
                        } catch (e) {
                            return '—';
                        }
                    }
                    const invPag = typeof pagination !== 'undefined' ? pagination : { page: 1, limit: 25, totalCount: 0, totalPages: 1 };
                    const invFilters = typeof listFilters !== 'undefined' ? listFilters : { search: '', category: '' };
                    const invCategories = typeof categories !== 'undefined' ? categories : [];
                    function invListUrl(pageNum) {
                        const parts = [];
                        if (typeof activeTab !== 'undefined' && activeTab === 'raw-materials') {
                            parts.push('tab=raw-materials');
                        } else if (typeof activeTab !== 'undefined' && (activeTab === 'rawmaterials-bundles' || activeTab === 'bom-bundles')) {
                            parts.push('tab=rawmaterials-bundles');
                        } else if (typeof activeTab !== 'undefined' && activeTab === 'stock-movement') {
                            parts.push('tab=stock-movement');
                        } else {
                            parts.push('tab=ProductInventory');
                        }
                        parts.push('page=' + encodeURIComponent(pageNum));
                        if (invFilters.search) parts.push('search=' + encodeURIComponent(invFilters.search));
                        if (invFilters.category) parts.push('category=' + encodeURIComponent(invFilters.category));
                        if (typeof inventoryProductIdFocus !== 'undefined' && inventoryProductIdFocus) {
                            parts.push('inventoryProductId=' + encodeURIComponent(inventoryProductIdFocus));
                        }
                        return '/Employee/Admin/Inventory?' + parts.join('&');
                    }
                    function stockQtyClass(qty) {
                        const n = Number(qty) || 0;
                        if (n < 0) return 'stock-qty-negative';
                        if (n === 0) return 'stock-qty-out';
                        if (n <= 10) return 'stock-qty-critical';
                        if (n <= 20) return 'stock-qty-low';
                        return 'stock-qty-normal';
                    }
                    const invRangeStart = invPag.totalCount > 0 ? (invPag.page - 1) * invPag.limit + 1 : 0;
                    const invRangeEnd = invPag.totalCount > 0 ? Math.min(invPag.page * invPag.limit, invPag.totalCount) : 0;
                %>


                <div class="inventory-filter-card" data-inventory-search="<%= (invFilters.search || '').replace(/"/g, '&quot;') %>">
                    <form method="get" action="/Employee/Admin/Inventory" class="inventory-filter-form">
                        <input type="hidden" name="tab" value="ProductInventory">
                        <input type="hidden" name="page" value="1">
                        <div class="inventory-filter-field">
                            <label for="invSearch">Search</label>
                            <input type="search" id="invSearch" name="search" value="<%= invFilters.search || '' %>" placeholder="Name or variation SKU">
                        </div>
                        <div class="inventory-filter-field">
                            <label for="invCategory">Category</label>
                            <select id="invCategory" name="category">
                                <option value="">All categories</option>
                                <% invCategories.forEach(function(cat) { %>
                                    <option value="<%= cat %>"<%= invFilters.category === cat ? ' selected' : '' %>><%= cat %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="inventory-filter-actions">
                            <button type="submit" class="pi-btn pi-btn-primary inventory-filter-apply-btn">Apply</button>
                            <% if (invFilters.search || invFilters.category) { %>
                            <a href="/Employee/Admin/Inventory?tab=ProductInventory" class="pi-btn pi-btn-secondary">Clear</a>
                            <% } %>
                        </div>
                    </form>
                    <% if (invPag.totalCount > 0) { %>
                    <p class="inventory-list-summary">Showing <%= invRangeStart %>&ndash;<%= invRangeEnd %> of <%= invPag.totalCount %> products</p>
                    <% } %>
                </div>



    <% if (locals.error && locals.error.length > 0) { %>
                    <div class="error-message"><%= error %></div>
                <% } %>
                <% if (locals.success && locals.success.length > 0) { %>
                    <% const hideRawMaterialFlashOnProducts = /raw material/i.test(String(success || '')); %>
                    <div class="success-message<%= hideRawMaterialFlashOnProducts ? ' success-message--raw-material' : '' %>"><%= success %></div>
                <% } %>

                <%- include('partials/create-inventory-product-modal', {
                    categories: invCategories,
                    bomBundles: typeof bomBundles !== 'undefined' ? bomBundles : [],
                    buildFromInventoryProductId: buildFromInventoryProductId
                }) %>

                <%- include('partials/product-listing-expandable', {
                    allProductsList: allProductsList,
                    invFilters: invFilters,
                    stockQtyClass: stockQtyClass,
                    formatListDate: formatListDate,
                    showReturnColumns: false,
                    showVariationReturnColumns: true,
                    showParentQty: false,
                    parentQtyField: 'total',
                    showActions: true,
                    showVariationActions: true,
                    showStorefront: false,
                    showDiscount: false,
                    showListingStage: false,
                    listingBuildUrlPrefix: '/Employee/Admin/Inventory?tab=ProductInventory&buildFrom=',
                    actionStyle: 'inventory',
                    showParentPriceColumns: false,
                    showParentDimensions: false,
                    showParentDualQty: true,
                    parentAvailableQtyLabel: 'Available',
                    showVariationDimensions: false,
                    showVariationQtyTotalColumn: true,
                    showVariationSalePrice: false,
                    formatDimensionsCompact: formatDimensionsCompact,
                    qtyParentLabel: 'Total Qty',
                    variationQtyLabel: 'Available Qty'
                }) %>

                <% if (invPag.totalPages > 1) { %>
                    <nav class="inventory-pagination" aria-label="Product inventory pages">
                        <% if (invPag.page > 1) { %>
                            <a href="<%= invListUrl(invPag.page - 1) %>">Previous</a>
                        <% } else { %>
                            <span class="disabled">Previous</span>
                        <% } %>
                        <% for (let p = Math.max(1, invPag.page - 2); p <= Math.min(invPag.totalPages, invPag.page + 2); p++) { %>
                            <% if (p === invPag.page) { %>
                                <span class="current"><%= p %></span>
                            <% } else { %>
                                <a href="<%= invListUrl(p) %>"><%= p %></a>
                            <% } %>
                        <% } %>
                        <% if (invPag.page < invPag.totalPages) { %>
                            <a href="<%= invListUrl(invPag.page + 1) %>">Next</a>
                        <% } else { %>
                            <span class="disabled">Next</span>
                        <% } %>
                    </nav>
                <% } %>
            </div>
            </div>

            <%- include('partials/raw-materials-tab', { materials: typeof materials !== 'undefined' ? materials : [], units: typeof units !== 'undefined' ? units : [], activeTab: typeof activeTab !== 'undefined' ? activeTab : 'ProductInventory' }) %>
            <%- include('partials/bom-bundles-tab', { bomBundles: typeof bomBundles !== 'undefined' ? bomBundles : [], materials: typeof materials !== 'undefined' ? materials : [], activeTab: typeof activeTab !== 'undefined' ? activeTab : 'ProductInventory' }) %>
            <%- include('partials/stock-movement-tab', { activeTab: typeof activeTab !== 'undefined' ? activeTab : 'ProductInventory' }) %>

        </div>
    <%- include('partials/bom-bundle-modal') %>
    </div>

    <script>
        window.__adminProductCategories = <%- JSON.stringify(typeof categories !== 'undefined' ? categories : []) %>;
    </script>
    <%- include('partials/edit-inventory-product-modal') %>
    <%- include('partials/edit-inventory-product-quick-modal') %>
    <%- include('partials/edit-variation-status-modal') %>
    <%- include('partials/inventory-details-modal') %>
    <%- include('partials/admin-variations-modal') %>
    <%- include('partials/repair-variation-modal') %>

    <!-- Restock Variation Modal -->
    <div id="variationRestockModal" class="modal pi-modal-compact">
        <div class="modal-content">
            <span class="close-button" id="closeVariationRestockModal">&times;</span>
            <h3>Restock Variation</h3>
            <input type="hidden" id="variationRestockVariationId" value="">
            <input type="hidden" id="variationRestockInventoryProductId" value="">
            <div class="form-group">
                <label>Variation</label>
                <p id="variationRestockName" style="margin:4px 0 0;font-weight:600;color:#333;"></p>
            </div>
            <div class="form-group" style="margin-bottom:12px;padding:10px;background:#f8f9fa;border-radius:6px;font-size:0.9em;">
                <strong>Current Qty Stock:</strong> <span id="variationRestockCurrentQty">0</span>
            </div>
            <div class="form-group">
                <label for="variationRestockQty">Quantity to add</label>
                <input type="number" id="variationRestockQty" min="1" value="1" style="width:100%;max-width:120px;padding:8px;border:1px solid #ced4da;border-radius:4px;text-align:center;">
                <p style="font-size:0.85em;color:#666;margin:8px 0 0;">Adds available stock and deducts raw materials per unit.</p>
            </div>
            <div class="pi-form-actions">
                <button type="button" id="cancelVariationRestock" class="pi-btn pi-btn-secondary">Cancel</button>
                <button type="button" id="confirmVariationRestock" class="pi-btn pi-btn-primary" style="background:#FFC107;color:#333;border:none;">Restock</button>
            </div>
        </div>
    </div>

    <!-- Inventory Changes Confirmation Modal -->
    <div id="inventoryConfirmationModal" class="inventory-confirmation-modal">
        <div class="inventory-confirmation-content">
            <h3>Confirm Inventory Changes</h3>
            <div id="inventoryChangesList" class="changes-list"></div>
            <p style="text-align: center; margin-bottom: 0; color: #666;">Proceed with these changes?</p>
            <div class="inventory-confirmation-buttons">
                <button class="inventory-cancel-btn" id="cancelInventoryChanges">Cancel</button>
                <button class="inventory-confirm-btn" id="confirmInventoryChanges">OK</button>
            </div>
        </div>
    </div>

    <%- include('partials/archive-confirmation-modal') %>

    <!-- Restock Confirmation Modal -->
    <div id="restockConfirmModal" class="inventory-confirmation-modal">
        <div class="inventory-confirmation-content">
            <h3>Confirm Restock</h3>
            <p id="restockConfirmText" style="text-align:center;margin:12px 0 8px;font-size:1.05em;font-weight:600;color:#333;"></p>
            <p style="text-align:center;margin:0 0 16px;color:#64748b;font-size:0.9em;">This adds available quantity and deducts raw materials per item.</p>
            <div class="inventory-confirmation-buttons">
                <button type="button" class="inventory-cancel-btn" id="cancelRestockConfirm">Cancel</button>
                <button type="button" class="inventory-confirm-btn" id="confirmRestockConfirm">Restock</button>
            </div>
        </div>
    </div>

    <script src="/js/Employee/Admin/admin-modals.js?v=20260541" defer></script>
    <script src="/js/Employee/Admin/product-inventory.js?v=20260552" defer></script>
    <script src="/js/Employee/Admin/product-inventory-tabs.js?v=20260541" defer></script>
    <script src="/js/Employee/Admin/stock-movement-tab.js?v=20260554" defer></script>
    <script src="/js/Employee/Admin/raw-materials-tab.js?v=20260552"></script>
    <script src="/js/Employee/Admin/bom-bundles-tab.js?v=20260552" defer></script>

    <% if (locals.error && locals.error.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= error %>', true);
        });
    </script>
    <% } %>
    <% if (locals.success && locals.success.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var msg = <%- JSON.stringify(success || '') %>;
            var urlTab = new URLSearchParams(window.location.search).get('tab');
            var onProductsTab = urlTab === 'ProductInventory' || urlTab === 'products' || (!urlTab && document.getElementById('productsTab') && document.getElementById('productsTab').classList.contains('active'));
            if (onProductsTab && /raw material/i.test(msg)) {
                var inlineFlash = document.querySelector('.success-message--raw-material');
                if (inlineFlash) inlineFlash.style.display = 'none';
                return;
            }
            showCustomPopup(msg);
        });
    </script>
    <% } %>
</body>
</html>


