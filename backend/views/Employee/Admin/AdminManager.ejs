                alertsDropdown.style.display = 'none';
                alertsBellBtn.setAttribute('aria-expanded', 'false');
                return;
            }
            alertsDropdown.style.display = 'block';
            alertsBellBtn.setAttribute('aria-expanded', 'true');
            alertsDropdownContent.innerHTML = '<div class="alerts-dropdown-empty">Loading...</div>';
            try {
                const safetyStock = (await (await fetch('/api/safety-stock-value')).json()).value || 10;
                const alertsData = await (await fetch(alertsDataUrl(safetyStock))).json();
                const sections = [];
                if ((alertsData.products && alertsData.products.length > 0) || (alertsData.rawMaterials && alertsData.rawMaterials.length > 0)) {
                    const productRows = [];
                    if (alertsData.products && alertsData.products.length > 0) {
                        alertsData.products.forEach(product => {
                            const availQty = variationAvailableQty(product);
                            const status = getStockStatus(availQty, safetyStock);
                            if (!status.label) return;
                            const statusClass = status.class.replace('alerts-status-', '');
                            const statusIcon = getStatusIcon(status.label);
                            productRows.push(`
                                <div class="alerts-dropdown-row ${statusClass}">
                                    <span class="alerts-dropdown-icon"><i class="fa-solid ${statusIcon}"></i></span>
                                    <div class="alerts-dropdown-details">
                                        <div class="alerts-dropdown-name">${product.Name}</div>
                                        <div class="alerts-dropdown-description">${formatStockAlertDescription(product)}</div>
                                    </div>
                                    <span class="alerts-dropdown-status ${statusClass}">${status.label}</span>
                                </div>
                            `);
                        });
                        if (productRows.length > 0) {
                            sections.push(`<div class="alerts-dropdown-section-title">Product Variations</div>`);
                            sections.push(productRows.join(''));
                        }
                    }
                    const materialRows = [];
                    if (alertsData.rawMaterials && alertsData.rawMaterials.length > 0) {
                        alertsData.rawMaterials.forEach(material => {
                            const status = getStockStatus(material.QuantityAvailable, safetyStock);
                            if (!status.label) return;
                            const statusClass = status.class.replace('alerts-status-', '');
                            const statusIcon = getStatusIcon(status.label);
                            const materialId = material.MaterialID ?? 'N/A';
                            const quantityAvailable = material.QuantityAvailable ?? 0;
                            const unitLabel = material.Unit || 'units';
                            materialRows.push(`
                                <div class="alerts-dropdown-row ${statusClass}">
                                    <span class="alerts-dropdown-icon"><i class="fa-solid ${statusIcon}"></i></span>
                                    <div class="alerts-dropdown-details">
                                        <div class="alerts-dropdown-name">${material.Name}</div>
