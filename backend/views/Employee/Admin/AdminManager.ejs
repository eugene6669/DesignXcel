        function formatTimeWithAMPM(timeString) {
            const [hours, minutes, seconds] = timeString.split(':');
            const formattedTime = `${hours % 12 || 12}:${minutes}:${seconds} ${hours >= 12 ? 'PM' : 'AM'}`;
            return formattedTime;
        }

        function getLogIcon(action = '') {
            const normalized = action.toLowerCase();
            if (normalized.includes('delete') || normalized.includes('remove')) return 'fa-trash-can';
            if (normalized.includes('update') || normalized.includes('edit')) return 'fa-pen-to-square';
            if (normalized.includes('create') || normalized.includes('add') || normalized.includes('insert')) return 'fa-circle-plus';
            if (normalized.includes('login') || normalized.includes('access')) return 'fa-right-to-bracket';
            if (normalized.includes('logout')) return 'fa-right-from-bracket';
            return 'fa-clipboard-list';
        }

        async function loadRecentLogs() {
            try {
                const response = await fetch('/Employee/Admin/Logs/Data');
                const data = await response.json();
                
                const logsContainer = document.getElementById('recentLogsContainer');
                
                if (data.success && data.logs && data.logs.length > 0) {
                    const recentLogs = data.logs.slice(0, 5); // Get top 5 logs
                    let logsHTML = '';
                    
                    recentLogs.forEach(log => {
                        const dbTimestamp = new Date(log.Timestamp);
                        const formattedTime = dbTimestamp.toLocaleString('en-PH', {
                            timeZone: 'Asia/Manila',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit',
                            hour12: true
                        });
                        const logIcon = getLogIcon(log.Action || '');
                        const desc = (log.Description || '').trim();
                        const shortDesc = desc.length > 72 ? desc.slice(0, 72) + '…' : desc;
                        logsHTML += `
                            <div class="log-item">
                                <div class="log-icon">
                                    <i class="fa-solid ${logIcon}"></i>
                                </div>
                                <div class="log-info">
