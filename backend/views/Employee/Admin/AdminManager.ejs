        function renderProductsList(products) {
            const modalBody = document.getElementById('productsModalBody');
            const productsList = document.createElement('div');
            productsList.className = 'products-list';
            
            products.forEach(product => {
                const stockQty = product.StockQuantity || 0;
                let stockClass = 'in-stock';
                let stockText = `${stockQty} in stock`;
                
                if (stockQty === 0) {
                    stockClass = 'out-stock';
                    stockText = 'Out of stock';
                } else if (stockQty <= 10) {
                    stockClass = 'low-stock';
                    stockText = `${stockQty} (Low)`;
                }
                
                const price = product.Price ? `₱${Number(product.Price).toLocaleString(undefined, { minimumFractionDigits: 2 })}` : 'N/A';
                const category = product.Category || 'Uncategorized';
                const sku = product.SKU || 'N/A';
                
                const item = document.createElement('div');
                item.className = 'products-list-item';
                item.innerHTML = `
