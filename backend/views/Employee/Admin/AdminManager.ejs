        function updateLogsStats(logs) {
            const totalLogs = logs.length;
            const last24Hours = logs.filter(log => {
                const logTime = new Date(log.Timestamp);
                const now = new Date();
                const diffHours = (now - logTime) / (1000 * 60 * 60);
                return diffHours <= 24;
            }).length;
            
            document.getElementById('logsModalTotal').textContent = totalLogs;
            document.getElementById('logsModalLast24').textContent = last24Hours;
        }

        // Canceled Orders Modal
        async function showCanceledOrdersModal() {
            const modal = document.getElementById('canceledOrdersModal');
            if (!modal) return;
            
            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
            
            const modalBody = document.getElementById('canceledOrdersModalBody');
            modalBody.innerHTML = '<div class="dashboard-modal-loading">Loading canceled orders...</div>';
            
            try {
                const response = await fetch('/api/dashboard/canceled-orders-list');
                const data = await response.json();
                
                if (data.success && data.orders && data.orders.length > 0) {
                    renderOrdersList(data.orders, 'cancelled');
                    updateCanceledOrdersStats(data.orders);
                } else {
                    modalBody.innerHTML = '<div class="dashboard-modal-empty">No canceled orders found.</div>';
                }
            } catch (error) {
                console.error('Error loading canceled orders:', error);
                modalBody.innerHTML = '<div class="dashboard-modal-empty" style="color:#dc2626;">Failed to load canceled orders. Please try again.</div>';
            }
        }

        function updateCanceledOrdersStats(orders) {
            const totalOrders = orders.length;
            const totalAmount = orders.reduce((sum, o) => sum + (parseFloat(o.TotalAmount) || 0), 0);
            
            document.getElementById('canceledOrdersModalTotal').textContent = totalOrders;
            document.getElementById('canceledOrdersModalAmount').textContent = `₱${totalAmount.toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
        }

        // Close modals on overlay click
        document.addEventListener('click', function(e) {
            const modals = ['productsModal', 'materialsModal', 'pendingOrdersModal', 'alertsModal', 'logsModal', 'canceledOrdersModal'];
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (modal && e.target === modal) {
                    closeDashboardModal(modalId);
                }
            });
        });

        // Close modals on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const modals = ['productsModal', 'materialsModal', 'pendingOrdersModal', 'alertsModal', 'logsModal', 'canceledOrdersModal'];
                modals.forEach(modalId => {
                    closeDashboardModal(modalId);
                });
                closeProductsModal();
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            
        });
    </script>
    
