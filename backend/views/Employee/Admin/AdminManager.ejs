        }

        .dashboard-modal-empty {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-light);
        }

        .dashboard-modal-loading {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-light);
        }

        .order-status-badge {
            padding: 0.375rem 0.75rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .order-status-badge.pending {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
        }

        .order-status-badge.cancelled {
            background: rgba(239, 68, 68, 0.1);
            color: #dc2626;
        }

        .alert-status-badge {
            padding: 0.375rem 0.75rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .alert-status-badge.low {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
        }

        .alert-status-badge.critical {
            background: rgba(249, 115, 22, 0.1);
            color: #f97316;
        }

        .alert-status-badge.out {
            background: rgba(239, 68, 68, 0.1);
            color: #dc2626;
        }

        /* Dashboard Styles */
        .dashboard-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1.75rem;
            flex-wrap: wrap;
        }

        .dashboard-header h2 {
            font-size: 1.85rem;
            margin: 0;
            font-weight: 600;
            color: var(--text-dark);
            font-family: var(--font-display);
        }

        .header-subtitle {
            margin: 0.25rem 0 0 0;
            font-size: 0.93rem;
            color: var(--text-light);
            font-family: var(--font-primary);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .header-alerts-container {
            position: relative;
        }

        .header-alerts-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background: var(--white);
            color: var(--text-dark);
            font-size: 1.25rem;
            cursor: pointer;
            transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        }

        .header-alerts-button:hover {
            background: rgba(240, 178, 27, 0.12);
            border-color: var(--primary-color);
            color: var(--primary-dark);
        }

        #alertsBellDot {
            display: none;
            position: absolute;
            top: 8px;
            right: 8px;
            width: 10px;
            height: 10px;
            background: #dc2626;
            border-radius: 999px;
            border: 2px solid var(--white);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin-bottom: 2rem;
        }

        .metric-card {
            background: var(--white);
            border-radius: 14px;
            padding: 1.25rem;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .metric-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: var(--primary-dark);
            background: rgba(240, 178, 27, 0.15);
        }

        .metric-content {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .metric-number {
            font-size: 1.85rem;
            font-weight: 600;
            color: var(--text-dark);
            margin: 0;
            font-family: var(--font-display);
        }

        .metric-label {
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-dark);
            font-family: var(--font-primary);
        }

        .metric-description {
            font-size: 0.8rem;
            color: var(--text-light);
        }

        .dashboard-sections {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-top: 1.75rem;
        }

        @media (max-width: 1200px) {
            .dashboard-sections {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .dashboard-sections {
                grid-template-columns: 1fr;
            }
        }

        .section-card {
            background: var(--white);
            border-radius: 14px;
            padding: 1.5rem;
            border: 1px solid var(--border-color);
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.85rem;
            margin-bottom: 1rem;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--text-dark);
            margin: 0;
            font-family: var(--font-display);
        }

        .section-title .title-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: var(--primary-dark);
            background: rgba(240, 178, 27, 0.18);
        }

        .alerts-list {
            display: flex;
            flex-direction: column;
            gap: 0.85rem;
        }

        .alert-item {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 0.85rem 1rem;
            border-radius: 12px;
            border: 1px solid rgba(240, 178, 27, 0.35);
            background: rgba(240, 178, 27, 0.08);
        }

        .alert-item.low {
            border-color: rgba(240, 178, 27, 0.45);
        }

        .alert-item.critical {
            border-color: rgba(240, 178, 27, 0.6);
        }

        .alert-item.out {
            border-color: rgba(220, 38, 38, 0.3);
            background: rgba(248, 113, 113, 0.08);
        }

        .alert-item .alert-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: var(--primary-dark);
            background: rgba(240, 178, 27, 0.18);
            flex-shrink: 0;
        }

        .alert-item.low .alert-icon {
            color: #f59e0b;
            background: rgba(245, 158, 11, 0.18);
        }

        .alert-item.critical .alert-icon {
            color: #f97316;
            background: rgba(249, 115, 22, 0.18);
        }

        .alert-item.out .alert-icon {
            color: #b91c1c;
            background: rgba(248, 113, 113, 0.18);
        }

        .alert-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }

        .alert-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-dark);
            margin: 0;
            font-family: var(--font-primary);
        }

        .alert-description {
            margin: 0;
            font-size: 0.82rem;
            color: var(--text-light);
            line-height: 1.35;
        }

        .alert-status {
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            color: var(--primary-dark);
            font-family: var(--font-primary);
        }

        .alert-item.out .alert-status {
            color: #b91c1c;
        }

        .log-list {
            display: flex;
            flex-direction: column;
            gap: 0.85rem;
        }

        .log-item {
            display: flex;
            gap: 0.75rem;
            align-items: flex-start;
            padding-bottom: 0.85rem;
            border-bottom: 1px solid #f1f2f4;
        }

        .log-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .log-icon {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
            background: rgba(240, 178, 27, 0.15);
            color: var(--primary-dark);
        }

        .log-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .log-action {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 0.92rem;
            margin: 0;
            font-family: var(--font-primary);
        }

        .log-user {
            font-size: 0.8rem;
            color: var(--text-light);
        }

        .log-time {
            font-size: 0.75rem;
            color: #9ca3af;
            font-weight: 600;
            margin-left: auto;
        }

        .no-alerts,
        .no-logs {
            text-align: center;
            color: #6b7280;
            font-style: italic;
            padding: 2rem 1rem;
        }

        .welcome-section {
            background: rgba(240, 178, 27, 0.1);
            color: var(--text-dark);
            padding: 1.75rem;
            border-radius: 16px;
            margin-bottom: 2rem;
        }

        .welcome-content {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .welcome-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            background: rgba(240, 178, 27, 0.2);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            color: var(--primary-dark);
        }

        .welcome-text {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .welcome-section h2 {
            margin: 0;
            font-size: 1.6rem;
            font-weight: 600;
            font-family: var(--font-display);
        }

        .welcome-section p {
            margin: 0;
            font-size: 0.92rem;
            color: var(--text-light);
            font-family: var(--font-primary);
        }

        .alerts-dropdown {
            display: none;
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            background: var(--white);
            border-radius: 12px;
            border: 1px solid var(--border-color);
            box-shadow: 0 16px 35px rgba(15, 23, 42, 0.12);
            min-width: 280px;
            max-width: 360px;
            z-index: 3000;
            overflow: hidden;
            animation: dropdownFade 0.15s ease;
        }

        .alerts-dropdown-header {
            padding: 0.85rem 1rem;
            border-bottom: 1px solid #f1f2f4;
            font-weight: 600;
            color: var(--text-dark);
            font-size: 0.9rem;
            background: var(--white);
            font-family: var(--font-primary);
        }

        .alerts-dropdown-content {
            max-height: 300px;
            overflow-y: auto;
        }

        .alerts-dropdown-row {
            display: flex;
            align-items: flex-start;
            gap: 0.65rem;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #f4f5f7;
        }

        .alerts-dropdown-row:last-child {
            border-bottom: none;
        }

        .alerts-dropdown-icon {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: rgba(240, 178, 27, 0.18);
            color: var(--primary-dark);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        .alerts-dropdown-row.low .alerts-dropdown-icon {
            background: rgba(245, 158, 11, 0.18);
            color: #f59e0b;
        }

        .alerts-dropdown-row.critical .alerts-dropdown-icon {
            background: rgba(249, 115, 22, 0.18);
            color: #f97316;
        }

        .alerts-dropdown-status {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-left: auto;
            color: var(--primary-dark);
            font-family: var(--font-primary);
        }

        .alerts-dropdown-row.low .alerts-dropdown-status,
        .alerts-dropdown-row.critical .alerts-dropdown-status {
            color: var(--primary-dark);
        }

        .alerts-dropdown-details {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .alerts-dropdown-name {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 0.9rem;
            font-family: var(--font-primary);
        }

        .alerts-dropdown-description {
            font-size: 0.78rem;
            color: var(--text-light);
            line-height: 1.25;
            font-family: var(--font-primary);
        }

        .alerts-dropdown-section-title {
            padding: 0.6rem 1rem 0.3rem;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-light);
            background: #f8f9fa;
            font-family: var(--font-primary);
        }

        .alerts-dropdown-section-title:not(:first-child) {
            margin-top: 0.25rem;
        }

        .alerts-dropdown-row.out .alerts-dropdown-icon {
            background: rgba(248, 113, 113, 0.2);
            color: #b91c1c;
        }

        .alerts-dropdown-status.out {
            color: #b91c1c;
        }

        .alerts-dropdown-footer {
            display: block;
            text-align: center;
            padding: 0.75rem 1rem;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--primary-dark);
            text-decoration: none;
            border-top: 1px solid #f4f5f7;
            transition: background 0.15s ease;
            font-family: var(--font-primary);
        }

        .alerts-dropdown-footer:hover {
            background: rgba(240, 178, 27, 0.12);
        }

        .alerts-dropdown-empty {
            color: var(--text-light);
            text-align: center;
            padding: 1.1rem;
            font-size: 0.85rem;
        }

        @keyframes dropdownFade {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 768px) {
            .dashboard-sections {
                grid-template-columns: 1fr;
            }
            
            .dashboard-grid {
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            }

            .alerts-dropdown {
                position: static;
                width: 100%;
                box-shadow: 0 16px 35px rgba(15, 23, 42, 0.12);
            }
        }

        .recent-orders-list-compact {
            scrollbar-width: thin;
            scrollbar-color: rgba(240, 178, 27, 0.3) transparent;
        }

        .recent-orders-list-compact::-webkit-scrollbar {
            width: 6px;
        }

        .recent-orders-list-compact::-webkit-scrollbar-track {
            background: transparent;
        }

        .recent-orders-list-compact::-webkit-scrollbar-thumb {
            background: rgba(240, 178, 27, 0.3);
            border-radius: 3px;
        }

        .recent-orders-list-compact::-webkit-scrollbar-thumb:hover {
            background: rgba(240, 178, 27, 0.5);
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <div class="sidebar">
            <%- include('partials/sidebar', { activePage: 'dashboard' }) %>
        </div>
        <div class="main-content">
            <div class="dashboard-header">
                <div>
                    <h2>Dashboard Overview</h2>
                    <p class="header-subtitle">Stay on top of orders, inventory, and activity</p>
                </div>
                <div class="header-actions">
                    <div class="header-alerts-container" id="alertsBellContainer">
                        <button type="button" id="alertsBellBtn" class="header-alerts-button" aria-label="Toggle alerts panel" aria-controls="alertsDropdown" aria-expanded="false">
                            <i class="fa-regular fa-bell"></i>
                            <span id="alertsBellDot"></span>
                        </button>
                        <div id="alertsDropdown" class="alerts-dropdown" style="display: none;">
                            <div class="alerts-dropdown-header">Low &amp; Out of Stock Alerts</div>
                            <div id="alertsDropdownContent" class="alerts-dropdown-content"></div>
                            <a href="/Employee/Admin/Alerts" id="alertsDropdownFooter" class="alerts-dropdown-footer" style="display: none;">Go to Alerts</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="content-area">
                <!-- Welcome Section -->
                <div class="welcome-section">
                    <div class="welcome-content">
                        <span class="welcome-icon">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                        </span>
                        <div class="welcome-text">
                            <h2>Welcome back, <%= user.fullName %>!</h2>
                            <p>Here's what's happening in your system today</p>
                        </div>
                    </div>
                </div>

                <!-- Metrics Grid -->
                <div class="dashboard-grid">
                    <div class="metric-card products" style="cursor: pointer; transition: all 0.2s ease;" onclick="showProductsModal()" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.background='rgba(240, 178, 27, 0.03)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.background='var(--white)';">
                        <div class="metric-icon">
                            <i class="fa-solid fa-box-open"></i>
                        </div>
                        <div class="metric-content">
                            <span class="metric-label">Total Products</span>
                            <span class="metric-number" id="totalProducts">-</span>
                            <span class="metric-description">Active products in inventory</span>
                        </div>
                    </div>
                    
                    <div class="metric-card materials" style="cursor: pointer; transition: all 0.2s ease;" onclick="showMaterialsModal()" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.background='rgba(240, 178, 27, 0.03)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.background='var(--white)';">
                        <div class="metric-icon">
                            <i class="fa-solid fa-cubes"></i>
                        </div>
                        <div class="metric-content">
                            <span class="metric-label">Raw Materials</span>
                            <span class="metric-number" id="totalMaterials">-</span>
                            <span class="metric-description">Available materials</span>
                        </div>
                    </div>
                    
                    <div class="metric-card pending-orders" style="cursor: pointer; transition: all 0.2s ease;" onclick="showPendingOrdersModal()" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.6)'; this.style.background='rgba(240, 178, 27, 0.05)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.background='var(--white)';">
                        <div class="metric-icon" style="background: rgba(240, 178, 27, 0.2);">
                            <i class="fa-solid fa-shopping-cart"></i>
                        </div>
                        <div class="metric-content">
                            <span class="metric-label">Pending Orders</span>
                            <span class="metric-number" id="pendingOrdersCount"><%= typeof pendingOrdersCount !== 'undefined' ? pendingOrdersCount : 0 %></span>
                            <span class="metric-description">Awaiting processing</span>
                        </div>
                    </div>
                    
                    <div class="metric-card alerts" style="cursor: pointer; transition: all 0.2s ease;" onclick="showAlertsModal()" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.background='rgba(240, 178, 27, 0.03)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.background='var(--white)';">
                        <div class="metric-icon">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                        </div>
                        <div class="metric-content">
                            <span class="metric-label">Active Alerts</span>
                            <span class="metric-number" id="totalAlerts">-</span>
                            <span class="metric-description">Requires attention</span>
                        </div>
                    </div>
                    
                    <div class="metric-card logs" style="cursor: pointer; transition: all 0.2s ease;" onclick="showLogsModal()" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.background='rgba(240, 178, 27, 0.03)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.background='var(--white)';">
                        <div class="metric-icon">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                        </div>
                        <div class="metric-content">
                            <span class="metric-label">Recent Activities</span>
                            <span class="metric-number" id="recentLogs">-</span>
                            <span class="metric-description">Last 24 hours</span>
                        </div>
                    </div>
                    
                    <div class="metric-card canceled-orders" style="cursor: pointer; transition: all 0.2s ease;" onclick="showCanceledOrdersModal()" onmouseover="this.style.borderColor='rgba(220, 38, 38, 0.4)'; this.style.background='rgba(220, 38, 38, 0.03)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.background='var(--white)';">
                        <div class="metric-icon" style="background: rgba(220, 38, 38, 0.15); color: #dc2626;">
                            <i class="fa-solid fa-ban"></i>
                        </div>
                        <div class="metric-content">
                            <span class="metric-label">Canceled Orders</span>
                            <span class="metric-number" id="canceledOrdersCount">-</span>
                            <span class="metric-description">Cancelled orders</span>
                        </div>
                    </div>
                </div>

                <!-- Dashboard Sections -->
                <div class="dashboard-sections">
                    <!-- Recent Orders Notification Section -->
                    <div class="section-card recent-orders-section" style="cursor: pointer; transition: all 0.2s ease;" onclick="window.location.href='/Employee/Admin/OrdersPending'" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.boxShadow='0 2px 8px rgba(240, 178, 27, 0.15)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.boxShadow='none';">
                        <div class="section-header">
                            <h3 class="section-title">
                                <span class="title-icon"><i class="fa-solid fa-shopping-cart"></i></span>
                                Recent Orders
                            </h3>
                        </div>
                        <div class="recent-orders-list-compact" style="display: flex; flex-direction: column; gap: 0.85rem; max-height: 400px; overflow-y: auto;">
                            <% if (typeof recentOrders !== 'undefined' && recentOrders && recentOrders.length > 0) { %>
                                <% if (typeof recentOrders !== 'undefined' && recentOrders) { recentOrders.forEach((order, index) => { %>
                                <div class="order-notification-item-compact log-item" style="display: flex; align-items: flex-start; gap: 0.75rem;">
                                    <div class="log-icon" style="background: rgba(240, 178, 27, 0.15); color: var(--primary-dark);">
                                        <i class="fa-solid fa-receipt"></i>
                                    </div>
                                    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.2rem;">
                                        <div class="log-action" style="font-size: 0.92rem;">
                                            Order #<%= order.ReferenceNumber %>
                                        </div>
                                        <div class="log-user" style="font-size: 0.8rem;">
                                            <%= order.CustomerName.length > 25 ? order.CustomerName.substring(0, 25) + '...' : order.CustomerName %> &bull; ₱<%= parseFloat(order.TotalAmount || 0).toLocaleString('en-PH', { minimumFractionDigits: 2 }) %>
                                        </div>
                                    </div>
                                    <div class="log-time" style="font-size: 0.75rem; color: var(--primary-dark); font-weight: 600; white-space: nowrap;">
                                        Pending
                                    </div>
                                </div>
                                <% }); } %>
                            <% } else { %>
                                <div class="no-logs" style="text-align: center; color: #6b7280; font-style: italic; padding: 2rem 1rem;">
                                    No pending orders found.
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Alerts Section (hidden) -->
                    <div class="section-card alerts-section" style="cursor: pointer; transition: all 0.2s ease;" onclick="window.location.href='/Employee/Admin/Alerts'" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.boxShadow='0 2px 8px rgba(240, 178, 27, 0.15)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.boxShadow='none';">
                        <div class="section-header">
                            <h3 class="section-title">
                                <span class="title-icon"><i class="fa-solid fa-bolt"></i></span>
                                Priority Alerts
                            </h3>
                        </div>
                        <div id="alertsContainer" class="alerts-list">
                            <div class="no-alerts">Loading alerts...</div>
                        </div>
                    </div>

                    <!-- Canceled Orders Notification Section -->
                    <div class="section-card canceled-orders-section" style="cursor: pointer; transition: all 0.2s ease;" onclick="window.location.href='/Employee/Admin/CancelledOrders'" onmouseover="this.style.borderColor='rgba(220, 38, 38, 0.4)'; this.style.boxShadow='0 2px 8px rgba(220, 38, 38, 0.15)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.boxShadow='none';">
                        <div class="section-header">
                            <h3 class="section-title">
                                <span class="title-icon" style="background: rgba(220, 38, 38, 0.18); color: #dc2626;"><i class="fa-solid fa-xmark-circle"></i></span>
                                Canceled Orders
                            </h3>
                        </div>
                        <div class="recent-orders-list-compact" style="display: flex; flex-direction: column; gap: 0.85rem; max-height: 400px; overflow-y: auto;">
                            <% if (typeof canceledOrders !== 'undefined' && canceledOrders && canceledOrders.length > 0) { %>
                                <% canceledOrders.forEach((order, index) => { %>
                                <div class="order-notification-item-compact log-item" style="display: flex; align-items: flex-start; gap: 0.75rem;">
                                    <div class="log-icon" style="background: rgba(220, 38, 38, 0.15); color: #dc2626;">
                                        <i class="fa-solid fa-ban"></i>
                                    </div>
                                    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.2rem;">
                                        <div class="log-action" style="font-size: 0.92rem;">
                                            Order #<%= order.ReferenceNumber %>
                                        </div>
                                        <div class="log-user" style="font-size: 0.8rem;">
                                            <%= order.CustomerName.length > 25 ? order.CustomerName.substring(0, 25) + '...' : order.CustomerName %> &bull; ₱<%= parseFloat(order.TotalAmount || 0).toLocaleString('en-PH', { minimumFractionDigits: 2 }) %>
                                        </div>
                                    </div>
                                    <div class="log-time" style="font-size: 0.75rem; color: #dc2626; font-weight: 600; white-space: nowrap;">
                                        Canceled
                                    </div>
                                </div>
                                <% }); %>
                            <% } else { %>
                                <div class="no-logs" style="text-align: center; color: #6b7280; font-style: italic; padding: 2rem 1rem;">
                                    No canceled orders found.
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Recent Logs Section -->
                    <div class="section-card recent-logs-section logs" style="cursor: pointer; transition: all 0.2s ease;" onclick="window.location.href='/Employee/Admin/Logs'" onmouseover="this.style.borderColor='rgba(240, 178, 27, 0.4)'; this.style.boxShadow='0 2px 8px rgba(240, 178, 27, 0.15)';" onmouseout="this.style.borderColor='var(--border-color)'; this.style.boxShadow='none';">
                        <div class="section-header">
                            <h3 class="section-title">
                                <span class="title-icon"><i class="fa-solid fa-clipboard-list"></i></span>
                                Recent Activity Logs
                            </h3>
                        </div>
                        <div id="recentLogsContainer" class="log-list">
                            <div class="no-logs">Loading recent logs...</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <!-- Custom Confirmation Modal -->
    <div id="logoutConfirmModal" class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Logout</h3>
            <p>Are you sure you want to log out?</p>
            <div class="modal-buttons">
                <button class="modal-button confirm" id="confirmLogoutBtn">Logout</button>
                <button class="modal-button cancel" id="cancelLogoutBtn">Cancel</button>
            </div>
        </div>
    </div>


    <script>
        // Improved dropdown functionality
        document.querySelectorAll('.dropdown-toggle').forEach(item => {
            item.addEventListener('click', event => {
                event.preventDefault();
                const dropdownMenu = item.nextElementSibling;
                const isVisible = dropdownMenu.style.display === 'block';
                
                // Close all other dropdowns first
                document.querySelectorAll('.dropdown-menu').forEach(menu => {
                    menu.style.display = 'none';
                });
                
                // Toggle the clicked dropdown
                dropdownMenu.style.display = isVisible ? 'none' : 'block';
            });
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(event) {
            const dropdowns = document.querySelectorAll('.dropdown');
            dropdowns.forEach(dropdown => {
                if (!dropdown.contains(event.target)) {
                    const dropdownMenu = dropdown.querySelector('.dropdown-menu');
                    if (dropdownMenu) {
                        dropdownMenu.style.display = 'none';
                    }
                }
            });
        });

        // Handle regular link clicks (non-dropdown toggles)
        document.querySelectorAll('.sidebar-menu a:not(.dropdown-toggle)').forEach(link => {
            link.addEventListener('click', event => {
                // Allow the default link behavior
                return true;
            });
        });

        // Dashboard Data Loading Functions
        async function loadDashboardData() {
            try {
                // Load metrics
                await Promise.all([
                    loadMetrics(),
                    loadAlerts(),
                    loadRecentLogs()
                ]);
            } catch (error) {
                console.error('Error loading dashboard data:', error);
            }
        }

        async function loadMetrics() {
            try {
                // Fetch total products
                const productsResponse = await fetch('/api/dashboard/products-count');
                const productsData = await productsResponse.json();
                document.getElementById('totalProducts').textContent = productsData.count || 0;

                // Fetch total materials
                const materialsResponse = await fetch('/api/dashboard/materials-count');
                const materialsData = await materialsResponse.json();
                document.getElementById('totalMaterials').textContent = materialsData.count || 0;

                // Fetch alerts count
                const safetyRes = await fetch('/api/safety-stock-value');
                const safetyStock = (await safetyRes.json()).value || 10;
                const alertsResponse = await fetch(alertsDataUrl(safetyStock));
                const alertsData = await alertsResponse.json();
                const totalAlerts = (alertsData.products?.length || 0) + (alertsData.rawMaterials?.length || 0);
                document.getElementById('totalAlerts').textContent = totalAlerts;

                // Fetch recent logs count
                const logsResponse = await fetch('/Employee/Admin/Logs/Data');
                const logsData = await logsResponse.json();
                const recentLogsCount = logsData.logs?.slice(0, 5).length || 0;
                document.getElementById('recentLogs').textContent = recentLogsCount;

                // Fetch canceled orders count
                const canceledOrdersResponse = await fetch('/api/dashboard/canceled-orders-count');
                const canceledOrdersData = await canceledOrdersResponse.json();
                document.getElementById('canceledOrdersCount').textContent = canceledOrdersData.count || 0;

            } catch (error) {
                console.error('Error loading metrics:', error);
                // Set default values on error
                document.getElementById('totalProducts').textContent = '0';
                document.getElementById('totalMaterials').textContent = '0';
                document.getElementById('totalAlerts').textContent = '0';
                document.getElementById('recentLogs').textContent = '0';
                document.getElementById('canceledOrdersCount').textContent = '0';
            }
        }

        async function getSafetyStockValue() {
            const res = await fetch('/api/safety-stock-value');
            const data = await res.json();
            return data.value || 10;
        }

        function getStockStatus(quantity, safetyStock) {
            if (quantity === 0) return { label: 'Out of Stock', class: 'alerts-status-out' };
            if (quantity > 0 && quantity <= safetyStock) return { label: 'Critical Stock', class: 'alerts-status-critical' };
            if (quantity > safetyStock && quantity <= safetyStock * 2) return { label: 'Low Stock', class: 'alerts-status-low' };
            return { label: '', class: '' };
        }

        function formatVariationAlertMeta(product) {
            const parts = [];
            if (product.SKU) parts.push('SKU: ' + product.SKU);
            const variationId = product.VariationID != null ? product.VariationID : product.ProductID;
            if (variationId != null) parts.push('Variation #' + variationId);
            return parts.length ? parts.join(' \u2022 ') : 'N/A';
        }

        function variationAvailableQty(product) {
            if (product.AvailableQuantity != null && product.AvailableQuantity !== '') {
                return Number(product.AvailableQuantity) || 0;
            }
            return Number(product.StockQuantity) || 0;
        }

        function formatStockAlertDescription(product) {
            const avail = variationAvailableQty(product);
            const total = product.TotalQuantity != null ? Number(product.TotalQuantity) : avail;
            let text = formatVariationAlertMeta(product) + ' \u2022 Available: ' + avail;
            if (total !== avail) text += ' \u2022 Total: ' + total;
            return text;
        }

        function alertsDataUrl(safetyStock) {
            const maxQty = Math.max((Number(safetyStock) || 10) * 2, 20);
            return '/Employee/Admin/Alerts/Data?maxQty=' + maxQty;
        }

        function getStatusIcon(label) {
            switch (label) {
                case 'Out of Stock':
                    return 'fa-circle-xmark';
                case 'Critical Stock':
                    return 'fa-triangle-exclamation';
                case 'Low Stock':
                    return 'fa-exclamation-circle';
                default:
                    return 'fa-circle-info';
            }
        }

        async function loadAlerts() {
            try {
                const safetyRes = await fetch('/api/safety-stock-value');
                const safetyStock = (await safetyRes.json()).value || 10;
                const data = await (await fetch(alertsDataUrl(safetyStock))).json();
                const alertsContainer = document.getElementById('alertsContainer');
                if (data.success && (data.products?.length > 0 || data.rawMaterials?.length > 0)) {
                    const alertItems = [];
                    if (data.products && data.products.length > 0) {
                        data.products.forEach(product => {
                            const availQty = variationAvailableQty(product);
                            const status = getStockStatus(availQty, safetyStock);
                            if (!status.label) return;
                            const statusClass = status.class.replace('alerts-status-', '');
                            const statusIcon = getStatusIcon(status.label);
                            alertItems.push(`
                                <div class="alert-item ${statusClass}">
                                    <div class="alert-icon">
                                        <i class="fa-solid ${statusIcon}"></i>
                                    </div>
                                    <div class="alert-content">
                                        <span class="alert-status">${status.label}</span>
                                        <div class="alert-title">${product.Name}</div>
                                        <p class="alert-description">${formatStockAlertDescription(product)}</p>
                                    </div>
                                </div>
                            `);
                        });
                    }
                    if (data.rawMaterials && data.rawMaterials.length > 0) {
                        data.rawMaterials.forEach(material => {
                            const status = getStockStatus(material.QuantityAvailable, safetyStock);
                            if (!status.label) return;
                            const statusClass = status.class.replace('alerts-status-', '');
                            const statusIcon = getStatusIcon(status.label);
                            const materialId = material.MaterialID ?? 'N/A';
                            const quantityAvailable = material.QuantityAvailable ?? 0;
                            const unitLabel = material.Unit || 'units';
                            alertItems.push(`
                                <div class="alert-item ${statusClass}">
                                    <div class="alert-icon">
                                        <i class="fa-solid ${statusIcon}"></i>
                                    </div>
                                    <div class="alert-content">
                                        <span class="alert-status">${status.label}</span>
                                        <div class="alert-title">${material.Name}</div>
                                        <p class="alert-description">Material ID: ${materialId} &bull; Available: ${quantityAvailable} ${unitLabel}</p>
                                    </div>
                                </div>
                            `);
                        });
                    }
                    alertsContainer.innerHTML = alertItems.join('') || '<div class="no-alerts">No active alerts at the moment. All systems are running smoothly!</div>';
                    if (typeof alertsBellDot !== 'undefined' && alertsBellDot) {
                        alertsBellDot.style.display = alertItems.length > 0 ? 'block' : 'none';
                    }
                } else {
