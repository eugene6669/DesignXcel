    <script>
        (function () {
            if (typeof window === 'undefined') return;

            document.addEventListener('DOMContentLoaded', function () {
                var currentPath = window.location.pathname.replace(/\/+$/, '');
                if (!currentPath) currentPath = '/';

                var links = document.querySelectorAll('.sidebar a[href]');

                links.forEach(function (link) {
                    var href = link.getAttribute('href');
                    if (!href) return;

                    var linkPath = (href.split('?')[0] || '/').replace(/\/+$/, '') || '/';
                    var isActive = false;

                    if (linkPath === '/Employee/Admin/Orders') {
                        isActive = currentPath === '/Employee/Admin/Orders';
                    } else if (linkPath === '/Employee/Admin/ReturnedOrders') {
                        isActive = currentPath === '/Employee/Admin/ReturnedOrders';
                    } else if (currentPath === linkPath) {
                        isActive = true;
                    } else if (linkPath !== '/' && currentPath.startsWith(linkPath + '/')) {
                        isActive = true;
                    }

                    if (isActive) {
                        link.classList.add('active');

                        var sectionLabel = link.closest('.sidebar-submenu');
                        if (sectionLabel && sectionLabel.previousElementSibling && sectionLabel.previousElementSibling.classList.contains('sidebar-section-label')) {
                            sectionLabel.previousElementSibling.classList.add('active');
                        }
                    }
                });
            });
        })();
    </script>