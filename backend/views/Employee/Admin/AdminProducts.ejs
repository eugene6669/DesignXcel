</head>
<body class="page-products-listing">
    <div id="customPopup" class="custom-popup">
        <div class="custom-popup-content">
            <span class="custom-popup-icon">✓</span>
            <span class="custom-popup-message"></span>
        </div>
    </div>
    <div class="dashboard-container">
        <div class="sidebar">
            <%- include('partials/sidebar', { activePage: 'products' }) %>
        </div>
        <div class="main-content">
            <div class="header">
                <h2>Products Listing</h2>
                <p class="products-list-hint">Create products and manage categories with the buttons above. Catalog: edit product name, category, sale price, item cost, description, and images via the row action. Edit variation name, color, thumbnails, and 3D model from each variation. Stock, returns workflow, and restock are on <a href="/Employee/Admin/Inventory?tab=ProductInventory">Inventory</a>.</p>
            </div>
            <div id="productsListingPanel" class="content-area">

                <% 
                    const fmtDate = typeof formatInventoryDate === 'function'
                        ? formatInventoryDate
                        : function(v) { return v ? String(v) : 'N/A'; };
                    // Use allInventoryProducts directly from InventoryProducts table
                    // All products now have inventory data stored directly in InventoryProducts
                    const inventoryRows = (typeof allInventoryProducts !== 'undefined' && Array.isArray(allInventoryProducts))
                        ? allInventoryProducts
                        : [];
                    const allProductsList = inventoryRows.length > 0
                        ? inventoryRows.map(product => ({
                            InventoryProductID: product.InventoryProductID,
                            InventoryProductName: product.InventoryProductName,
                            InventoryProductSKU: product.InventoryProductSKU,
                            InventoryProductCategory: product.InventoryProductCategory,
                            InventoryProductPrice: product.InventoryProductPrice,
                            InventoryItemCostTotal: product.InventoryItemCostTotal || 0,
                            InventoryProductImageURL: product.InventoryProductImageURL,
                            LastDateAdded: product.LastDateAdded || product.DateAdded,
                            LastDateAddedLabel: fmtDate(product.LastDateAdded || product.DateAdded, 'N/A'),
                            TotalQuantity: product.TotalQuantity || 0,
                            AvailableQuantity: product.AvailableQuantity || 0,
                            DamagedQuantity: product.DamagedQuantity || 0,
                            ReturnedQuantity: product.ReturnedQuantity || 0,
                            RepairedQuantity: product.RepairedQuantity || 0,
                            DisposedQuantity: product.DisposedQuantity || 0,
                            InventoryStatus: product.InventoryStatus || 'no_stock',
                            ShowOnStorefront: product.ShowOnStorefront,
                            LinkedProductID: product.LinkedProductID || null,
                            DiscountID: product.DiscountID || null,
                            DiscountType: product.DiscountType || null,
                            DiscountValue: product.DiscountValue != null ? product.DiscountValue : null,
                            DiscountStartDate: product.DiscountStartDate || null,
                            DiscountEndDate: product.DiscountEndDate || null,
                            DiscountedPrice: product.DiscountedPrice != null ? product.DiscountedPrice : null,
                            Notes: product.Notes || '',
                            hasInventory: (product.TotalQuantity || 0) > 0
                        }))
                        : [];
                    const invPag = typeof pagination !== 'undefined' ? pagination : { page: 1, limit: 25, totalCount: 0, totalPages: 1 };
                    const invFilters = typeof listFilters !== 'undefined' ? listFilters : { search: '', category: '' };
                    const invCategories = typeof categories !== 'undefined' ? categories : [];
                    function invListUrl(pageNum) {
                        const parts = [];
                        parts.push('page=' + encodeURIComponent(pageNum));
                        if (invFilters.search) parts.push('search=' + encodeURIComponent(invFilters.search));
                        if (invFilters.category) parts.push('category=' + encodeURIComponent(invFilters.category));
                        if (typeof inventoryProductIdFocus !== 'undefined' && inventoryProductIdFocus) {
                            parts.push('inventoryProductId=' + encodeURIComponent(inventoryProductIdFocus));
                        }
                        return '/Employee/Admin/ProductsListing?' + parts.join('&');
                    }
                    function stockQtyClass(qty) {
                        const n = Number(qty) || 0;
                        if (n < 0) return 'stock-qty-negative';
                        if (n === 0) return 'stock-qty-out';
                        if (n <= 10) return 'stock-qty-critical';
                        if (n <= 20) return 'stock-qty-low';
                        return 'stock-qty-normal';
                    }
                    const invRangeStart = invPag.totalCount > 0 ? (invPag.page - 1) * invPag.limit + 1 : 0;
                    const invRangeEnd = invPag.totalCount > 0 ? Math.min(invPag.page * invPag.limit, invPag.totalCount) : 0;
                    function formatListDate(val) {
                        return fmtDate(val, 'N/A');
                    }
                %>

                <div class="inventory-filter-card" data-inventory-search="<%= (invFilters.search || '').replace(/"/g, '&quot;') %>">
                    <form method="get" action="/Employee/Admin/ProductsListing" class="inventory-filter-form">
                        <input type="hidden" name="page" value="1">
                        <div class="inventory-filter-field">
                            <label for="invSearch">Search</label>
                            <input type="search" id="invSearch" name="search" value="<%= invFilters.search || '' %>" placeholder="Name or variation SKU">
                        </div>
                        <div class="inventory-filter-field">
                            <label for="invCategory">Category</label>
                            <select id="invCategory" name="category">
                                <option value="">All categories</option>
                                <% invCategories.forEach(function(cat) { %>
                                    <option value="<%= cat %>"<%= invFilters.category === cat ? ' selected' : '' %>><%= cat %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="inventory-filter-actions">
                            <button type="submit" class="pi-btn pi-btn-primary">Apply filters</button>
                            <% if (invFilters.search || invFilters.category) { %>
                            <a href="/Employee/Admin/ProductsListing" class="pi-btn pi-btn-secondary">Clear</a>
                            <% } %>
                        </div>
                    </form>
                    <% if (invPag.totalCount > 0) { %>
                    <p class="inventory-list-summary">Showing <%= invRangeStart %>–<%= invRangeEnd %> of <%= invPag.totalCount %> products</p>
                    <% } %>
                </div>

                <div class="pi-toolbar">
                    <button type="button" id="manageCategoriesBtn" class="add-inventory-btn">Manage Categories</button>
                    <button type="button" id="addInventoryItemBtn" class="add-inventory-btn">Create Product</button>
                </div>

                <% if (locals.error && locals.error.length > 0) { %>
                    <div class="error-message"><%= error %></div>
                <% } %>
                <% if (locals.success && locals.success.length > 0) { %>
                    <div class="success-message"><%= success %></div>
                <% } %>

                <!-- Create Product Modal -->
                <div id="addProductModal" class="modal pi-modal-compact pi-create-product-modal">
                    <div class="modal-content">
                        <span class="close-button" id="closeAddModal">&times;</span>
                        <h3>Create New Product</h3>
                        <form id="addProductForm" class="pi-create-form" action="/Employee/Admin/ProductsListing/Add" method="POST" enctype="multipart/form-data">
                            <input type="hidden" id="quantity" name="quantity" value="0">

                            <div class="pi-form-grid pi-create-top">
                                <div class="form-group">
                                    <label for="name">Product Name <span style="color:#dc3545;">*</span></label>
                                    <input type="text" id="name" name="name" required>
                                </div>
                                <div class="form-group">
                                    <label for="createProductPrice">Sale Price (₱) <span style="color:#dc3545;">*</span></label>
                                    <input type="text" id="createProductPrice" name="price" inputmode="decimal" autocomplete="off" required placeholder="0.00">
                                </div>
                                <div class="form-group">
                                    <label for="createProductCostPrice">Item Cost Price (₱) <span style="color:#dc3545;">*</span></label>
                                    <input type="text" id="createProductCostPrice" name="costPrice" inputmode="decimal" autocomplete="off" required placeholder="0.00">
                                </div>
                                <div class="form-group">
                                    <label for="category">Category <span style="color:#dc3545;">*</span></label>
                                    <select id="category" name="category" required>
                                        <option value="">Select category</option>
                                        <% if (categories && categories.length > 0) { %>
                                            <% categories.forEach(cat => { %>
                                                <option value="<%= cat %>"><%= cat %></option>
                                            <% }); %>
                                        <% } else { %>
                                            <option value="Chairs">Chairs</option>
                                            <option value="Tables">Tables</option>
                                            <option value="Storage">Storage</option>
                                            <option value="Partitions">Partitions</option>
                                            <option value="Others">Others</option>
                                        <% } %>
                                    </select>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="description">Description</label>
                                <textarea id="description" name="description" rows="2" placeholder="Optional"></textarea>
                            </div>

                            <div class="form-group pi-section">
                                <h4>Product Images</h4>
                                <p style="font-size:0.85em;color:#666;margin:0 0 8px;">Parent catalog images (variations have their own media below).</p>
                                <div class="pi-form-grid">
                                    <div>
                                        <label for="createProductMainImage">Main Image</label>
                                        <input type="file" id="createProductMainImage" name="productMainImage" accept="image/*">
                                    </div>
                                    <div>
                                        <label for="createProductThumbnails">Thumbnails (up to 4)</label>
                                        <input type="file" id="createProductThumbnails" name="productThumbnail" accept="image/*" multiple>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group pi-section" style="display: none;">
                                <h4>Dimensions</h4>
                                <div class="pi-form-grid">
                                    <div>
                                        <label for="length">Length (cm)</label>
                                        <input type="number" id="length" name="length" step="0.1" min="0" placeholder="0.0">
                                    </div>
                                    <div>
                                        <label for="width">Width (cm)</label>
                                        <input type="number" id="width" name="width" step="0.1" min="0" placeholder="0.0">
                                    </div>
                                    <div>
                                        <label for="height">Height (cm)</label>
                                        <input type="number" id="height" name="height" step="0.1" min="0" placeholder="0.0">
                                    </div>
                                    <div>
                                        <label for="weight">Weight (kg)</label>
                                        <input type="number" id="weight" name="weight" step="0.1" min="0" placeholder="0.0">
                                    </div>
                                </div>
                            </div>

                            <div class="form-group pi-section">
                                <h4>BOM Bundle <span style="color:#dc3545;">*</span></h4>
                                <p>Pick a saved recipe or add materials manually.</p>
                                <label for="createBomBundleSelect">Bundle</label>
                                <select id="createBomBundleSelect" name="bomBundleId">
                                    <option value="">— Manual materials (no bundle) —</option>
                                    <% const bundleList = typeof bomBundles !== 'undefined' && Array.isArray(bomBundles) ? bomBundles : []; %>
                                    <% bundleList.forEach(function(b) { %>
                                        <option value="<%= b.BomBundleID %>"><%= b.BundleCode %> — <%= b.Name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="form-group pi-section">
                                <h4>Materials <span style="color:#dc3545;">*</span></h4>
                                <p>Qty per unit when stocked.</p>
                                <div id="createInventoryRecipeStatus" style="font-size:0.82em;margin-bottom:8px;color:#666;"><em>Select a bundle or add materials</em></div>
                                <div class="materials-section">
                                    <div id="createInventoryMaterialsContainer"></div>
                                    <button type="button" id="addCreateInventoryMaterialBtn" class="add-material-btn">+ Add Material</button>
                                    <div id="createInventoryMaterialsSummary" style="margin-top: 10px; padding: 8px; background: #fff; border-radius: 4px; font-size: 0.9em;">
                                        <strong>Selected materials:</strong>
                                        <div id="createInventoryMaterialsSummaryList" style="margin-top: 4px; color: #666;"><em>No materials selected yet</em></div>
                                    </div>
                                </div>
                                <input type="hidden" id="requiredMaterials" name="requiredMaterials" value="">
                            </div>

                            <div class="form-group pi-section">
                                <h4>Variations <span style="color:#dc3545;">*</span></h4>
                                <p>At least one. Main image required; thumbnails and 3D optional.</p>
