        // Sort products based on selected criteria
        function sortProducts() {
            const table = document.querySelector('table');
            if (!table) return;
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            
            const rows = Array.from(tbody.querySelectorAll('tr'));
            const selectedCategory = categoryFilter.value;
            const sortBy = sortOptions.value;
            
            // First filter by category if selected
            let filteredRows = rows;
            if (selectedCategory) {
                filteredRows = rows.filter(row => {
                    const categoryCell = row.querySelectorAll('td')[6];
                    const category = categoryCell?.textContent?.trim() || '';
                    return category === selectedCategory;
                });
            }
            
            // Then sort the filtered rows
            filteredRows.sort((a, b) => {
                switch (sortBy) {
                    case 'category':
                        const categoryA = a.querySelectorAll('td')[6]?.textContent?.trim() || '';
                        const categoryB = b.querySelectorAll('td')[6]?.textContent?.trim() || '';
                        return categoryA.localeCompare(categoryB);
                        
                    case 'name':
                        const nameA = a.querySelectorAll('td')[1]?.textContent?.trim() || '';
                        const nameB = b.querySelectorAll('td')[1]?.textContent?.trim() || '';
                        return nameA.localeCompare(nameB);
                        
                    case 'price':
                        const priceA = parseFloat(a.querySelectorAll('td')[3]?.textContent?.replace(/[₱,]/g, '') || '0');
                        const priceB = parseFloat(b.querySelectorAll('td')[3]?.textContent?.replace(/[₱,]/g, '') || '0');
                        return priceA - priceB;
                        
                    case 'stock':
                        const stockA = parseInt(a.querySelectorAll('td')[5]?.textContent?.trim() || '0');
                        const stockB = parseInt(b.querySelectorAll('td')[5]?.textContent?.trim() || '0');
                        return stockA - stockB;
                        
                    case 'date':
                        const dateA = a.querySelectorAll('td')[8]?.textContent?.trim() || '';
                        const dateB = b.querySelectorAll('td')[8]?.textContent?.trim() || '';
                        return dateB.localeCompare(dateA); // Newest first
                        
                    default:
                        return 0;
                }
            });
            
            // Reorder rows in the table
            filteredRows.forEach(row => tbody.appendChild(row));
            
            // Show/hide rows based on category filter
            rows.forEach(row => {
                const categoryCell = row.querySelectorAll('td')[6];
                const category = categoryCell?.textContent?.trim() || '';
                
                if (!selectedCategory || category === selectedCategory) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
        
        // Filter products by category (show/hide)
        function filterByCategory() {
            const table = document.querySelector('table');
            if (!table) return;
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            
            const selectedCategory = categoryFilter.value;
