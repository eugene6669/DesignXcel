                            document.getElementById('width').value = dimensions.width || '';
                            document.getElementById('height').value = dimensions.height || '';
                            document.getElementById('weight').value = dimensions.weight || '';
                            document.getElementById('dimensions_notes').value = dimensions.notes || '';
                        } catch (e) {
                            console.log('Error parsing dimensions:', e);
