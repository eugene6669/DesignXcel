                document.getElementById('width').value = '';
                document.getElementById('height').value = '';
                document.getElementById('weight').value = '';
                document.getElementById('dimensions_notes').value = '';
                return;
            }
            
            try {
                const response = await fetch(`/api/admin/inventory-product/${selectedId}?source=${sourceTable}`);
                const data = await response.json();
                
                if (data.success && data.product) {
                    const product = data.product;
                    
                    // Populate basic information
                    document.getElementById('name').value = product.Name || '';
                    document.getElementById('description').value = product.Description || '';
                    document.getElementById('price').value = product.Price || '';
                    
                    // Set stock quantity automatically from inventory
                    const stockInput = document.getElementById('stockquantity');
                    const stockInfo = document.getElementById('stockQuantityInfo');
                    const stockError = document.getElementById('stockQuantityError');
                    let availableQty = 0;
                    
                    // First, try to get stock from dropdown option's data-stock attribute (fast fallback)
                    const selectedOption = document.getElementById('selectInventoryProduct').options[document.getElementById('selectInventoryProduct').selectedIndex];
                    if (selectedOption && selectedOption.getAttribute('data-stock')) {
                        availableQty = parseInt(selectedOption.getAttribute('data-stock')) || 0;
                        console.log('[SELECT INVENTORY] Setting stock from dropdown data-stock:', availableQty);
                    }
                    
                    // Fetch actual AvailableQuantity from InventoryProducts (more accurate)
                    if (sourceTable === 'InventoryProducts') {
                        try {
                            console.log('[SELECT INVENTORY] Fetching inventory quantity for ID:', selectedId);
                            const inventoryResponse = await fetch(`/api/admin/inventory-quantity/${selectedId}`);
                            const inventoryData = await inventoryResponse.json();
                            console.log('[SELECT INVENTORY] Inventory quantity response:', inventoryData);
                            
                            if (inventoryData.success && inventoryData.AvailableQuantity !== undefined) {
                                availableQty = inventoryData.AvailableQuantity || 0;
                                console.log('[SELECT INVENTORY] Setting stock from API response:', availableQty);
                            } else {
                                console.warn('[SELECT INVENTORY] API response missing AvailableQuantity, using dropdown value:', availableQty);
                            }
                        } catch (invError) {
                            console.error('[SELECT INVENTORY] Error fetching inventory quantity:', invError);
                            console.log('[SELECT INVENTORY] Using dropdown value as fallback:', availableQty);
                        }
                    }
                    
                    // Set the stock quantity value directly
                    if (stockInput) {
                        stockInput.value = availableQty;
                        stockInput.setAttribute('max', availableQty);
                                
                                // Show info message
                        if (sourceTable === 'InventoryProducts' && availableQty > 0) {
                                stockInfo.textContent = `Available in inventory: ${availableQty}. Stock quantity cannot exceed this value.`;
                                stockInfo.style.color = '#17a2b8';
                                stockInfo.style.display = 'block';
                                stockError.style.display = 'none';
                                
                                // Add validation on input
                            stockInput.addEventListener('input', function() {
                                    const enteredValue = parseInt(this.value) || 0;
                                    if (enteredValue > availableQty) {
                                        stockError.textContent = `Cannot exceed inventory available quantity (${availableQty})`;
                                        stockError.style.display = 'block';
                                        stockInfo.style.display = 'none';
                                        this.setCustomValidity(`Stock quantity cannot exceed ${availableQty}`);
                                    } else {
                                        stockError.style.display = 'none';
                                        stockInfo.style.display = 'block';
                                        this.setCustomValidity('');
                                    }
                                });
                    } else {
                        stockInput.removeAttribute('max');
                            stockInfo.style.display = 'none';
                            stockError.style.display = 'none';
                        }
                        
                        console.log('[SELECT INVENTORY] Final stock quantity set:', stockInput.value);
                    } else {
                        console.error('[SELECT INVENTORY] Stock input element not found!');
                    }
                    
                    // Set category
                    const categorySelect = document.getElementById('category');
                    if (product.Category) {
                        // Check if category exists in dropdown, if not add it
                        let categoryExists = false;
                        for (let i = 0; i < categorySelect.options.length; i++) {
                            if (categorySelect.options[i].value === product.Category) {
                                categoryExists = true;
                                categorySelect.value = product.Category;
                                break;
                            }
                        }
                        if (!categoryExists && product.Category) {
                            const option = document.createElement('option');
                            option.value = product.Category;
                            option.textContent = product.Category;
                            categorySelect.appendChild(option);
                            categorySelect.value = product.Category;
