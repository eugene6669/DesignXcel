            padding: 5px 12px;
            font-size: 0.82em;
            cursor: pointer;
            transition: background 0.2s ease, box-shadow 0.2s ease;
        }
        .add-inventory-discount-btn:hover {
            background: #e0a518;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
        }
        .remove-inventory-discount-btn {
            background: #fff;
            color: #333;
            border: 1px solid #ccc;
            border-radius: 4px;
            padding: 4px 8px;
