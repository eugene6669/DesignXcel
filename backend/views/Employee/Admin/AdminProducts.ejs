    <div id="inventory-discount-modal" class="modal">
        <div class="modal-content" style="max-width:480px;">
            <span class="close-button" id="closeInventoryDiscountModal">&times;</span>
            <h3>Set product discount</h3>
            <p id="inventoryDiscountProductLabel" style="margin:0 0 12px;color:#555;font-size:0.9em;"></p>
            <form id="inventory-discount-form">
                <input type="hidden" id="inventory-discount-product-id">
                <div style="margin-bottom:1em;">
                    <label for="inventory-discount-type">Discount type</label><br>
                    <select id="inventory-discount-type" style="width:100%;padding:0.5em;margin-top:0.5em;">
                        <option value="percentage">Percentage (%)</option>
                        <option value="fixed">Fixed amount (₱)</option>
                    </select>
                </div>
                <div style="margin-bottom:1em;">
                    <label for="inventory-discount-value">Discount value</label><br>
                    <input type="number" id="inventory-discount-value" step="0.01" min="0" style="width:100%;padding:0.5em;margin-top:0.5em;" required>
                    <div id="inventory-discount-max-hint" style="font-size:0.85em;color:#6b7280;margin-top:0.25em;"></div>
                </div>
                <div style="margin-bottom:1em;">
                    <label for="inventory-discount-start">Start</label><br>
                    <input type="datetime-local" id="inventory-discount-start" style="width:100%;padding:0.5em;margin-top:0.5em;" required>
                </div>
                <div style="margin-bottom:1em;">
                    <label for="inventory-discount-end">End</label><br>
                    <input type="datetime-local" id="inventory-discount-end" style="width:100%;padding:0.5em;margin-top:0.5em;" required>
                </div>
                <div style="text-align:right;">
                    <button type="button" id="cancelInventoryDiscountBtn" class="pi-btn pi-btn-secondary" style="margin-right:8px;">Cancel</button>
                    <button type="submit" class="add-inventory-discount-btn" style="border:none;">Save discount</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        (function() {
            let inventoryDiscountProductPrice = 0;
            const modal = document.getElementById('inventory-discount-modal');
            const form = document.getElementById('inventory-discount-form');
            const typeEl = document.getElementById('inventory-discount-type');
            const hintEl = document.getElementById('inventory-discount-max-hint');

            function showPopup(msg, isError) {
                const el = document.getElementById('customPopup');
                if (!el) { alert(msg); return; }
                el.querySelector('.custom-popup-message').textContent = msg;
                el.classList.toggle('error', !!isError);
                el.classList.add('show');
                setTimeout(function() { el.classList.remove('show'); }, 3500);
            }

            function updateDiscountHint() {
                if (!typeEl || !hintEl) return;
                if (typeEl.value === 'percentage') {
                    hintEl.textContent = 'Maximum: 50%';
                } else {
                    const maxFixed = inventoryDiscountProductPrice * 0.5;
                    hintEl.textContent = 'Maximum: ₱' + maxFixed.toFixed(2) + ' (50% of list price)';
                }
            }

            function resolveInventoryProductId(el) {
                if (!el) return '';
                const fromBtn = el.getAttribute('data-inventory-product-id') || el.dataset.inventoryProductId || '';
                if (fromBtn && fromBtn !== 'undefined') return fromBtn;
                const row = el.closest('[data-inventory-product-id]');
                if (row) {
                    const fromRow = row.getAttribute('data-inventory-product-id') || '';
                    if (fromRow && fromRow !== 'undefined') return fromRow;
                }
                return '';
            }

            function openInventoryDiscountModal(inventoryProductId, productName, productPrice) {
                const id = String(inventoryProductId || '').trim();
                if (!id || id === 'undefined') {
                    showPopup('Could not determine product ID. Refresh the page and try again.', true);
                    return;
                }
                document.getElementById('inventory-discount-product-id').value = id;
                document.getElementById('inventoryDiscountProductLabel').textContent = productName || '';
                inventoryDiscountProductPrice = parseFloat(productPrice) || 0;
                const now = new Date();
                const end = new Date();
                end.setDate(end.getDate() + 30);
                document.getElementById('inventory-discount-start').value = now.toISOString().slice(0, 16);
                document.getElementById('inventory-discount-end').value = end.toISOString().slice(0, 16);
                updateDiscountHint();
                if (modal) modal.style.display = 'block';
            }

            function closeInventoryDiscountModal() {
                if (modal) modal.style.display = 'none';
                if (form) form.reset();
            }

            async function removeInventoryDiscount(inventoryProductId, productName) {
                if (!confirm('Remove discount for "' + productName + '"?')) return;
                try {
                    const res = await fetch('/api/admin/inventory-products/' + inventoryProductId + '/discount', { method: 'DELETE' });
                    const data = await res.json();
                    if (data.success) {
                        showPopup(data.message || 'Discount removed.');
                        window.location.reload();
                    } else {
                        showPopup(data.error || 'Failed to remove discount.', true);
                    }
                } catch (e) {
                    showPopup('Failed to remove discount.', true);
                }
            }

            if (typeEl) typeEl.addEventListener('change', updateDiscountHint);
            document.getElementById('closeInventoryDiscountModal')?.addEventListener('click', closeInventoryDiscountModal);
            document.getElementById('cancelInventoryDiscountBtn')?.addEventListener('click', closeInventoryDiscountModal);
            if (modal) {
                modal.addEventListener('click', function(e) {
                    if (e.target === modal) closeInventoryDiscountModal();
                });
            }

            document.addEventListener('click', function(e) {
                const addBtn = e.target.closest('.add-inventory-discount-btn');
                if (addBtn) {
                    openInventoryDiscountModal(
                        resolveInventoryProductId(addBtn),
                        addBtn.getAttribute('data-product-name') || addBtn.dataset.productName,
                        addBtn.getAttribute('data-product-price') || addBtn.dataset.productPrice
                    );
                    return;
                }
                const remBtn = e.target.closest('.remove-inventory-discount-btn');
                if (remBtn) {
                    const remId = resolveInventoryProductId(remBtn);
                    if (!remId) {
                        showPopup('Could not determine product ID. Refresh the page and try again.', true);
                        return;
                    }
                    removeInventoryDiscount(remId, remBtn.getAttribute('data-product-name') || remBtn.dataset.productName);
                }
            });

            if (form) {
                form.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    const inventoryProductId = String(document.getElementById('inventory-discount-product-id').value || '').trim();
                    if (!inventoryProductId || inventoryProductId === 'undefined') {
                        showPopup('Missing product ID. Close the modal and use Add discount on a product row again.', true);
                        return;
                    }
                    const discountType = typeEl.value;
                    const discountValue = parseFloat(document.getElementById('inventory-discount-value').value);
                    const startDate = document.getElementById('inventory-discount-start').value;
                    const endDate = document.getElementById('inventory-discount-end').value;
                    if (!discountValue || discountValue <= 0) {
                        showPopup('Discount value must be greater than 0.', true);
                        return;
                    }
                    if (discountType === 'percentage' && discountValue > 50) {
                        showPopup('Percentage discount cannot exceed 50%.', true);
                        return;
                    }
                    if (discountType === 'fixed' && discountValue > inventoryDiscountProductPrice * 0.5) {
                        showPopup('Fixed discount cannot exceed 50% of list price.', true);
                        return;
                    }
                    try {
                        const res = await fetch('/api/admin/inventory-products/' + inventoryProductId + '/discount', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ discountType, discountValue, startDate, endDate })
                        });
                        const data = await res.json();
                        if (data.success) {
                            closeInventoryDiscountModal();
                            showPopup(data.message || 'Discount saved.');
                            window.location.reload();
                        } else {
                            showPopup(data.error || 'Failed to save discount.', true);
                        }
                    } catch (err) {
                        showPopup('Failed to save discount.', true);
                    }
                });
            }
        })();
    </script>

    <script src="/js/Employee/Admin/product-inventory.js?v=20260527b" defer></script>
    <% if (locals.error && locals.error.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= error %>', true);
        });
    </script>
    <% } %>
    <% if (locals.success && locals.success.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup(<%- JSON.stringify(success || '') %>);
        });
    </script>
    <% } %>
    <script>
    (function () {
        function sanitizeCreatePrice(v) {
            v = String(v || '').replace(/,/g, '').replace(/[^\d.]/g, '');
            var dot = v.indexOf('.');
            if (dot !== -1) {
                v = v.slice(0, dot + 1) + v.slice(dot + 1).replace(/\./g, '');
                if (v.length - dot - 1 > 2) v = v.slice(0, dot + 3);
            }
            return v;
        }
        function formatCreatePrice(el) {
            if (!el) return;
            var v = sanitizeCreatePrice(el.value);
            if (!v || v === '.') { el.value = v; return; }
            if (v.endsWith('.')) v = v.slice(0, -1);
            var n = parseFloat(v);
            if (isFinite(n)) el.value = n.toFixed(2);
        }
        function wireCreateProductPriceField(el) {
            if (!el || el.getAttribute('data-auto-price') === '1') return;
            el.setAttribute('data-auto-price', '1');
            el.addEventListener('input', function () {
                var v = sanitizeCreatePrice(el.value);
                if (el.value !== v) el.value = v;
            });
            el.addEventListener('focusout', function () { formatCreatePrice(el); });
            el.addEventListener('change', function () { formatCreatePrice(el); });
            el.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { formatCreatePrice(el); }
            });
        }
        function wireCreateProductPrices() {
            wireCreateProductPriceField(document.getElementById('createProductPrice'));
            wireCreateProductPriceField(document.getElementById('createProductCostPrice'));
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', wireCreateProductPrices);
        } else {
            wireCreateProductPrices();
        }
        var addBtn = document.getElementById('addInventoryItemBtn');
        if (addBtn) addBtn.addEventListener('click', function () { setTimeout(wireCreateProductPrices, 0); });
        var form = document.getElementById('addProductForm');
        if (form) {
            form.addEventListener('submit', function () {
                formatCreatePrice(document.getElementById('createProductPrice'));
                formatCreatePrice(document.getElementById('createProductCostPrice'));
            }, true);
        }
    })();
    </script>
</body>
</html>