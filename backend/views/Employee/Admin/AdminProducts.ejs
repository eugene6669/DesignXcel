                document.getElementById('variationsModalTitle').textContent = `Manage Variations - ${productName}`;
                
                // Reset variation quantity input before loading
                const variationQuantityInput = document.getElementById('variationQuantity');
                const availableStockInfo = document.getElementById('availableStockInfo');
                if (variationQuantityInput) {
                    variationQuantityInput.value = '';
                    // Removed max attribute removal (no validation)
                }
                if (availableStockInfo) {
                    availableStockInfo.textContent = '';
                    availableStockInfo.style.display = 'none'; // Hide the info message
                }
                
                // Reset form fields
                document.getElementById('variationName').value = '';
                document.getElementById('variationColor').value = '';
                document.getElementById('variationQuantity').value = '';
                document.getElementById('variationPrice').value = '';
                document.getElementById('variationImage').value = '';
                
                // Reset inventory variation linking
                const inventoryVariationIdField = document.getElementById('inventoryVariationId');
                if (inventoryVariationIdField) {
                    inventoryVariationIdField.value = '';
                }
                
                const selectInventoryVariation = document.getElementById('selectInventoryVariation');
                if (selectInventoryVariation) {
                    selectInventoryVariation.selectedIndex = 0;
                }
                
                // Make quantity field editable again
                const quantityInput = document.getElementById('variationQuantity');
                if (quantityInput) {
                    quantityInput.readOnly = false;
                    quantityInput.style.backgroundColor = '';
                    quantityInput.style.cursor = '';
                    quantityInput.title = '';
                }
                
                // Remove any image preview
                const previewContainer = document.getElementById('inventoryVariationImagePreview');
                if (previewContainer) {
                    previewContainer.remove();
                }
                
                variationsModal.classList.add('show');
                await loadVariations(productId);
                // Use inventoryProductId to load inventory variations (or productId as fallback)
                await loadInventoryVariationsForDropdown(inventoryProductId);
            });
        });

        // Close variations modal
        closeVariationsModal.addEventListener('click', function() {
            variationsModal.classList.remove('show');
        });

        // Add variation form submission
        addVariationForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Validate that inventory variation is selected (required)
            const selectInventoryVariation = document.getElementById('selectInventoryVariation');
            const inventoryVariationId = document.getElementById('inventoryVariationId').value;
            
            if (!selectInventoryVariation.value || !inventoryVariationId) {
                showVariationModalNotification('Error: You must select an inventory variation to link. All customer variations must be linked to an inventory variation.', true);
                return;
            }
            
            const formData = new FormData(this);
            
            try {
                const response = await fetch('/Employee/Admin/Variations/Add', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showVariationModalNotification(result.message);
                    this.reset();
                    loadVariations(document.getElementById('variationProductID').value);
                } else {
                    showVariationModalNotification(result.message, true);
                }
            } catch (error) {
                console.error('Error adding variation:', error);
                showVariationModalNotification('Failed to add variation', true);
            }
        });

        // Store product stock info globally
        window.currentProductStockInfo = {
            productStock: 0,
            availableStock: 0,
            totalVariationQuantity: 0
        };

        // Load variations for a product
        async function loadVariations(productId) {
            try {
                const response = await fetch(`/Employee/Admin/Variations/Get/${productId}`);
                const result = await response.json();
                
                if (result.success) {
                    // Store stock information globally (for reference, but no validation)
                    window.currentProductStockInfo = {
                        productStock: result.productStock || 0,
                        availableStock: result.availableStock || 0,
                        totalVariationQuantity: result.totalVariationQuantity || 0
                    };
                    
                    // Removed validation: No max quantity restriction and no stock info message
                    // User requested removal of this validation
                    
                    displayVariations(result.variations);
                } else {
                    variationsContainer.innerHTML = '<p>No variations found or error loading variations.</p>';
                }
            } catch (error) {
                console.error('Error loading variations:', error);
                variationsContainer.innerHTML = '<p>Error loading variations.</p>';
            }
        }
        
        // Load inventory variations for dropdown
        async function loadInventoryVariationsForDropdown(productId) {
            try {
                const response = await fetch(`/api/admin/inventory-product-variations/${productId}`);
                const result = await response.json();
                
                const selectDropdown = document.getElementById('selectInventoryVariation');
                if (!selectDropdown) return;
                
                // Clear existing options except the first one
                selectDropdown.innerHTML = '<option value="">-- Select an inventory variation (Required) --</option>';
                
                if (result.success && result.variations && result.variations.length > 0) {
                    result.variations.forEach(variation => {
                        if (variation.IsActive === 1 || variation.IsActive === true) {
                            const option = document.createElement('option');
                            option.value = variation.VariationID;
                            const displayText = `${variation.VariationName}${variation.Color ? ' - ' + variation.Color : ''} (Qty: ${variation.Quantity}${variation.Price ? ', Price: ₱' + parseFloat(variation.Price).toFixed(2) : ''})`;
                            option.textContent = displayText;
                            option.dataset.variation = JSON.stringify(variation);
                            selectDropdown.appendChild(option);
                        }
                    });
                } else {
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = 'No inventory variations available';
                    option.disabled = true;
                    selectDropdown.appendChild(option);
                }
            } catch (error) {
                console.error('Error loading inventory variations for dropdown:', error);
                const selectDropdown = document.getElementById('selectInventoryVariation');
                if (selectDropdown) {
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = 'Error loading inventory variations';
                    option.disabled = true;
                    selectDropdown.appendChild(option);
                }
            }
        }
        
        // Handle inventory variation selection for linking
        // Use event delegation to handle dynamically loaded dropdown
        document.addEventListener('change', function(e) {
            if (e.target && e.target.id === 'selectInventoryVariation') {
                const selectedOption = e.target.options[e.target.selectedIndex];
                const inventoryVariationIdField = document.getElementById('inventoryVariationId');
                
                if (selectedOption && selectedOption.value) {
                    try {
                        const variation = JSON.parse(selectedOption.dataset.variation);
                        
                        // Store the inventory variation ID for linking
                        if (inventoryVariationIdField) {
                            inventoryVariationIdField.value = variation.VariationID || '';
                        }
                        
                        // Populate form fields from inventory variation
                        document.getElementById('variationName').value = variation.VariationName || '';
                        document.getElementById('variationColor').value = variation.Color || '';
                        
                        // Use AvailableQuantity if available, otherwise use Quantity
                        const availableQty = variation.AvailableQuantity !== null && variation.AvailableQuantity !== undefined 
                            ? variation.AvailableQuantity 
                            : (variation.Quantity || '');
                        document.getElementById('variationQuantity').value = availableQty;
                        document.getElementById('variationPrice').value = variation.Price ? parseFloat(variation.Price).toFixed(2) : '';
                        
                        // Make quantity field readonly when linked (stock is managed in inventory)
                        const quantityInput = document.getElementById('variationQuantity');
                        if (quantityInput) {
                            quantityInput.readOnly = true;
                            quantityInput.style.backgroundColor = '#f0f0f0';
                            quantityInput.style.cursor = 'not-allowed';
                            quantityInput.title = 'Quantity is synced from inventory. Manage stock in Product Inventory.';
                        }
                        
                        // Show image preview if available
                        const imageInput = document.getElementById('variationImage');
                        if (variation.VariationImageURL) {
                            let previewContainer = document.getElementById('inventoryVariationImagePreview');
                            if (!previewContainer) {
                                previewContainer = document.createElement('div');
                                previewContainer.id = 'inventoryVariationImagePreview';
                                previewContainer.style.marginTop = '10px';
                                previewContainer.style.padding = '10px';
                                previewContainer.style.backgroundColor = '#e7f3ff';
                                previewContainer.style.borderRadius = '4px';
                                previewContainer.style.border = '1px solid #b3d9ff';
                                imageInput.parentElement.appendChild(previewContainer);
                            }
                            previewContainer.innerHTML = `
                                <small style="display: block; margin-bottom: 5px; color: #0066cc; font-weight: 600;">Linked Inventory Variation Image:</small>
                                <img src="${variation.VariationImageURL}" alt="Variation Image" style="max-width: 100px; max-height: 100px; border-radius: 4px; border: 1px solid #ddd;">
                                <small style="display: block; margin-top: 5px; color: #0066cc;">Upload a new image to replace it</small>
                            `;
                        } else {
                            const previewContainer = document.getElementById('inventoryVariationImagePreview');
                            if (previewContainer) {
                                previewContainer.remove();
                            }
                        }
                        
                        console.log(`[VARIATION LINK] Linked to Inventory Variation ID: ${variation.VariationID}`);
                    } catch (error) {
                        console.error('Error parsing variation data:', error);
                    }
                } else {
                    // Inventory variation selection is required - show error if user tries to clear selection
                    if (inventoryVariationIdField && inventoryVariationIdField.value) {
                        // If there was a previous selection, warn user that selection is required
                        alert('Error: You must select an inventory variation. All customer variations must be linked to an inventory variation.');
                        // Restore previous selection
                        e.target.value = inventoryVariationIdField.value;
                        // Trigger change event to restore form values
                        e.target.dispatchEvent(new Event('change', { bubbles: true }));
                        return;
                    }
                }
            }
        });

        // Display variations
        function displayVariations(variations) {
            // Store variations globally for edit functionality
            window.currentVariations = variations;
            
            if (variations.length === 0) {
                variationsContainer.innerHTML = '<p>No variations found for this product.</p>';
                return;
            }

            const variationsHTML = variations.map(variation => {
                // Escape variation name for use in onclick attribute
                const escapedName = (variation.VariationName || 'N/A').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                return `
                <div style="border: 1px solid #ddd; padding: 15px; margin-bottom: 10px; border-radius: 5px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h5 style="margin: 0 0 5px 0;">${variation.VariationName}</h5>
                        <p style="margin: 0; color: #666;">
                            ${variation.Color ? `Color: ${variation.Color} | ` : ''}
                            Quantity: ${variation.Quantity} |
                            Price: ₱${parseFloat(variation.Price || 0).toFixed(2)} |
                            Status: ${variation.IsActive ? 'Active' : 'Inactive'} |
                            Created: ${new Date(variation.CreatedAt).toLocaleDateString()}
                        </p>
                        ${variation.VariationImageURL ? `<img src="${variation.VariationImageURL}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; margin-top: 5px;">` : ''}
                    </div>
                    <div>
                        <button onclick="editVariation(${variation.VariationID})" style="background: #ffc107; color: #333; border: none; padding: 5px 10px; border-radius: 4px; margin-right: 5px; cursor: pointer;">Edit</button>
                        <button onclick="deleteVariation(${variation.VariationID}, '${escapedName}', ${variation.Quantity || 0})" style="background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">Delete</button>
                    </div>
                </div>
            `;
            }).join('');

            variationsContainer.innerHTML = variationsHTML;
        }

        // Edit variation functionality
        window.editVariation = function(variationId) {
            // Find the variation data from the current variations list
            const variations = window.currentVariations || [];
            const variation = variations.find(v => v.VariationID == variationId);
            
            
            if (!variation) {
                showVariationModalNotification('Variation not found!', true);
                return;
            }
            
            // Populate the edit form with current variation data
            document.getElementById('editVariationID').value = variation.VariationID;
            document.getElementById('editVariationName').value = variation.VariationName;
            document.getElementById('editVariationColor').value = variation.Color || '';
            document.getElementById('editVariationQuantity').value = variation.Quantity;
            document.getElementById('editVariationPrice').value = variation.Price || 0;
            document.getElementById('editVariationIsActive').checked = variation.IsActive;
            
            // Removed validation: No max quantity restriction and no stock info message
            // User requested removal of this validation
            const editAvailableStockInfo = document.getElementById('editAvailableStockInfo');
                if (editAvailableStockInfo) {
                editAvailableStockInfo.textContent = '';
                editAvailableStockInfo.style.display = 'none'; // Hide the info message
            }
            
            // Show current image if exists
            const imagePreview = document.getElementById('currentVariationImagePreview');
            if (variation.VariationImageURL) {
                imagePreview.innerHTML = `
                    <small>Current image:</small><br>
                    <img src="${variation.VariationImageURL}" style="width: 100px; height: 100px; object-fit: cover; border-radius: 4px; margin-top: 5px;">
                `;
            } else {
                imagePreview.innerHTML = '<small>No current image</small>';
            }
            
            // Show the edit modal
            document.getElementById('editVariationModal').classList.add('show');
        };

        // Delete variation - shows confirmation modal
        window.deleteVariation = function(variationId, variationName, variationQuantity) {
            // Populate delete confirmation modal with variation info
            // Use provided parameters or try to find in current variations list as fallback
            let name = variationName || 'N/A';
            let quantity = variationQuantity || 0;
            
            // If parameters not provided, try to find in current variations list
            if (!variationName || variationQuantity === undefined) {
                const variations = window.currentVariations || [];
                const variation = variations.find(v => v.VariationID == variationId);
                if (variation) {
                    name = variation.VariationName || 'N/A';
                    quantity = variation.Quantity || 0;
                }
            }
            
            // Populate delete confirmation modal with variation info
            document.getElementById('deleteVariationName').textContent = name;
            document.getElementById('deleteVariationQuantity').textContent = quantity;
            
            // Store variation ID for deletion
            document.getElementById('deleteVariationModal').setAttribute('data-variation-id', variationId);
            
            // Show delete confirmation modal
            document.getElementById('deleteVariationModal').style.display = 'flex';
        };

        // Delete Variation Confirmation Modal Event Listeners
        const deleteVariationModal = document.getElementById('deleteVariationModal');
        const cancelDeleteVariation = document.getElementById('cancelDeleteVariation');
        const confirmDeleteVariation = document.getElementById('confirmDeleteVariation');

        // Cancel delete variation
        cancelDeleteVariation.addEventListener('click', function() {
            deleteVariationModal.style.display = 'none';
        });

        // Close modal when clicking outside
        window.addEventListener('click', function(event) {
            if (event.target === deleteVariationModal) {
                deleteVariationModal.style.display = 'none';
            }
        });

        // Confirm delete variation
        confirmDeleteVariation.addEventListener('click', async function() {
            const variationId = deleteVariationModal.getAttribute('data-variation-id');
            
            if (!variationId) {
                showVariationModalNotification('Variation ID not found!', true);
                return;
            }
            
            // Disable button to prevent double-click
            confirmDeleteVariation.disabled = true;
            confirmDeleteVariation.textContent = 'Deleting...';
            
            try {
                const response = await fetch(`/Employee/Admin/Variations/Delete/${variationId}`, {
                    method: 'POST'
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const result = await response.json();
                
                if (result.success) {
                    // Close delete modal
                    deleteVariationModal.style.display = 'none';
                    // Show success notification
                    showVariationModalNotification(result.message || 'Variation deleted successfully.');
                    
                    // Get product ID and reload variations list
                    const productId = document.getElementById('variationProductID').value;
                    if (productId) {
                        await loadVariations(productId);
                    }
                } else {
                    showVariationModalNotification(result.message || 'Failed to delete variation.', true);
                }
            } catch (error) {
                console.error('Error deleting variation:', error);
                showVariationModalNotification('Failed to delete variation. Please try again.', true);
            } finally {
                // Re-enable button
                confirmDeleteVariation.disabled = false;
                confirmDeleteVariation.textContent = 'Delete Variation';
            }
        });

        // Edit Variation Modal Event Listeners
        const editVariationModal = document.getElementById('editVariationModal');
        const closeEditVariationModal = document.getElementById('closeEditVariationModal');
        const editVariationForm = document.getElementById('editVariationForm');
        const cancelEditVariation = document.getElementById('cancelEditVariation');

        // Close edit variation modal
        closeEditVariationModal.addEventListener('click', function() {
            editVariationModal.classList.remove('show');
        });

        // Cancel edit variation
        cancelEditVariation.addEventListener('click', function() {
            editVariationModal.classList.remove('show');
        });

        // Edit variation form submission
        editVariationForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            
            
            try {
                const response = await fetch('/Employee/Admin/Variations/Edit', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showEditVariationModalNotification(result.message);
                    setTimeout(() => {
                        editVariationModal.classList.remove('show');
                        this.reset();
                        loadVariations(document.getElementById('variationProductID').value);
                    }, 1500);
                } else {
                    showEditVariationModalNotification(result.message, true);
                }
            } catch (error) {
                console.error('Error updating variation:', error);
                showEditVariationModalNotification('Failed to update variation', true);
            }
        });

        // Toggle Variations Row
        document.addEventListener('click', function(e) {
            if (e.target.closest('.toggle-variations-btn')) {
                const btn = e.target.closest('.toggle-variations-btn');
                const productId = btn.getAttribute('data-product-id');
                const inventoryProductId = btn.getAttribute('data-inventory-product-id');
                const variationsRow = document.querySelector(`tr.variations-row[data-product-id="${productId}"]`);
                
                if (variationsRow) {
                    const isVisible = variationsRow.style.display !== 'none';
                    variationsRow.style.display = isVisible ? 'none' : 'table-row';
                    btn.classList.toggle('expanded', !isVisible);
                    
                    // Load variations if showing for the first time
                    if (!isVisible) {
                        loadProductVariations(productId, inventoryProductId);
                    }
                }
            }
        });

        // Refresh Variations
        document.addEventListener('click', function(e) {
            if (e.target.closest('.refresh-variations-btn')) {
                const btn = e.target.closest('.refresh-variations-btn');
                const productId = btn.getAttribute('data-product-id');
                const inventoryProductId = btn.getAttribute('data-inventory-product-id');
                loadProductVariations(productId, inventoryProductId);
            }
        });

        // Load Product Variations from Inventory
        async function loadProductVariations(productId, inventoryProductId) {
            const container = document.querySelector(`.variations-container[data-product-id="${productId}"]`);
            if (!container) return;

            const loadingDiv = container.querySelector('.variations-loading');
            const tableContainer = container.querySelector('.variations-table-container');
            const emptyDiv = container.querySelector('.variations-empty');
            const tableBody = container.querySelector('.variations-table-body');

            // Show loading
            loadingDiv.style.display = 'block';
            tableContainer.style.display = 'none';
            emptyDiv.style.display = 'none';

            try {
                // Use inventoryProductId if available, otherwise use productId
                const apiProductId = inventoryProductId || productId;
                const response = await fetch(`/api/admin/inventory-product-variations/${apiProductId}`);
                const result = await response.json();

                if (result.success && result.variations && result.variations.length > 0) {
                    // Display variations
                    tableBody.innerHTML = '';
                    result.variations.forEach(variation => {
                        const availableQty = variation.AvailableQuantity !== null && variation.AvailableQuantity !== undefined 
                            ? variation.AvailableQuantity 
                            : (variation.Quantity || 0);
                        const damagedQty = variation.DamagedQuantity || 0;
                        const returnedQty = variation.ReturnedQuantity || 0;
                        const repairedQty = variation.RepairedQuantity || 0;
                        const disposedQty = variation.DisposedQuantity || 0;
                        const totalQty = (availableQty + damagedQty) > 0 
                            ? (availableQty + damagedQty) 
                            : (variation.Quantity || 0);

                        const row = document.createElement('tr');
                        row.innerHTML = `
                            <td><strong>${escapeHtml(variation.VariationName || 'N/A')}</strong></td>
                            <td>${escapeHtml(variation.Color || 'N/A')}</td>
                            <td style="text-align: center;"><strong style="font-size: 1.1em; color: #007bff;">${totalQty}</strong></td>
                            <td style="text-align: center;">
                                <span class="status-badge status-available">${availableQty}</span>
                            </td>
                            <td style="text-align: center;">
                                ${damagedQty > 0 ? `<span class="status-badge status-damaged">${damagedQty}</span>` : '<span style="color: #999;">0</span>'}
                            </td>
                            <td style="text-align: center;">
                                ${returnedQty > 0 ? `<span class="status-badge status-returned">${returnedQty}</span>` : '<span style="color: #999;">0</span>'}
                            </td>
                            <td style="text-align: center;">
                                ${repairedQty > 0 ? `<span class="status-badge status-repaired">${repairedQty}</span>` : '<span style="color: #999;">0</span>'}
                            </td>
                            <td style="text-align: center;">
                                ${disposedQty > 0 ? `<span class="status-badge status-disposed">${disposedQty}</span>` : '<span style="color: #999;">0</span>'}
                            </td>
                            <td style="text-align: center;">₱${parseFloat(variation.Price || 0).toFixed(2)}</td>
                            <td style="text-align: center;">
                                ${variation.VariationImageURL 
                                    ? `<img src="${variation.VariationImageURL}" alt="Variation" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd;" onerror="this.src='/images/placeholder-avatar.jpg'">`
                                    : '<span style="color: #999;">No image</span>'}
                            </td>
                        `;
                        tableBody.appendChild(row);
                    });

                    loadingDiv.style.display = 'none';
                    tableContainer.style.display = 'block';
                    emptyDiv.style.display = 'none';
                } else {
                    // No variations
                    loadingDiv.style.display = 'none';
                    tableContainer.style.display = 'none';
                    emptyDiv.style.display = 'block';
                }
            } catch (error) {
                console.error('Error loading variations:', error);
                loadingDiv.innerHTML = '<p style="color: #dc3545;">Error loading variations. Please try again.</p>';
                tableContainer.style.display = 'none';
                emptyDiv.style.display = 'none';
            }
        }

        // Helper function to escape HTML
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Update variations modal to use inventory product ID
        document.addEventListener('click', function(e) {
            if (e.target.closest('.variations-btn')) {
                const btn = e.target.closest('.variations-btn');
                const productId = btn.getAttribute('data-id');
                const inventoryId = btn.getAttribute('data-inventory-id') || productId;
                const productName = btn.getAttribute('data-name');
                
                // Open variations modal and set product ID
                document.getElementById('variationsModal').classList.add('show');
                document.getElementById('variationProductID').value = inventoryId;
                document.getElementById('variationsModalTitle').textContent = `Manage Variations - ${productName}`;
                
                // Load variations
                loadVariations(inventoryId);
            }
        });
    </script>
