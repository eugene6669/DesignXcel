        async function submitProductForm(form, formData) {
            // Validate that a product is selected from inventory (only for Add Product form, not Edit)
            const isEditForm = form.id === 'editProductForm';
            if (!isEditForm) {
                // Only validate inventory product selection for Add Product form
                const selectInventoryProduct = document.getElementById('selectInventoryProduct');
                if (selectInventoryProduct) {
                    const selectedProduct = selectInventoryProduct.value;
                    if (!selectedProduct || selectedProduct.trim() === '') {
                        showCustomPopup('Please select a product from inventory before submitting.', true);
                        return;
                    }
                }
            }
            
            const url = form.action;
            try {
                const response = await fetch(url, {
                    method: form.method,
                    body: formData,
                    credentials: 'same-origin',
                    redirect: 'follow'
                });
                
                // Check for error status codes first
                if (!response.ok) {
                    // Try to parse error response as JSON
                    try {
                        const errorData = await response.json();
                        console.error('Product save failed (HTTP ' + response.status + '):', errorData);
                        showCustomPopup(errorData.message || 'Failed to save product: ' + response.statusText, true);
                        return;
                    } catch (e) {
                        // If not JSON, show generic error
                        console.error('Product save failed:', response.status, response.statusText);
                        showCustomPopup('Failed to save product: ' + response.statusText + ' (Status: ' + response.status + ')', true);
                        return;
                    }
                }
                
                // If response is HTML (redirect happened), just reload the page
                const contentType = response.headers.get('content-type') || '';
                if (contentType.includes('text/html') || response.redirected) {
                    showEditProductModalNotification('Product saved successfully!');
                    setTimeout(() => {
                        location.reload();
                    }, 1000);
                    return;
                }
                
                // Try to parse as JSON
                if (contentType.includes('application/json')) {
                    const data = await response.json();
                    console.log('Response data:', data);
                    if (data.success) {
                        const successMessage = data.message || 'Product saved successfully!';
                        showEditProductModalNotification(successMessage);
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        console.error('Product save failed:', data);
                        showCustomPopup(data.message || 'Failed to save product.', true);
                    }
                } else {
                    // Default: reload on success
                    showEditProductModalNotification('Product saved successfully!');
                    setTimeout(() => {
                        location.reload();
                    }, 1000);
                }
            } catch (error) {
                console.error('Error submitting product form:', error);
                showCustomPopup('Error saving product: ' + (error.message || 'Unknown error'), true);
                // Log the full error for debugging
                console.error('Full error object:', error);
            }
        }

