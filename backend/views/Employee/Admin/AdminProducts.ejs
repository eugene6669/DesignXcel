        .rm-btn { border: none; padding: 7px 14px; border-radius: 4px; cursor: pointer; font-size: 0.85em; font-weight: 600; }
        .rm-btn-primary { background: #28a745; color: #fff; }
        .rm-btn-secondary { background: #6c757d; color: #fff; }
        .rm-btn-info { background: #17a2b8; color: #fff; }
        .rm-quick-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; max-height: 52vh; overflow-y: auto; padding: 4px 0; }
        .rm-quick-item { border: 1px solid #dee2e6; border-radius: 4px; padding: 8px; background: #f8f9fa; font-size: 0.82em; }
        .rm-quick-item label { display: flex; gap: 8px; align-items: flex-start; cursor: pointer; margin: 0; }
        .rm-quick-cat { font-size: 0.9em; font-weight: 600; color: #333; margin: 12px 0 6px; padding-bottom: 4px; border-bottom: 1px solid #e9ecef; }
