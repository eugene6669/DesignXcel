                    }
                    
                    // Populate materials
                    if (product.RequiredMaterials && product.RequiredMaterials.length > 0) {
                        document.getElementById('addMaterialsContainer').innerHTML = '';
                        product.RequiredMaterials.forEach((material, index) => {
