                                                        </tr>
                                                    </thead>
                                                    <tbody class="variations-table-body">
                                                        <!-- Variations will be loaded here -->
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div class="variations-empty" style="display: none; text-align: center; padding: 20px; color: #999;">
                                                <p>No variations found for this product.</p>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <div class="pagination" style="text-align:center; margin-top:20px;">
                        <% if (page > 1) { %>
