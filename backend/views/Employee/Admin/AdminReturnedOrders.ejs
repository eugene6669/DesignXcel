        async function handleDeclineReturn() {
            if (!currentDeclineOrderId) {
                alert('No order selected for decline.');
                return;
            }

            // Get checked conditions (conditions NOT met)
            const uncheckedConditions = [];
            if (document.getElementById('declineConditionOriginalPackaging').checked) {
                uncheckedConditions.push('Item is NOT in original, undamaged packaging');
            }
            if (document.getElementById('declineConditionAllParts').checked) {
                uncheckedConditions.push('All parts, accessories, and documentation are NOT included');
            }
            if (document.getElementById('declineConditionUnused').checked) {
                uncheckedConditions.push('Item has been used or modified');
            }
            if (document.getElementById('declineConditionProofOfPurchase').checked) {
                uncheckedConditions.push('No proof of purchase provided');
            }

            const additionalReason = document.getElementById('declineReasonInput').value.trim();
            
            // Build decline reason
            let declineReason = '';
            if (uncheckedConditions.length > 0) {
                declineReason = 'Conditions NOT met: ' + uncheckedConditions.join('; ');
                if (additionalReason) {
                    declineReason += '. Additional reason: ' + additionalReason;
                }
            } else if (additionalReason) {
                declineReason = additionalReason;
            } else {
                alert('Please check at least one condition that was NOT met or provide an additional reason.');
                return;
            }

            const confirmBtn = document.getElementById('confirmDeclineBtn');
            if (confirmBtn) {
                confirmBtn.disabled = true;
                confirmBtn.textContent = 'Processing...';
            }

            try {
                const response = await fetch(`/api/admin/orders/${currentDeclineOrderId}/return/decline`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include',
                    body: JSON.stringify({ 
                        declineReason: declineReason,
                        uncheckedConditions: uncheckedConditions
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showSuccessModal('Return request declined successfully. A decline email has been sent to the customer.', '', 'decline');
                    closeDeclineModal();
                    setTimeout(() => {
                        window.location.reload();
                    }, 3000);
                } else {
                    alert(result.message || 'Failed to decline return request.');
                    if (confirmBtn) {
                        confirmBtn.disabled = false;
                        confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg> Decline Return';
                    }
                }
            } catch (error) {
                console.error('Error declining return:', error);
                alert('An error occurred while declining the return. Please try again.');
                if (confirmBtn) {
                    confirmBtn.disabled = false;
                    confirmBtn.textContent = 'Decline Return';
                }
            }
        }

