                            </div>
                            <h3>Success!</h3>
                            <p id="successModalMessage" style="color: #6b7280; font-size: 1rem; line-height: 1.6; margin-bottom: 24px;"></p>
                            <div id="successModalDetails"></div>
                            <div class="modal-buttons">
                                <button class="modal-button confirm" onclick="closeSuccessModal()" style="min-width: 120px;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    OK
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                document.body.insertAdjacentHTML('beforeend', modalHTML);
            }
            
            const modalEl = document.getElementById('successModal');
            const iconEl = document.getElementById('successModalIcon');
            const messageEl = document.getElementById('successModalMessage');
            const detailsEl = document.getElementById('successModalDetails');
            
            if (type === 'decline') {
                iconEl.className = 'modal-icon decline';
                iconEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
            } else if (type === 'refund') {
                iconEl.className = 'modal-icon refund';
                iconEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>';
            } else if (type === 'replacement') {
                iconEl.className = 'modal-icon approve';
                iconEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>';
            } else {
                iconEl.className = 'modal-icon approve';
                iconEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            }
            
            messageEl.textContent = message;
            if (detailsHtml) {
                detailsEl.innerHTML = detailsHtml;
                detailsEl.style.display = 'block';
            } else {
                detailsEl.style.display = 'none';
            }
            
            modalEl.classList.add('show');
        }

        function closeSuccessModal() {
            const modal = document.getElementById('successModal');
            if (modal) {
                modal.classList.remove('show');
            }
        }

        // Close modals when clicking outside
        document.addEventListener('click', function(event) {
            const declineModal = document.getElementById('declineReturnModal');
            const approveModal = document.getElementById('approveReturnModal');
            const refundModal = document.getElementById('refundConfirmModal');
            const replacementModal = document.getElementById('replacementConfirmModal');
            const successModal = document.getElementById('successModal');
            if (declineModal && event.target === declineModal) {
                closeDeclineModal();
            }
            if (approveModal && event.target === approveModal) {
                closeApproveModal();
            }
            if (refundModal && event.target === refundModal) {
                closeRefundModal();
            }
            if (replacementModal && event.target === replacementModal) {
                closeReplacementModal();
            }
            if (successModal && event.target === successModal) {
                closeSuccessModal();
            }
        });

        async function confirmReturnPickup(orderId) {
            if (!orderId) return;
            if (!confirm('Confirm that returned items have been picked up from the customer?')) return;
            try {
                const response = await fetch('/api/admin/orders/' + orderId + '/return/pickup-complete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include'
                });
                const result = await response.json();
                if (result.success) {
                    showSuccessModal(result.message || 'Pickup confirmed.', '', 'approve');
                    setTimeout(function () { window.location.reload(); }, 1200);
                } else {
                    alert(result.message || 'Failed to confirm pickup.');
                }
            } catch (err) {
                console.error('Error confirming pickup:', err);
                alert('Failed to confirm pickup. Please try again.');
            }
        }

        // Replacement Handler (after pickup confirmed)
        let currentReplacementOrderId = null;

        function openReplacementModal(orderId) {
            currentReplacementOrderId = orderId;
            const modal = document.getElementById('replacementConfirmModal');
            if (modal) {
                modal.classList.add('show');
            }
        }

        function closeReplacementModal() {
            const modal = document.getElementById('replacementConfirmModal');
            if (modal) {
                modal.classList.remove('show');
            }
            currentReplacementOrderId = null;
        }

        async function confirmReplacement() {
            if (!currentReplacementOrderId) {
                alert('No order selected for replacement processing.');
                return;
            }

            const confirmBtn = document.getElementById('confirmReplacementBtn');
            if (confirmBtn) {
                confirmBtn.disabled = true;
                confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg> Processing...';
            }

            try {
                const response = await fetch(`/api/admin/orders/${currentReplacementOrderId}/replacement`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include'
                });

                const result = await response.json();

                if (result.success) {
                    showSuccessModal('Replacement processed. Returned items were added to inventory. Manage stock in Product Returns.', '', 'replacement');
                    closeReplacementModal();
                    setTimeout(() => {
                        window.location.href = '/Employee/Admin/ProductReturns';
                    }, 1500);
                } else {
                    alert(result.message || 'Failed to process replacement.');
                    if (confirmBtn) {
                        confirmBtn.disabled = false;
                        confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg> Proceed to Processing';
                    }
                }
            } catch (error) {
                console.error('Error processing replacement:', error);
                alert('An error occurred while processing the replacement. Please try again.');
                if (confirmBtn) {
                    confirmBtn.disabled = false;
                    confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg> Proceed to Processing';
                }
            }
        }

        async function handleReplacement(orderId) {
            // Legacy function - redirects to modal
            openReplacementModal(orderId);
        }

        // Refund Handler (for processing after approval)
        let currentRefundOrderId = null;

        function openRefundModal(orderId) {
            currentRefundOrderId = orderId;
            const modal = document.getElementById('refundConfirmModal');
            if (modal) {
                modal.classList.add('show');
            }
        }

        function closeRefundModal() {
            const modal = document.getElementById('refundConfirmModal');
            if (modal) {
                modal.classList.remove('show');
            }
            currentRefundOrderId = null;
        }

        async function confirmRefund() {
            if (!currentRefundOrderId) {
                alert('No order selected for refund.');
                return;
            }

            const confirmBtn = document.getElementById('confirmRefundBtn');
            if (confirmBtn) {
                confirmBtn.disabled = true;
                confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg> Processing...';
            }

            try {
                const response = await fetch(`/api/admin/orders/${currentRefundOrderId}/refund`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include'
                });

                const result = await response.json();

                if (result.success) {
                    let message = 'Refund processed successfully. The money has been refunded to the customer.';
                    if (result.refundAmount) {
                        message += ` Refund Amount: ₱${Number(result.refundAmount).toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
                    }
                    if (result.stripeRefundId) {
                        message += ` Stripe Refund ID: ${result.stripeRefundId}`;
                    }
                    showSuccessModal(message, '', 'refund');
                    closeRefundModal();
                    setTimeout(() => {
                        window.location.href = '/Employee/Admin/ProductReturns';
                    }, 1500);
                } else {
                    alert(result.message || 'Failed to process refund.');
                    if (confirmBtn) {
                        confirmBtn.disabled = false;
                        confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg> Process Refund';
                    }
                }
            } catch (error) {
                console.error('Error processing refund:', error);
                alert('An error occurred while processing the refund. Please try again.');
                if (confirmBtn) {
                    confirmBtn.disabled = false;
                    confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg> Process Refund';
                }
            }
        }

        async function handleRefund(orderId) {
            // Legacy function - redirects to modal
            openRefundModal(orderId);
        }
    </script>

</body>
</html> 