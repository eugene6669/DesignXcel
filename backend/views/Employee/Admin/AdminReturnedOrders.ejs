        // Payment Status Check
        async function checkPaymentStatus(orderId) {
            const modal = document.getElementById(`payment-modal-${orderId}`);
            const modalBody = document.getElementById(`payment-modal-body-${orderId}`);
            
            if (!modal || !modalBody) {
                console.error('Payment modal not found for order:', orderId);
                return;
            }
            
            // Show modal with loading state
            modal.classList.add('show');
            modalBody.innerHTML = `
                <div style="text-align: center; padding: 2rem;">
                    <div style="display: inline-block; width: 40px; height: 40px; border: 4px solid #e5e7eb; border-top-color: #F0B21B; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <p style="margin-top: 1rem; color: #6b7280;">Loading payment details...</p>
                </div>
            `;
            
            try {
                const response = await fetch(`/api/admin/payment-status/${orderId}`, {
                    method: 'GET',
                    credentials: 'include'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    const details = result.paymentDetails;
                    const paymentStatus = (details.PaymentStatus || 'Unknown').toLowerCase();
                    const statusClass = paymentStatus === 'paid' || paymentStatus === 'completed' ? 'paid' : 
                                      paymentStatus === 'pending' ? 'pending' : 'failed';
                    
                    let html = `
                        <div class="payment-section">
                            <div class="payment-section-title">Payment Information</div>
                            <div class="payment-info-row">
                                <span class="payment-info-label">Payment Method</span>
                                <span class="payment-info-value">${details.PaymentMethod || 'N/A'}</span>
                            </div>
                            <div class="payment-info-row">
                                <span class="payment-info-label">Payment Status</span>
                                <span class="payment-info-value status ${statusClass}">${details.PaymentStatus || 'Unknown'}</span>
                            </div>
                            <div class="payment-info-row">
                                <span class="payment-info-label">Total Amount</span>
                                <span class="payment-info-value amount">₱${Number(details.TotalAmount || 0).toLocaleString(undefined, { minimumFractionDigits: 2 })}</span>
                            </div>
                            <div class="payment-info-row">
                                <span class="payment-info-label">Order Date</span>
                                <span class="payment-info-value">${new Date(details.OrderDate).toLocaleString('en-US', { 
                                    year: 'numeric', 
                                    month: 'long', 
                                    day: 'numeric', 
                                    hour: '2-digit', 
                                    minute: '2-digit' 
                                })}</span>
                            </div>
                    `;
                    
                    const paymentIdentifier = details.PaymentIdentifier || details.StripeSessionID || details.TransactionID;
                    const paymentIdentifierLabel = details.PaymentIdentifierLabel || 'Payment ID';
                    if (paymentIdentifier) {
                        html += `
                            <div class="payment-info-row">
                                <span class="payment-info-label">${paymentIdentifierLabel}</span>
                                <span class="payment-info-value" style="font-size: 0.75rem; word-break: break-all;">${paymentIdentifier}</span>
                            </div>
                        `;
                    }
                    if (details.CheckoutSessionValue && details.CheckoutSessionLabel) {
                        html += `
                            <div class="payment-info-row">
                                <span class="payment-info-label">${details.CheckoutSessionLabel}</span>
                                <span class="payment-info-value" style="font-size: 0.75rem; word-break: break-all;">${details.CheckoutSessionValue}</span>
                            </div>
                        `;
                    }
                    
                    html += `</div>`;
                    
                    if (details.stripeDetails) {
                        const gw = details.stripeDetails || {};
                        const stripeStatusRaw = gw.payment_status || details.PaymentStatus || 'unknown';
                        const stripeStatus = String(stripeStatusRaw).toLowerCase();
                        const stripeStatusClass = stripeStatus === 'paid' || stripeStatus === 'complete' ? 'paid' : 
                                                  stripeStatus === 'pending' || stripeStatus === 'unpaid' ? 'pending' : 'failed';
                        const cents = Number(gw.amount_total);
                        const orderTotalNum = Number(details.TotalAmount || 0);
                        const amountPhp = (Number.isFinite(cents) && cents > 0) ? (cents / 100) : orderTotalNum;
                        const pmLabel = (details.DisplayPaymentMethod || details.PaymentMethod || '').toString();
                        const gwTitle = pmLabel.toLowerCase().includes('stripe') ? 'Stripe Details' : pmLabel.toLowerCase().includes('paymongo') ? 'PayMongo Details' : 'Gateway Details';
                        const custEmail = gw.customer_email || details.CustomerEmail || 'N/A';
                        
                        html += `
                            <div class="payment-section">
                                <div class="payment-section-title">${gwTitle}</div>
                                <div class="stripe-details-section">
                                    <div class="payment-info-row">
                                        <span class="payment-info-label">Payment Status</span>
                                        <span class="payment-info-value status ${stripeStatusClass}">${gw.payment_status || details.PaymentStatus || 'Unknown'}</span>
                                    </div>
                                    <div class="payment-info-row">
                                        <span class="payment-info-label">Amount Paid</span>
                                        <span class="payment-info-value amount">₱${amountPhp.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
                                    </div>
                                    <div class="payment-info-row">
                                        <span class="payment-info-label">Currency</span>
                                        <span class="payment-info-value">${(gw.currency || 'php').toUpperCase()}</span>
                                    </div>
                                    <div class="payment-info-row">
                                        <span class="payment-info-label">Customer Email</span>
                                        <span class="payment-info-value">${custEmail}</span>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                    
                    modalBody.innerHTML = html;
                } else {
                    modalBody.innerHTML = `
                        <div style="text-align: center; padding: 2rem;">
                            <div style="color: #ef4444; font-size: 3rem; margin-bottom: 1rem;">⚠️</div>
                            <p style="color: #6b7280; font-size: 1rem;">${result.message || 'Failed to retrieve payment details'}</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error checking payment status:', error);
                modalBody.innerHTML = `
                    <div style="text-align: center; padding: 2rem;">
                        <div style="color: #ef4444; font-size: 3rem; margin-bottom: 1rem;">⚠️</div>
                        <p style="color: #6b7280; font-size: 1rem;">Error checking payment status. Please try again.</p>
                    </div>
                `;
            }
        }

