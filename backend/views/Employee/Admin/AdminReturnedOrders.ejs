        async function confirmApproveReturn() {
            if (!currentApproveOrderId) {
                alert('No order selected for approval.');
                return;
            }

            const confirmBtn = document.getElementById('confirmApproveBtn');
            if (confirmBtn) {
                confirmBtn.disabled = true;
                confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Processing...';
            }

            try {
                const response = await fetch(`/api/admin/orders/${currentApproveOrderId}/return/approve`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include'
                });

                const result = await response.json();

                if (result.success) {
                    let message = 'Return request approved successfully. An approval email has been sent to the customer.';
                    let detailsHtml = '';
                    if (result.fees) {
                        detailsHtml = '<div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #e5e7eb;">';
                        if (result.fees.returnShippingFee > 0) {
                            detailsHtml += `<p style="margin: 0 0 8px 0; color: #6b7280; font-size: 14px;">Return Shipping Fee: ₱${Number(result.fees.returnShippingFee).toLocaleString(undefined, { minimumFractionDigits: 2 })}</p>`;
                        }
                        if (result.fees.refundAmount > 0) {
                            detailsHtml += `<p style="margin: 8px 0 0 0; color: #10b981; font-size: 16px; font-weight: 600;">Refund Amount: ₱${Number(result.fees.refundAmount).toLocaleString(undefined, { minimumFractionDigits: 2 })}</p>`;
                        }
                        detailsHtml += '</div>';
                    }
                    showSuccessModal(message, detailsHtml);
                    closeApproveModal();
                    setTimeout(() => {
                        window.location.reload();
                    }, 3000);
                } else {
                    alert(result.message || 'Failed to approve return request.');
                    if (confirmBtn) {
                        confirmBtn.disabled = false;
                        confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Approve Return';
                    }
                }
            } catch (error) {
                console.error('Error approving return:', error);
                alert('An error occurred while approving the return. Please try again.');
                if (confirmBtn) {
                    confirmBtn.disabled = false;
                    confirmBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Approve Return';
                }
            }
        }

