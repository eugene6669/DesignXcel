                                                    <h4 style="font-size: 0.875rem; font-weight: 600; color: #6b7280; text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px;">
                                                        Products (<%= order.items ? order.items.length : 0 %>)
