                                        <td class="orders-actions-cell" style="padding: 1rem; text-align: center;">
                                            <div class="table-action-buttons">
                                                <button class="order-card-toggle table-action-btn" type="button" data-toggle-target="<%= order.OrderID %>" style="background: #F0B21B; color: white;" onclick="toggleOrderDetails(<%= order.OrderID %>)">View</button>
                                                <% if (order.Status === 'Returned') { %>
                                                    <button type="button" onclick="openApproveModal(<%= order.OrderID %>)" class="btn-action btn-approve table-action-btn">Approve</button>
                                                    <button type="button" onclick="openDeclineModal(<%= order.OrderID %>)" class="btn-action btn-decline table-action-btn">Decline</button>
                                                <% } else if (order.Status === 'Processing (Pickup)' || (order.Status === 'Processing' && order.ActionType)) { %>
                                                    <button type="button" onclick="confirmReturnPickup(<%= order.OrderID %>)" class="btn-action btn-approve table-action-btn">Confirm Pickup</button>
                                                <% } else if (order.Status === 'Pickup Received' && (order.ActionType || '').toLowerCase() === 'refund') { %>
                                                    <button type="button" onclick="openRefundModal(<%= order.OrderID %>)" class="btn-action btn-refund table-action-btn">Refund</button>
                                                <% } else if (order.Status === 'Pickup Received' && (order.ActionType || '').toLowerCase() === 'replacement') { %>
                                                    <button type="button" onclick="openReplacementModal(<%= order.OrderID %>)" class="btn-action btn-replacement table-action-btn">Replace</button>
                                                <% } else if (order.Status === 'Refunded' || order.Status === 'Completed Returned') { %>
                                                    <a href="/Employee/Admin/ProductReturns" class="btn-action table-action-btn" style="background:#6366f1;color:#fff;text-decoration:none;">Product Returns</a>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Order Details Row (Hidden by default) -->
                                    <tr id="table-details-<%= order.OrderID %>" style="display: none; background: #f9fafb;">
                                        <td colspan="8" style="padding: 1.5rem;">
                                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
                                                <!-- Customer Section -->
                                                <div>
                                                    <h4 style="font-size: 0.875rem; font-weight: 600; color: #6b7280; text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em;">Customer</h4>
                                                    <div style="font-size: 0.875rem; color: #111827; line-height: 1.6;">
                                                        <div><strong><%= order.CustomerName %></strong></div>
                                                        <div style="margin-top: 0.25rem;"><%= order.CustomerEmail %></div>
                                                        <div style="margin-top: 0.25rem;">Phone: <%= order.CustomerPhone %></div>
                                                    </div>
                                                </div>

                                                <!-- Shipping Address Section -->
                                                <% if (order.DeliveryType !== 'pickup' && order.DeliveryTypeName !== 'Pick up') { %>
