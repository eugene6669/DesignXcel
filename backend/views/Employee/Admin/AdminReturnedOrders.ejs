                                        style="border-bottom: 1px solid #e5e7eb; transition: background 0.2s;" 
                                        onmouseover="this.style.background='#f9fafb'" 
                                        onmouseout="this.style.background='#ffffff'">
                                        <td style="padding: 1rem; font-weight: 600; color: #111827;">
                                            <%= order.ReferenceNumber || '#' + order.OrderID %>
                                            <% if (order.IsBulkOrder) { %>
                                                <span style="display: inline-flex; align-items: center; gap: 4px; margin-left: 0.5rem; background: linear-gradient(135deg, #f0b21b 0%, #d4a017 100%); color: white; padding: 2px 8px; border-radius: 12px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase;">Bulk</span>
                                            <% } %>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <div style="font-weight: 600; color: #111827; margin-bottom: 0.25rem;"><%= order.CustomerName || 'N/A' %></div>
                                            <div style="font-size: 0.875rem; color: #6b7280;"><%= order.CustomerEmail || '' %></div>
                                        </td>
                                        <td style="padding: 1rem; font-size: 0.875rem; color: #6b7280;">
                                            <%= order.FormattedOrderDate || new Date(order.OrderDate).toLocaleString('en-US') %>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <span class="order-card-status <%= returnedOrderStatusClass(order) %>" style="display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 4px 12px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;"><%= returnedOrderStatusLabel(order) %></span>
                                        </td>
                                        <td style="padding: 1rem;">
                                            <% if (returnedOrderTypeClass(order)) { %>
                                            <span class="return-type-label <%= returnedOrderTypeClass(order) %>"><%= returnedOrderTypeLabel(order) %></span>
                                            <% } else { %>
                                            <span style="color:#9ca3af;">—</span>
                                            <% } %>
                                        </td>
                                        <td style="padding: 1rem; font-size: 0.875rem; color: #6b7280;">
                                            <%= order.PaymentMethod || 'N/A' %>
                                        </td>
                                        <td style="padding: 1rem; text-align: right; font-weight: 700; color: #111827;">
                                            <% const showRefundAmount = order.Status === 'Refunded' && order.RefundAmount > 0; %>
