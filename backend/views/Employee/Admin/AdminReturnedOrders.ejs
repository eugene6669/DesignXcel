                                                                            <img src="<%= item.VariationImageURL %>" alt="<%= item.VariationName || item.Name %>" style="width: 100%; height: 100%; object-fit: cover;">
                                                                        <% } else if (item.ImageURL) { %>
                                                                            <img src="<%= item.ImageURL %>" alt="<%= item.Name %>" style="width: 100%; height: 100%; object-fit: cover;">
                                                                        <% } else { %>
                                                                            <div style="color: #94a3b8; font-size: 1.5rem;">🖼️</div>
