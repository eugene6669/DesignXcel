                                                                        <div style="font-weight: 600; color: #111827; margin-bottom: 0.25rem;"><%= item.Name %></div>
                                                                        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 0.8rem; color: #6b7280;">
                                                                            <% if (item.VariationName) { %>
                                                                                <span>Variation: <%= item.VariationName %></span>
                                                                            <% } %>
                                                                            <% if (item.Color) { %>
                                                                                <span>Color: <%= item.Color %></span>
                                                                            <% } %>
                                                                            <% 
                                                                                // Always show "Returning: X of Y" format for returned orders with OriginalQuantity
                                                                                const showReturningFormat = item.OriginalQuantity && 
                                                                                                            (item.OriginalQuantity !== item.Quantity || item.IsReturned);
                                                                            %>
                                                                            <% if (showReturningFormat) { %>
                                                                                <span>Returning: <strong style="color: #ef4444;"><%= item.Quantity %></strong> of <strong><%= item.OriginalQuantity %></strong> ordered</span>
                                                                            <% } else { %>
                                                                                <span>Qty: <%= item.Quantity %></span>
                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                    <div style="font-weight: 700; color: #111827; font-size: 0.9rem;">
                                                                        ₱<%= Number(item.PriceAtPurchase).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
                                                                    </div>
                                                                </div>
                                                            <% }); %>
                                                        <% } else { %>
                                                            <div style="padding: 1rem; text-align: center; color: #6b7280;">No products found.</div>
                                                        <% } %>
                                                    </div>
                                                </div>

                                                <!-- Payment & Delivery Section -->
                                                <div>
                                                    <h4 style="font-size: 0.875rem; font-weight: 600; color: #6b7280; text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em;">Payment & Delivery</h4>
                                                    <div style="font-size: 0.875rem; color: #111827; line-height: 1.6; display: flex; flex-direction: column; gap: 0.5rem;">
                                                        <div>
                                                            Payment Method: <strong><%= order.PaymentMethod || 'N/A' %></strong>
                                                            <% if (order.StripeSessionID || order.TransactionID || String((order.PaymentMethodDisplay||order.PaymentMethod||'')).toLowerCase().includes('cash')) { %>
                                                                <button type="button" class="btn-filter btn-filter-primary js-check-payment" style="padding:0.35rem 0.65rem;font-size:0.7rem;margin-left:0.5rem;" data-order-id="<%= order.OrderID %>">Check Payment</button>
                                                            <% } %>
                                                        </div>
                                                        <% if (order.TransactionID) { %>
                                                        <div>Payment Reference: <strong style="font-family: monospace; font-size: 0.9em; color: #64748b;"><%= order.TransactionID %></strong></div>
                                                        <% } %>
                                                        <div>Service Type: <strong><%= order.DeliveryTypeName || 'Pick up' %></strong></div>
                                                        <% if ((order.DeliveryTypeName === 'Pick up' || order.DeliveryType === 'pickup') && order.PickupDate) { %>
                                                        <div>
                                                            Pickup Date: <strong><%= new Date(order.PickupDate).toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: true }) %></strong>
                                                        </div>
                                                        <% } %>
                                                    </div>
                                                </div>

                                                <!-- Order Summary Section -->
                                                <div>
                                                    <h4 style="font-size: 0.875rem; font-weight: 600; color: #6b7280; text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em;">Order Summary</h4>
                                                    <div style="font-size: 0.875rem; color: #111827; display: flex; flex-direction: column; gap: 0.5rem;">
                                                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #e2e8f0;">
                                                            <span>Subtotal:</span>
                                                            <strong>₱<%= Number(order.Subtotal || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %></strong>
                                                        </div>
                                                        <% if (!order.IsBulkOrder) { %>
                                                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #e2e8f0;">
                                                            <span>Shipping Fee:</span>
                                                            <strong>₱<%= Number(order.DeliveryCost || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %></strong>
                                                        </div>
                                                        <% } %>
                                                        <% 
                                                            let extraFee = 0;
                                                            if (order.ExtraDeliveryFee !== undefined && order.ExtraDeliveryFee !== null) {
                                                                extraFee = parseFloat(order.ExtraDeliveryFee) || 0;
                                                            }
                                                            if (extraFee === 0 || isNaN(extraFee)) {
                                                                const subtotal = parseFloat(order.Subtotal || 0);
                                                                const shipping = parseFloat(order.DeliveryCost || 0);
                                                                const total = parseFloat(order.TotalAmount || 0);
                                                                const calculatedSum = subtotal + shipping;
                                                                const difference = total - calculatedSum;
                                                                if (difference > 1) {
                                                                    extraFee = difference;
                                                                }
                                                            }
                                                        %>
                                                        <% if (extraFee > 0) { %>
                                                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #e2e8f0;">
                                                            <span>Extra Delivery Fee (Qty &gt; 4):</span>
                                                            <strong>₱<%= extraFee.toLocaleString(undefined, { minimumFractionDigits: 2 }) %></strong>
                                                        </div>
                                                        <% } %>
                                                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; margin-top: 0.5rem; border-top: 2px solid #0f172a;">
                                                            <span style="font-weight: 700; font-size: 1.05rem;">Total:</span>
                                                            <strong style="font-weight: 700; font-size: 1.05rem; color: #0f172a;">₱<%= Number(order.TotalAmount || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %></strong>
                                                        </div>
                                                    </div>
                                                </div>

                                                <%- include('partials/admin-returned-order-actions', {
                                                    order: order,
                                                    returnedOrderStatusLabel: returnedOrderStatusLabel,
                                                    returnedOrderStatusClass: returnedOrderStatusClass,
                                                    returnedOrderTypeLabel: returnedOrderTypeLabel,
                                                    returnedOrderTypeClass: returnedOrderTypeClass,
                                                    computeRefundAmountForOrder: computeRefundAmountForOrder,
                                                    refundPolicySummary: refundPolicySummary,
                                                    returnConditionsUnmetCount: returnConditionsUnmetCount,
                                                    conditionMet: conditionMet
                                                }) %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination Controls -->
                    <% if (pagination && pagination.totalPages > 1) {
                        const pgBtnBase = 'padding: 0.625rem 1rem; border: 1px solid #e5e7eb; border-radius: 6px; font-weight: 600; font-size: 0.875rem; transition: all 0.2s;';
                        const pgBtnDisabled = pgBtnBase + ' background: #f3f4f6; color: #9ca3af; cursor: not-allowed;';
                        const pgBtnEnabled = pgBtnBase + ' background: #ffffff; color: #374151; cursor: pointer;';
                        const pgPageStart = Math.max(1, pagination.currentPage - 2);
                        const pgPageEnd = Math.min(pagination.totalPages, pagination.currentPage + 2);
                    %>
                        <div style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 2rem; flex-wrap: wrap;">
                            <% if (pagination.currentPage === 1) { %>
                            <button type="button" disabled style="<%= pgBtnDisabled %>">Previous</button>
                            <% } else { %>
                            <button type="button" class="pagination-go-btn" data-page="<%= pagination.currentPage - 1 %>" style="<%= pgBtnEnabled %>" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='#ffffff'">Previous</button>
                            <% } %>

                            <% for (let i = pgPageStart; i <= pgPageEnd; i++) {
                                const isCurrentPage = i === pagination.currentPage;
                            %>
                                <% if (isCurrentPage) { %>
                                <button type="button" disabled style="<%= pgBtnBase %> background: #F0B21B; color: #ffffff; cursor: default; min-width: 40px;"><%= i %></button>
                                <% } else { %>
                                <button type="button" class="pagination-go-btn" data-page="<%= i %>" style="<%= pgBtnEnabled %> min-width: 40px;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='#ffffff'"><%= i %></button>
                                <% } %>
                            <% } %>

                            <% if (pagination.currentPage === pagination.totalPages) { %>
                            <button type="button" disabled style="<%= pgBtnDisabled %>">Next</button>
                            <% } else { %>
                            <button type="button" class="pagination-go-btn" data-page="<%= pagination.currentPage + 1 %>" style="<%= pgBtnEnabled %>" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='#ffffff'">Next</button>
                            <% } %>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-state-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                                <polyline points="3.27 6.96 12 12 20.73 6.96"></polyline>
                                <line x1="12" y1="22" x2="12" y2="12"></line>
                            </svg>
                        </div>
                        <div class="empty-state-text">No returned orders found.</div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <div id="order-success-popup"></div>

    <!-- Loading Spinner Utility -->
    <script src="/js/Employee/Admin/admin-loading-spinner.js"></script>
    <script src="/js/Employee/Admin/admin-orders-compact.js?v=20260524a"></script>
    
    <script>
        // Loading Spinner Helper (if utility not loaded)
        if (typeof showLoadingSpinner === 'undefined') {
            function showLoadingSpinner(spinnerId = 'orders-loading-spinner', text = 'Loading...') {
                const spinner = document.getElementById(spinnerId);
                if (spinner) {
                    const textElement = spinner.querySelector('.admin-loading-spinner__text');
                    if (textElement && text) textElement.textContent = text;
                    spinner.classList.remove('hidden');
                    spinner.style.display = 'flex';
                }
            }
            function hideLoadingSpinner(spinnerId = 'orders-loading-spinner') {
                const spinner = document.getElementById(spinnerId);
                if (spinner) {
                    spinner.classList.add('hidden');
                    spinner.style.display = 'none';
                }
            }
        }
        
        // View Toggle Functions
        let currentView = 'table';
        
        function switchView(view) {
            currentView = view;
            const cardsView = document.getElementById('ordersGrid');
            const tableView = document.getElementById('ordersTable');
            const cardsBtn = document.getElementById('viewCardsBtn');
            const tableBtn = document.getElementById('viewTableBtn');
            
            if (view === 'cards') {
                if (cardsView) cardsView.style.display = 'grid';
                if (tableView) tableView.style.display = 'none';
                if (cardsBtn) {
                    cardsBtn.style.background = '#F0B21B';
                    cardsBtn.style.color = 'white';
                }
                if (tableBtn) {
                    tableBtn.style.background = 'transparent';
                    tableBtn.style.color = '#6b7280';
                }
            } else {
                if (cardsView) cardsView.style.display = 'none';
                if (tableView) tableView.style.display = 'block';
                if (cardsBtn) {
                    cardsBtn.style.background = 'transparent';
                    cardsBtn.style.color = '#6b7280';
                }
                if (tableBtn) {
                    tableBtn.style.background = '#F0B21B';
                    tableBtn.style.color = 'white';
                }
            }
        }
        
        // Pagination Function
        function goToPage(page) {
            const url = new URL(window.location.href);
            url.searchParams.set('page', page);
            window.location.href = url.toString();
        }

        document.querySelectorAll('.pagination-go-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const page = parseInt(btn.getAttribute('data-page'), 10);
                if (!Number.isNaN(page)) goToPage(page);
            });
        });
        
        // Toggle Order Details in Table View
        function toggleOrderDetails(orderId) {
            const detailsRow = document.getElementById(`table-details-${orderId}`);
            if (detailsRow) {
                detailsRow.style.display = detailsRow.style.display === 'none' ? 'table-row' : 'none';
            }
        }
        
        document.querySelectorAll('.order-card-toggle').forEach(toggle => {
            toggle.addEventListener('click', () => {
                const card = toggle.closest('.order-card');
                if (!card) return;

                const collapsed = card.classList.toggle('collapsed');
                toggle.setAttribute('aria-expanded', (!collapsed).toString());

                const label = toggle.querySelector('.toggle-label');
                if (label) {
                    label.textContent = collapsed ? 'View Details' : 'Hide Details';
                }
            });
        });
    </script>

    <!-- Custom Confirmation Modal -->
    <div id="logoutConfirmModal" class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Logout</h3>
            <p>Are you sure you want to log out?</p>
            <div class="modal-buttons">
                <button class="modal-button confirm" id="confirmLogoutBtn">Logout</button>
                <button class="modal-button cancel" id="cancelLogoutBtn">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        // Custom Logout Modal Logic
        const logoutConfirmModal = document.getElementById('logoutConfirmModal');
        const confirmLogoutBtn = document.getElementById('confirmLogoutBtn');
        const cancelLogoutBtn = document.getElementById('cancelLogoutBtn');

        async function handleLogout(event) {
            event.preventDefault();
            logoutConfirmModal.classList.add('show');
        }

        confirmLogoutBtn.addEventListener('click', async () => {
            logoutConfirmModal.classList.remove('show');
            try {
                const response = await fetch('/logout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    window.location.href = '/login';
                } else {
                    console.error('Logout failed');
                    alert('Failed to logout. Please try again.');
                }
            } catch (error) {
                console.error('Error during logout:', error);
                alert('An error occurred during logout. Please try again.');
            }
        });

        cancelLogoutBtn.addEventListener('click', () => {
            logoutConfirmModal.classList.remove('show');
        });

        // Close modal if clicked outside content
        logoutConfirmModal.addEventListener('click', (event) => {
            if (event.target === logoutConfirmModal) {
                logoutConfirmModal.classList.remove('show');
            }
        });

        // Filter functions
        function applyFilters() {
            const searchTerm = document.getElementById('searchFilter').value.toLowerCase();
            const startDateFilter = document.getElementById('startDateFilter').value;
            const endDateFilter = document.getElementById('endDateFilter').value;
            const paymentFilter = document.getElementById('paymentFilter').value.toLowerCase();
            const amountFilter = document.getElementById('amountFilter').value;
            const deliveryTypeFilter = document.getElementById('deliveryTypeFilter').value;

            const orderCards = document.querySelectorAll('.order-card');
            let visibleCount = 0;

            orderCards.forEach(card => {
                const orderId = card.getAttribute('data-order-id');
                const customer = card.getAttribute('data-customer') || '';
                const email = card.getAttribute('data-email') || '';
                const payment = (card.getAttribute('data-payment') || '').toLowerCase();
                const amount = parseFloat(card.getAttribute('data-amount') || 0);
                const date = card.getAttribute('data-date') || '';
                const deliveryType = card.getAttribute('data-delivery-type') || '';

                let shouldShow = true;

                // Comprehensive search filter
                if (searchTerm) {
                    const referenceNumber = (card.getAttribute('data-reference-number') || '').toLowerCase();
                    const phone = (card.getAttribute('data-phone') || '');
                    const address = (card.getAttribute('data-address') || '');
                    const products = (card.getAttribute('data-products') || '');
                    const status = (card.getAttribute('data-status') || '');
                    const notes = (card.getAttribute('data-notes') || '');
                    const bulkOrder = (card.getAttribute('data-bulk-order') || '');
                    
                    shouldShow = shouldShow && (
                        orderId.includes(searchTerm) ||
                        referenceNumber.includes(searchTerm) ||
                        customer.includes(searchTerm) ||
                        email.includes(searchTerm) ||
                        phone.includes(searchTerm) ||
                        address.includes(searchTerm) ||
                        products.includes(searchTerm) ||
                        status.includes(searchTerm) ||
                        notes.includes(searchTerm) ||
                        (searchTerm === 'bulk' && bulkOrder === 'yes') ||
                        (searchTerm === 'bulk order' && bulkOrder === 'yes')
                    );
                }

                // Date range filter
                if (startDateFilter || endDateFilter) {
                    const orderDate = new Date(date);
                    if (startDateFilter) {
                        const startDate = new Date(startDateFilter);
                        startDate.setHours(0, 0, 0, 0);
                        if (orderDate < startDate) {
                            shouldShow = false;
                        }
                    }
                    if (endDateFilter) {
                        const endDate = new Date(endDateFilter);
                        endDate.setHours(23, 59, 59, 999);
                        if (orderDate > endDate) {
                            shouldShow = false;
                        }
                    }
                }

                // Payment filter (case-insensitive, supports e-wallet variations)
                if (paymentFilter) {
                    const paymentLower = payment;
                    const matchesEwallet = paymentFilter === 'e-wallet' && (
                        paymentLower.includes('e-wallet') ||
                        paymentLower.includes('ewallet') ||
                        paymentLower.includes('e wallet') ||
                        paymentLower === 'wallet'
                    );
                    const matchesOther = paymentFilter !== 'e-wallet' && paymentLower.includes(paymentFilter);
                    
                    if (!matchesEwallet && !matchesOther) {
                        shouldShow = false;
                    }
                }

                // Amount filter
                if (amountFilter) {
                    const [min, max] = amountFilter === '10000+' 
                        ? [10000, Infinity]
                        : amountFilter.split('-').map(v => v.replace(/[₱,]/g, ''));
                    if (amount < parseFloat(min) || (max !== 'Infinity' && amount > parseFloat(max))) {
                        shouldShow = false;
                    }
                }

                // Delivery type filter
                if (deliveryTypeFilter && deliveryType !== deliveryTypeFilter) {
                    shouldShow = false;
                }

                card.style.display = shouldShow ? 'flex' : 'none';
                if (shouldShow) visibleCount++;
            });

            // Filter table rows
            const tableRows = document.querySelectorAll('.table-order-row');
            let tableVisibleCount = 0;

            tableRows.forEach(row => {
                const orderId = row.getAttribute('data-order-id');
                const customer = row.getAttribute('data-customer');
                const email = row.getAttribute('data-email');
                const payment = (row.getAttribute('data-payment') || '').toLowerCase();
                const amount = parseFloat(row.getAttribute('data-amount'));
                const date = row.getAttribute('data-date');
                const deliveryType = row.getAttribute('data-delivery-type');

                let shouldShow = true;

                // Comprehensive search filter
                if (searchTerm) {
                    const referenceNumber = (row.getAttribute('data-reference-number') || '').toLowerCase();
                    const phone = (row.getAttribute('data-phone') || '');
                    const address = (row.getAttribute('data-address') || '');
                    const products = (row.getAttribute('data-products') || '');
                    const status = (row.getAttribute('data-status') || '');
                    const notes = (row.getAttribute('data-notes') || '');
                    const bulkOrder = (row.getAttribute('data-bulk-order') || '');
                    
                    shouldShow = shouldShow && (
                        orderId.includes(searchTerm) ||
                        referenceNumber.includes(searchTerm) ||
                        customer.includes(searchTerm) ||
                        email.includes(searchTerm) ||
                        phone.includes(searchTerm) ||
                        address.includes(searchTerm) ||
                        products.includes(searchTerm) ||
                        status.includes(searchTerm) ||
                        notes.includes(searchTerm) ||
                        (searchTerm === 'bulk' && bulkOrder === 'yes') ||
                        (searchTerm === 'bulk order' && bulkOrder === 'yes')
                    );
                }

                // Date range filter
                if (startDateFilter || endDateFilter) {
                    const orderDate = new Date(date);
                    if (startDateFilter) {
                        const startDate = new Date(startDateFilter);
                        startDate.setHours(0, 0, 0, 0);
                        if (orderDate < startDate) {
                            shouldShow = false;
                        }
                    }
                    if (endDateFilter) {
                        const endDate = new Date(endDateFilter);
                        endDate.setHours(23, 59, 59, 999);
                        if (orderDate > endDate) {
                            shouldShow = false;
                        }
                    }
                }

                // Payment filter (case-insensitive, supports e-wallet variations)
                if (paymentFilter) {
                    const paymentLower = payment;
                    const matchesEwallet = paymentFilter === 'e-wallet' && (
                        paymentLower.includes('e-wallet') ||
                        paymentLower.includes('ewallet') ||
                        paymentLower.includes('e wallet') ||
                        paymentLower === 'wallet'
                    );
                    const matchesOther = paymentFilter !== 'e-wallet' && paymentLower.includes(paymentFilter);
                    
                    if (!matchesEwallet && !matchesOther) {
                        shouldShow = false;
                    }
                }

                // Amount filter
                if (amountFilter) {
                    const [min, max] = amountFilter === '10000+' 
                        ? [10000, Infinity]
                        : amountFilter.split('-').map(v => v.replace(/[₱,]/g, ''));
                    if (amount < parseFloat(min) || (max !== 'Infinity' && amount > parseFloat(max))) {
                        shouldShow = false;
                    }
                }

                // Delivery type filter
                if (deliveryTypeFilter && deliveryType !== deliveryTypeFilter) {
                    shouldShow = false;
                }

                row.style.display = shouldShow ? '' : 'none';
                // Also hide the details row if the main row is hidden
                const detailsRow = document.getElementById(`table-details-${orderId}`);
                if (detailsRow) {
                    detailsRow.style.display = shouldShow ? detailsRow.style.display : 'none';
                }
                if (shouldShow) tableVisibleCount++;
            });

            // Update count based on current view
            const cardsView = document.getElementById('ordersGrid');
            const currentView = cardsView && cardsView.style.display !== 'none' ? 'cards' : 'table';
            if (currentView === 'cards') {
                document.getElementById('ordersCount').textContent = `${visibleCount} Orders`;
            } else {
                document.getElementById('ordersCount').textContent = `${tableVisibleCount} Orders`;
            }
            
            // Update bulk orders count
            const visibleBulkCount = Array.from(orderCards).filter(card => {
                return card.style.display !== 'none' && card.getAttribute('data-bulk-order') === 'yes';
            }).length;
            const bulkCountElement = document.getElementById('bulkOrdersCount');
            if (bulkCountElement) {
                bulkCountElement.textContent = `${visibleBulkCount} Bulk Orders`;
            }
        }

        function clearFilters() {
            document.getElementById('searchFilter').value = '';
            document.getElementById('startDateFilter').value = '';
            document.getElementById('endDateFilter').value = '';
            document.getElementById('paymentFilter').value = '';
            document.getElementById('amountFilter').value = '';
            document.getElementById('deliveryTypeFilter').value = '';
            
            const orderCards = document.querySelectorAll('.order-card');
            orderCards.forEach(card => card.style.display = 'flex');
            document.getElementById('ordersCount').textContent = '<%= orders ? orders.length : 0 %> Orders';
            
            // Reset bulk orders count
            const bulkCountElement = document.getElementById('bulkOrdersCount');
            if (bulkCountElement) {
                const allCards = document.querySelectorAll('.order-card');
                const bulkCount = Array.from(allCards).filter(card => card.getAttribute('data-bulk-order') === 'yes').length;
                bulkCountElement.textContent = `${bulkCount} Bulk Orders`;
            }
