        // Date validation: Set minimum date for end date based on start date
        document.getElementById('startDateFilter').addEventListener('change', function() {
            const startDate = this.value;
            const endDateInput = document.getElementById('endDateFilter');
            if (startDate) {
                endDateInput.setAttribute('min', startDate);
                // If end date is before start date, clear it
                if (endDateInput.value && endDateInput.value < startDate) {
                    endDateInput.value = '';
                    endDateInput.setCustomValidity('');
                }
            } else {
                endDateInput.removeAttribute('min');
            }
            applyFilters();
        });

        document.getElementById('endDateFilter').addEventListener('change', function() {
            const startDate = document.getElementById('startDateFilter').value;
            const endDate = this.value;
            if (startDate && endDate && endDate < startDate) {
                this.setCustomValidity('End date cannot be before start date');
                this.reportValidity();
                this.value = '';
            } else {
                this.setCustomValidity('');
                applyFilters();
            }
        });

