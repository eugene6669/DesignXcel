<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Content Management - Order Support</title>
    <link rel="stylesheet" href="/css/Employee/Admin/AdminIndexStyles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">

    <style>
        /* Modern CMS Design - Matching Frontend */
        :root {
            --primary-color: #F0B21B;
            --primary-hover: #d69e16;
            --primary-light: #fff9e6;
            --text-primary: #333333;
            --text-secondary: #666666;
            --bg-light: #f8f9fa;
            --bg-white: #ffffff;
            --border-color: #e5e7eb;
            --success-color: #10b981;
            --error-color: #F0B21B;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        /* Custom Confirmation Modal Styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            visibility: hidden;
            opacity: 0;
            transition: visibility 0s, opacity 0.3s ease;
        }

        .modal-overlay.show {
            visibility: visible;
            opacity: 1;
        }

        .modal-content {
            background-color: #fff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            text-align: center;
            max-width: 400px;
            width: 90%;
            transform: scale(0.9);
            transition: transform 0.3s ease;
        }

        .modal-overlay.show .modal-content {
            transform: scale(1);
        }

        .modal-content h3 {
            margin-top: 0;
            color: var(--text-primary);
            font-size: 1.5em;
            margin-bottom: 20px;
        }

        .modal-content p {
            color: var(--text-secondary);
            font-size: 1.1em;
            margin-bottom: 30px;
        }

        .modal-buttons {
            display: flex;
            justify-content: center;
            gap: 15px;
        }

        .modal-button {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .modal-button.confirm {
            background-color: var(--error-color);
            color: white;
        }

        .modal-button.confirm:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        .modal-button.cancel {
            background-color: var(--bg-light);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        .modal-button.cancel:hover {
            background-color: #e9ecef;
        }

        .sidebar {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }
        .sidebar-menu {
            flex-grow: 1;
        }
        .logout-section {
            padding: 40px;
            border-top: 1px solid var(--border-color);
            margin-top: auto;
            text-align: center;
        }
        .logout-button {
            display: inline-block;
            width: auto;
            padding: 12px 25px;
            background-color: var(--error-color);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-sm);
        }
        .logout-button:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        /* Modern CMS Tab Styles */
        .cms-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 24px;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 8px;
        }

        .cms-tab-btn {
            padding: 12px 20px;
            cursor: pointer;
            border: none;
            background: transparent;
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 14px;
            border-radius: 8px 8px 0 0;
            transition: all 0.3s ease;
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cms-tab-btn:hover {
            background: var(--bg-light);
            color: var(--text-primary);
        }

        .cms-tab-btn.active {
            background: var(--bg-white);
            color: var(--primary-color);
            font-weight: 600;
        }

        .cms-tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--primary-color);
            border-radius: 2px 2px 0 0;
        }

        .cms-tab-content {
            background: var(--bg-white);
            border-radius: 12px;
            padding: 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-color);
        }

        .cms-tab-content h3 {
            color: var(--text-primary);
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Modern Section Styles */
        .cms-section-modern {
            background: var(--bg-white);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
        }

        .cms-section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 2px solid var(--bg-light);
        }

        .cms-section-header svg {
            width: 24px;
            height: 24px;
            color: var(--primary-color);
            flex-shrink: 0;
        }

        .cms-section-header h4 {
            margin: 0;
            color: var(--text-primary);
            font-size: 18px;
            font-weight: 600;
        }

        .cms-section-description {
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 24px;
        }

        /* Form Group Styles */
        .cms-form-group {
            background: var(--bg-light);
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid var(--primary-color);
        }

        .cms-form-group h5 {
            margin: 0 0 16px 0;
            color: var(--text-primary);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cms-form-group h5 svg {
            width: 18px;
            height: 18px;
            color: var(--primary-color);
        }

        .cms-form-field {
            margin-bottom: 16px;
        }

        .cms-form-field label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-primary);
            font-weight: 500;
            font-size: 14px;
        }

        .cms-form-field input[type="text"],
        .cms-form-field input[type="email"],
        .cms-form-field input[type="tel"],
        .cms-form-field input[type="url"],
        .cms-form-field textarea,
        .cms-form-field select {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
            background: var(--bg-white);
            color: var(--text-primary);
        }

        .cms-form-field input:focus,
        .cms-form-field textarea:focus,
        .cms-form-field select:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(240, 178, 27, 0.1);
        }

        .cms-form-field input[type="color"] {
            width: 100%;
            height: 48px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            cursor: pointer;
        }

        .cms-form-field small {
            display: block;
            margin-top: 6px;
            color: var(--text-secondary);
            font-size: 12px;
        }

        /* Button Styles */
        .cms-btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .cms-btn-primary {
            background: var(--primary-color);
            color: white;
            box-shadow: var(--shadow-sm);
        }

        .cms-btn-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        .cms-btn-danger {
            background: #ef4444;
            color: white;
        }

        .cms-btn-danger:hover {
            background: #dc2626;
            transform: translateY(-1px);
        }

        /* Live Preview Styles */
        .cms-preview-container {
            margin-top: 32px;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid var(--border-color);
            box-shadow: var(--shadow-md);
        }

        .cms-preview-header {
            background: var(--bg-light);
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cms-preview-header svg {
            width: 20px;
            height: 20px;
            color: var(--primary-color);
        }

        .cms-preview-header h5 {
            margin: 0;
            color: var(--text-primary);
            font-size: 16px;
            font-weight: 600;
        }

        /* Hero Preview Matching React Component */
        .hero-preview {
            min-height: 400px;
            height: 70vh;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

        .hero-preview-bg-slider {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        .hero-preview-bg-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            opacity: 0;
            transition: opacity 1s ease-in-out;
        }

        .hero-preview-bg-slide.active {
            opacity: 1;
        }

        .hero-preview-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.2) 50%, rgba(0, 0, 0, 0.3) 100%);
            z-index: 2;
        }

        .hero-preview-content {
            position: relative;
            z-index: 3;
            padding: 60px 20px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 400px;
            height: 100%;
        }

        .hero-preview-container {
            max-width: 1200px;
            width: 100%;
        }

        .hero-preview-title {
            font-size: 3rem;
            font-weight: 700;
            line-height: 1.2;
            color: white;
            margin: 0 0 24px 0;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
        }

        .hero-preview-subtitle {
            font-size: 1.25rem;
            line-height: 1.6;
            color: white;
            margin: 0 0 32px 0;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            opacity: 0.95;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.6);
        }

        .hero-preview-actions {
            display: flex;
            align-items: center;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .hero-preview-btn {
            padding: 12px 24px;
            border-radius: 6px;
            font-weight: 500;
            font-size: 15px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(240, 178, 27, 0.2);
            border: none;
            cursor: pointer;
            min-width: 120px;
            justify-content: center;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .hero-preview-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(240, 178, 27, 0.3);
        }

        .hero-preview-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--primary-color);
            border: 2px solid var(--primary-color);
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            z-index: 4;
            box-shadow: 0 4px 12px rgba(240, 178, 27, 0.3);
        }

        .hero-preview-arrow:hover {
            background: var(--primary-hover);
            border-color: var(--primary-hover);
            transform: translateY(-50%) scale(1.1);
        }

        .hero-preview-arrow-left {
            left: 30px;
        }

        .hero-preview-arrow-right {
            right: 30px;
        }

        .hero-preview-indicators {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            justify-content: center;
            gap: 8px;
            z-index: 4;
        }

        .hero-preview-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            border: none;
            background: rgba(255, 255, 255, 0.4);
            cursor: pointer;
            transition: all 0.3s ease;
            padding: 0;
        }

        .hero-preview-indicator:hover {
            background: rgba(255, 255, 255, 0.7);
            transform: scale(1.2);
        }

        .hero-preview-indicator.active {
            background: var(--primary-color);
            transform: scale(1.3);
        }

        /* Icon Styles */
        .cms-icon {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .cms-tabs {
                overflow-x: auto;
            }
            .hero-preview-title {
                font-size: 2rem;
            }
            .hero-preview-subtitle {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <div class="sidebar">
            <%- include('partials/sidebar', { activePage: 'cms' }) %>
        </div>
        <div class="main-content">
            <div class="header">
                <h2>Content Management</h2>
            </div>
            <div class="content-area">
                <!-- Tab Navigation -->
                <div class="cms-tabs">
                    <button class="cms-tab-btn" onclick="showTab('banner')" id="tab-banner">Header Banner</button>
                    <button class="cms-tab-btn" onclick="showTab('hero-banner')" id="tab-hero-banner">Hero Banner</button>
                    <button class="cms-tab-btn" onclick="showTab('products')" id="tab-products">Products</button>
                    <button class="cms-tab-btn" onclick="showTab('testimonials')" id="tab-testimonials">Testimonials</button>
                    <button class="cms-tab-btn" onclick="showTab('offer')" id="tab-offer">Offer</button>
                    <button class="cms-tab-btn" onclick="showTab('projects')" id="tab-projects">Projects</button>
                    <button class="cms-tab-btn" onclick="showTab('about')" id="tab-about">About Us</button>
                    <button class="cms-tab-btn" onclick="showTab('auto-messages')" id="tab-auto-messages">Auto. Messages</button>
                    <button class="cms-tab-btn" onclick="showTab('terms')" id="tab-terms">Terms & Conditions</button>
                    <button class="cms-tab-btn" onclick="showTab('theme')" id="tab-theme">Theme</button>
                    <button class="cms-tab-btn" onclick="showTab('messages')" id="tab-messages">Messages</button>
                </div>
                <!-- Tab Content -->
                <div class="cms-tab-content" id="tab-content-hero-banner">
                    <h3>
                        <svg class="cms-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="3" y1="9" x2="21" y2="9"></line>
                            <line x1="9" y1="21" x2="9" y2="9"></line>
                        </svg>
                        Hero Banner Management
                    </h3>
                    <div class="cms-section-content">
                        <div class="cms-section-modern">
                            <div class="cms-section-header">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                                    <path d="M2 17l10 5 10-5"></path>
                                    <path d="M2 12l10 5 10-5"></path>
                                </svg>
                                <h4>Hero Banner Content & Image</h4>
                            </div>
                            <p class="cms-section-description">Customize the main hero banner that appears at the top of your homepage. This matches the React frontend Hero component design.</p>
                            
                            <form id="hero-banner-form" enctype="multipart/form-data" style="margin-bottom: 2em;">
                                <!-- Hero Banner Image -->
                                <div class="cms-form-group">
                                    <h5>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                            <polyline points="21 15 16 10 5 21"></polyline>
                                        </svg>
                                        Hero Banner Image
                                    </h5>
                                    <div class="cms-form-field">
                                        <label for="hero-banner-images">Upload Images (1-3 images):</label>
                                        <input type="file" id="hero-banner-images" name="heroBannerImages" accept="image/*" multiple style="width: 100%; padding: 12px 16px; border: 1px solid var(--border-color); border-radius: 8px; font-size: 14px; background: var(--bg-white);">
                                        <small>Recommended size: 1920x600 or larger. Upload 1-3 images for a rotating hero banner. Will be displayed as the background of your hero section.</small>
                                    </div>
                                    <div id="current-hero-images" class="cms-form-field">
                                        <label>Current Hero Images:</label>
                                        <div id="hero-images-preview" style="border: 1px solid var(--border-color); padding: 16px; border-radius: 8px; min-height: 100px; display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 12px; background: var(--bg-white);">
                                            <span id="no-hero-images-text" style="color: var(--text-secondary);">No hero images set</span>
                                            <div id="hero-images-container" style="display: none; width: 100%;">
                                                <!-- Images will be dynamically added here -->
                                            </div>
                                        </div>
                                        <button id="remove-hero-images-btn" onclick="removeHeroBannerImages()" class="cms-btn cms-btn-danger" style="margin-top: 12px; display: none;">
                                            <svg class="cms-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            </svg>
                                            Remove All Hero Images
                                        </button>
                                    </div>
                                </div>
                                
                                <!-- Hero Banner Content -->
                                <div class="cms-form-group">
                                    <h5>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                            <polyline points="14 2 14 8 20 8"></polyline>
                                            <line x1="16" y1="13" x2="8" y2="13"></line>
                                            <line x1="16" y1="17" x2="8" y2="17"></line>
                                            <polyline points="10 9 9 9 8 9"></polyline>
                                        </svg>
                                        Hero Banner Content
                                    </h5>
                                    <div class="cms-form-field">
                                        <label for="hero-main-heading">Main Heading:</label>
                                        <input type="text" id="hero-main-heading" name="mainHeading" placeholder="Premium Office Furniture Solutions" required>
                                    </div>
                                    <div class="cms-form-field">
                                        <label for="hero-description-line1">Description Line 1:</label>
                                        <input type="text" id="hero-description-1" name="descriptionLine1" placeholder="Transform your workspace with our premium collection of office furniture">
                                    </div>
                                    <div class="cms-form-field">
                                        <label for="hero-description-line2">Description Line 2:</label>
                                        <input type="text" id="hero-description-2" name="descriptionLine2" placeholder="Discover our premium collection of office furniture designed for modern professionals">
                                    </div>
                                    <div class="cms-form-field">
                                        <label for="hero-button-text">Button Text:</label>
                                        <input type="text" id="hero-button-text" name="buttonText" placeholder="SHOP NOW" required>
                                    </div>
                                    <div class="cms-form-field">
                                        <label for="hero-button-link">Button Link:</label>
                                        <input type="text" id="hero-button-link" name="buttonLink" placeholder="/products" required>
                                    </div>
                                    <div class="cms-form-field">
                                        <label for="hero-button2-text">Second Button Text:</label>
                                        <input type="text" id="hero-button2-text" name="button2Text" placeholder="Custom Design">
                                    </div>
                                    <div class="cms-form-field">
                                        <label for="hero-button2-link">Second Button Link:</label>
                                        <input type="text" id="hero-button2-link" name="button2Link" placeholder="/custom-furniture">
                                    </div>
                                </div>
                                
                                <!-- Hero Banner Colors -->
                                <div class="cms-form-group">
                                    <h5>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="13.5" cy="6.5" r=".5"></circle>
                                            <circle cx="17.5" cy="10.5" r=".5"></circle>
                                            <circle cx="8.5" cy="7.5" r=".5"></circle>
                                            <circle cx="6.5" cy="12.5" r=".5"></circle>
                                            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>
                                        </svg>
                                        Hero Banner Colors
                                    </h5>
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                                        <div class="cms-form-field">
                                            <label for="hero-text-color">Text Color:</label>
                                            <input type="color" id="hero-text-color" name="textColor" value="#ffffff">
                                        </div>
                                        <div class="cms-form-field">
                                            <label for="hero-button-bg-color">Button Background Color:</label>
