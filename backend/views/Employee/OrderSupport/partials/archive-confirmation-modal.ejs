<!-- Archive confirmation — use with showArchiveConfirmModal() in product-inventory.js -->
<div id="archiveConfirmModal" class="inventory-confirmation-modal archive-confirm-modal" aria-hidden="true">
    <div class="inventory-confirmation-content archive-confirm-content" role="dialog" aria-labelledby="archiveConfirmTitle">
        <div class="archive-confirm-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
            </svg>
        </div>
        <h3 id="archiveConfirmTitle">Archive item?</h3>
        <p id="archiveConfirmMessage" class="archive-confirm-message"></p>
        <p class="archive-confirm-hint">The item will move to <strong>Archived items</strong>. You can restore it from there later.</p>
        <div class="inventory-confirmation-buttons">
            <button type="button" class="inventory-cancel-btn" id="cancelArchiveConfirm">Cancel</button>
            <button type="button" class="inventory-confirm-btn archive-confirm-btn-danger" id="confirmArchiveConfirm">Archive</button>
        </div>
    </div>
</div>
