                                    if (inventoryTabButton) inventoryTabButton.classList.remove('active');
                                    if (inventoryTabContent) inventoryTabContent.classList.remove('active');
                                    
                                    // Add active to variations tab
                                    variationsTabButton.classList.add('active');
                                    variationsTabContent.classList.add('active');
                                    
                                    // Update button visibility
                                    if (addInventoryItemBtn) addInventoryItemBtn.style.display = 'none';
                                    if (addVariationBtn) addVariationBtn.style.display = 'inline-block';
