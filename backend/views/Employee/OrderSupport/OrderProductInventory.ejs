    </script>
    <% } %>
    <% if (locals.success && locals.success.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= success %>');
        });
    </script>
    <% } %>
</body>
</html>


