        // Function to edit inventory product quantity
        async function editInventoryProduct(productId, isFromProductsTable) {
            try {
                // All products on this page are from InventoryProducts table
                // Fetch current inventory data directly from InventoryProducts
                const response = await fetch(`/api/admin/inventory-quantity/${productId}?source=InventoryProducts`);
                const data = await response.json();

                if (!data.success) {
                    showCustomPopup('Failed to load inventory data: ' + (data.message || 'Unknown error'), true);
                    return;
                }

                const inventory = data.inventory;

                // Populate modal fields
                // All products on this page are from InventoryProducts table
                document.getElementById('editProductId').value = productId;
                document.getElementById('editIsFromProductsTable').value = 'false'; // Always false for InventoryProducts
                document.getElementById('editProductName').value = inventory.productName || 'N/A';
                document.getElementById('editCurrentTotalQuantity').value = inventory.totalQuantity || 0;
                
                // Set current quantities (for display and hidden inputs)
                const currentAvailable = inventory.availableQuantity || 0;
                const currentDamaged = inventory.damagedQuantity || 0;
                const currentRepaired = inventory.repairedQuantity || 0;
                const currentDisposed = inventory.disposedQuantity || 0;
                
                document.getElementById('currentAvailableQty').textContent = currentAvailable;
                document.getElementById('currentDamagedQty').textContent = currentDamaged;
                document.getElementById('currentRepairedQty').textContent = currentRepaired;
                document.getElementById('currentDisposedQty').textContent = currentDisposed;
                
                // Set hidden input values to current quantities
                document.getElementById('editAvailableQuantity').value = currentAvailable;
                document.getElementById('editDamagedQuantity').value = currentDamaged;
                document.getElementById('editRepairedQuantity').value = currentRepaired;
                document.getElementById('editDisposedQuantity').value = currentDisposed;
                
                // Show current product image if exists
                const productImagePreview = document.getElementById('editProductImagePreview');
                if (productImagePreview && inventory.productImageURL) {
                    productImagePreview.innerHTML = `<p style="margin: 5px 0; font-weight: bold;">Current Image:</p><img src="${inventory.productImageURL}" alt="Current product image" style="max-width: 200px; max-height: 200px; border-radius: 4px; border: 1px solid #ddd; margin-top: 5px;">`;
                } else if (productImagePreview) {
                    productImagePreview.innerHTML = '';
                }
                
                // Reset status dropdown and quantity input
                document.getElementById('editStatusSelect').value = '';
                document.getElementById('editQuantityInput').value = '0';
                document.getElementById('quantityInputContainer').style.display = 'none';
                
                // Removed Notes field for compact modal
                
                // Store initial total for reference (before any changes)
                const initialTotal = inventory.totalQuantity || 0;
                const totalQuantityInput = document.getElementById('editCurrentTotalQuantity');
                if (totalQuantityInput) {
                    totalQuantityInput.setAttribute('data-initial-total', initialTotal);
                }
                
                // Update total display
                updateTotalQuantity();
                
                // Add event listener for total quantity field to add to available stock
                // This allows users to directly edit total quantity, which adds to Available
                if (totalQuantityInput) {
                    // Store initial total for reference
                    totalQuantityInput.setAttribute('data-initial-total', initialTotal);
                    
                    // Check if listener is already attached
                    if (!totalQuantityInput.hasAttribute('data-listener-attached')) {
                        // Add change event listener
                        totalQuantityInput.addEventListener('change', function() {
                            console.log('Total quantity field changed in inventory modal');
                            const newTotal = parseInt(this.value) || 0;
                            const initialTotalValue = parseInt(this.getAttribute('data-initial-total')) || 0;
                            const totalDifference = newTotal - initialTotalValue;
                            
                            console.log('Total quantity change:', {
                                newTotal: newTotal,
                                initialTotal: initialTotalValue,
                                difference: totalDifference
                            });
                            
                            if (totalDifference !== 0) {
                                // Get current available and damaged from display
                                const currentAvailable = parseInt(document.getElementById('currentAvailableQty').textContent) || 0;
                                const currentDamaged = parseInt(document.getElementById('currentDamagedQty').textContent) || 0;
                                const currentTotalCalculated = currentAvailable + currentDamaged;
                                
                                // Validate: new total must be at least equal to damaged (available can't be negative)
                                if (newTotal < currentDamaged) {
                                    showCustomPopup(`Cannot set total quantity below current damaged quantity (${currentDamaged}). Available cannot be negative.`, true);
                                    this.value = currentTotalCalculated;
                                    return;
                                }
                                
                                // The difference should be added to Available (new stock received or removed)
                                // Total = Available + Damaged
                                // If Total increases by X, Available increases by X (Damaged stays same)
                                // If Total decreases by X, Available decreases by X (Damaged stays same)
                                const newAvailable = currentAvailable + totalDifference;
                                
                                // Ensure available doesn't go negative
                                if (newAvailable < 0) {
                                    // If new total is less than damaged, adjust available to 0 and reduce damaged if possible
                                    if (newTotal < currentDamaged) {
                                        showCustomPopup(`Cannot set total quantity (${newTotal}) below current damaged quantity (${currentDamaged}).`, true);
                                        this.value = currentTotalCalculated;
                                        return;
                                    }
                                    // Otherwise, set available to 0 (total equals damaged)
                                    newAvailable = 0;
                                }
                                
                                // Validate: Available + Damaged cannot exceed Total
                                // If calculated total exceeds new total, adjust available to fit
                                const calculatedTotal = newAvailable + currentDamaged;
                                let adjustedAvailable = newAvailable;
                                if (calculatedTotal > newTotal) {
                                    adjustedAvailable = newTotal - currentDamaged;
                                    if (adjustedAvailable < 0) {
                                        showCustomPopup(`Cannot set total quantity (${newTotal}) below current damaged quantity (${currentDamaged}).`, true);
                                        this.value = currentTotalCalculated;
                                        return;
                                    }
                                    console.log('Adjusted available in change event:', {
                                        originalAvailable: newAvailable,
                                        adjustedAvailable: adjustedAvailable,
                                        damaged: currentDamaged,
                                        newTotal: newTotal
                                    });
                                }
                                
                                // Update available quantity in hidden input and display
                                document.getElementById('editAvailableQuantity').value = adjustedAvailable;
                                document.getElementById('currentAvailableQty').textContent = adjustedAvailable;
                                
                                console.log('Updated available quantity:', {
                                    oldAvailable: currentAvailable,
                                    newAvailable: newAvailable,
                                    damaged: currentDamaged,
                                    newTotal: newTotal
                                });
                                
                                // Update the total display
                                updateTotalQuantity();
                                
                                // Show message
                                if (totalDifference > 0) {
                                    showCustomPopup(`Adding ${totalDifference} item(s) to Available stock. Total quantity: ${initialTotalValue} → ${newTotal}`);
                                } else {
                                    showCustomPopup(`Removing ${Math.abs(totalDifference)} item(s) from Available stock. Total quantity: ${initialTotalValue} → ${newTotal}`);
                                }
                            }
                        });
                        totalQuantityInput.setAttribute('data-listener-attached', 'true');
                        console.log('Total quantity field event listener attached for inventory modal');
                    } else {
                        console.log('Total quantity field listener already attached for inventory modal');
                    }
                }

                // Show modal
                document.getElementById('editInventoryModal').style.display = 'block';
            } catch (error) {
                console.error('Error loading inventory data:', error);
                showCustomPopup('Failed to load inventory data', true);
            }
        }

        // Function to show quantity input when status is selected
        function showQuantityForStatus() {
            const statusSelect = document.getElementById('editStatusSelect');
            const quantityContainer = document.getElementById('quantityInputContainer');
            const quantityInput = document.getElementById('editQuantityInput');
            // Maximum quantity constant for office furniture inventory
            const MAX_QUANTITY = 999999;
            
            if (statusSelect.value) {
                quantityContainer.style.display = 'block';
                
                // Get current quantity for selected status
                let currentQty = 0;
                
                switch(statusSelect.value) {
                    case 'available':
                        currentQty = parseInt(document.getElementById('currentAvailableQty').textContent) || 0;
                        quantityInput.value = currentQty;
                        quantityInput.min = 0;
                        quantityInput.max = MAX_QUANTITY;
                        break;
                    case 'damaged':
                        currentQty = parseInt(document.getElementById('currentDamagedQty').textContent) || 0;
                        const availableQty = parseInt(document.getElementById('currentAvailableQty').textContent) || 0;
                        quantityInput.value = 0; // Start at 0 - user enters how many to mark as damaged
                        quantityInput.min = 0;
                        quantityInput.max = availableQty; // Can mark up to all available items as damaged
                        break;
                    case 'repaired':
                        currentQty = parseInt(document.getElementById('currentRepairedQty').textContent) || 0;
                        const damagedQty = parseInt(document.getElementById('currentDamagedQty').textContent) || 0;
                        if (damagedQty === 0) {
                            quantityInput.max = 0; // Can't repair if no damaged items
                            quantityInput.min = 0;
                            quantityInput.value = 0; // Show 0 - no items to repair
                        } else {
                            quantityInput.max = damagedQty; // Can repair up to all damaged items
                            quantityInput.min = 0;
                            quantityInput.value = 0; // Start at 0 - user enters how many to repair
                        }
                        break;
                    case 'disposed':
                        currentQty = parseInt(document.getElementById('currentDisposedQty').textContent) || 0;
                        const availForDisposal = (parseInt(document.getElementById('currentAvailableQty').textContent) || 0) + 
                                                (parseInt(document.getElementById('currentDamagedQty').textContent) || 0);
                        quantityInput.value = 0; // Start at 0 - user enters how many to dispose
                        quantityInput.min = 0;
                        quantityInput.max = Math.min(MAX_QUANTITY, availForDisposal);
                        break;
                }
                
                // Update hidden inputs and total when quantity changes
                updateQuantityForStatus();
            } else {
                quantityContainer.style.display = 'none';
            }
        }

        // Function to update hidden input for selected status and adjust other statuses
        // Enhanced with e-commerce best practices validation for office furniture inventory
        function updateQuantityForStatus() {
            const statusSelect = document.getElementById('editStatusSelect');
            const quantityInput = document.getElementById('editQuantityInput');
            let newQuantity = parseInt(quantityInput.value) || 0;
            
            // Validation: Quantity cannot be negative
            if (newQuantity < 0) {
                showCustomPopup('Quantity cannot be negative. Please enter a valid number.', true);
                newQuantity = 0;
                quantityInput.value = 0;
                updateTotalQuantity(); // Update display
                return;
            }
            
            // Get current quantities
            const currentAvailable = parseInt(document.getElementById('currentAvailableQty').textContent) || 0;
            const currentDamaged = parseInt(document.getElementById('currentDamagedQty').textContent) || 0;
            const currentRepaired = parseInt(document.getElementById('currentRepairedQty').textContent) || 0;
            const currentDisposed = parseInt(document.getElementById('currentDisposedQty').textContent) || 0;
            
            // Calculate the change in quantity for the selected status
            let quantityChange = 0;
            switch(statusSelect.value) {
                case 'available':
                    quantityChange = newQuantity - currentAvailable;
                    break;
                case 'damaged':
                    // For damaged, input represents "how many to mark as damaged" (additive)
                    // So quantityChange is just the amount entered (how many to add)
                    quantityChange = newQuantity; // This is how many items to mark as damaged
                    break;
                case 'repaired':
                    // For repaired, input represents "how many to repair" (additive)
                    // So quantityChange is just the amount entered (how many to add)
                    quantityChange = newQuantity; // This is how many items to repair
                    break;
                case 'disposed':
                    quantityChange = newQuantity; // This is how many items to dispose (additive)
                    break;
            }
            
            // Initialize all quantities with current values
            let newAvailable = currentAvailable;
            let newDamaged = currentDamaged;
            let newRepaired = currentRepaired;
            let newDisposed = currentDisposed;
            
            // E-commerce Inventory Logic for Office Furniture:
            // - Available: Sellable items (counts in total)
            // - Damaged: Broken items (reduces total, comes from available)
            // - Repaired: Fixed damaged items (increases available, comes from damaged)
            // - Disposed: Thrown away (reduces total, comes from available)
            
            // Validation: Maximum quantity check for office furniture (prevent unrealistic values)
            const MAX_QUANTITY = 999999; // Maximum reasonable quantity for office furniture inventory
            if (newQuantity > MAX_QUANTITY) {
                showCustomPopup(`Quantity exceeds maximum allowed (${MAX_QUANTITY.toLocaleString()}). Please enter a valid quantity.`, true);
                newQuantity = MAX_QUANTITY;
                quantityInput.value = MAX_QUANTITY;
                // Recalculate quantityChange
                switch(statusSelect.value) {
                    case 'available': quantityChange = newQuantity - currentAvailable; break;
                    case 'damaged': quantityChange = newQuantity; break; // Additive
                    case 'repaired': quantityChange = newQuantity; break; // Additive
                    case 'disposed': quantityChange = newQuantity; break; // Additive
                }
            }
            
            // Validation: Quantity must be a valid integer
            if (isNaN(newQuantity) || !Number.isInteger(parseFloat(quantityInput.value))) {
                showCustomPopup('Please enter a valid whole number for quantity.', true);
                // Restore previous value
                switch(statusSelect.value) {
                    case 'available': quantityInput.value = currentAvailable; break;
                    case 'damaged': quantityInput.value = 0; break; // Additive - start at 0
                    case 'repaired': quantityInput.value = 0; break; // Additive - start at 0
                    case 'disposed': quantityInput.value = 0; break; // Additive - start at 0
                }
                updateTotalQuantity(); // Update display
                return;
            }
            
            // Update the selected status quantity
            switch(statusSelect.value) {
                case 'available':
                    newAvailable = newQuantity;
                    // If increasing available: restore from damaged/returned/disposed/repaired
                    if (quantityChange > 0) {
                        let remaining = quantityChange;
                        // Damaged items must be repaired first before becoming available
                        // Skip damaged - they need to go through repaired status first
                        // Disposed items cannot be restored (already thrown away)
                        // Skip disposed - cannot be restored
                        // Repaired items automatically become available
                        if (remaining > 0 && newRepaired > 0) {
                            const restore = Math.min(remaining, newRepaired);
                            newRepaired -= restore;
                            remaining -= restore;
                        }
                        // If still remaining, this is a new stock addition (valid for office furniture receiving)
                        // Remaining quantity is treated as new inventory addition
                    } else if (quantityChange < 0) {
                        // If decreasing available: items must go to a valid status
                        // Validation: Cannot decrease available below 0
                        const decreaseAmount = Math.abs(quantityChange);
                        if (decreaseAmount > currentAvailable) {
                            showCustomPopup(`Cannot decrease available quantity below 0. Current available: ${currentAvailable}`, true);
                            newAvailable = currentAvailable;
                            quantityInput.value = currentAvailable;
                            // Recalculate
                            quantityChange = 0;
                        } else {
                            // Default: items go to damaged (inventory loss or damage)
                            newDamaged += decreaseAmount;
                        }
                    }
                    break;
                case 'damaged':
                    // Office Furniture Inventory Logic for Damaged Items:
                    // The input represents "how many available items to mark as damaged" (additive)
                    // Scenario: Available=10, Damaged=1, user enters 1 (meaning mark 1 more as damaged)
                    // Result: Available=10-1=9, Damaged=1+1=2
                    // Total stays constant: 9 + 2 = 11 (same as 10 + 1 = 11)
                    // - User enters how many to mark as damaged, this is ADDED to current damaged quantity
                    // - Available decreases by the amount entered
                    // - Total = Available + Damaged stays constant
                    
                    // Transfer from available to damaged - ensure exact transfer to keep total constant
                    // IMPORTANT: newQuantity is the amount to ADD to damaged (additive)
                    // Calculate how many items we can actually transfer (limited by available)
                    let itemsToTransfer = Math.min(newQuantity, currentAvailable);
                    
                    // Validation: Cannot mark more than available items as damaged
                    if (newQuantity > currentAvailable) {
                        showCustomPopup(`Cannot mark more items as damaged than available. Only ${currentAvailable} available item(s) can be marked as damaged. Using ${itemsToTransfer} instead.`, true);
                        // Update input to show the actual amount being transferred
                        quantityInput.value = itemsToTransfer;
                        // Update newQuantity to match what we can actually transfer
                        newQuantity = itemsToTransfer;
                        itemsToTransfer = newQuantity; // Recalculate with updated value
                    }
                    
                    // Perform the transfer - this ensures total stays constant
                    // CRITICAL: Add itemsToTransfer to currentDamaged (additive behavior)
                    if (itemsToTransfer > 0) {
                        // Ensure we're working with integers
                        const intCurrentAvailable = parseInt(currentAvailable) || 0;
                        const intCurrentDamaged = parseInt(currentDamaged) || 0;
                        const intItemsToTransfer = parseInt(itemsToTransfer) || 0;
                        
                        // Explicit transfer: available decreases by X, damaged increases by X
                        // This ensures: (Available - X) + (Damaged + X) = Available + Damaged (constant)
                        // Example: Available=10, Damaged=1, user enters 1 → Available=10-1=9, Damaged=1+1=2
                        // Total before: 10 + 1 = 11
                        // Total after: 9 + 2 = 11 (stays constant ✓)
                        newAvailable = intCurrentAvailable - intItemsToTransfer;
                        // ADDITIVE: Add itemsToTransfer to current damaged quantity
                        newDamaged = intCurrentDamaged + intItemsToTransfer;
                        
                        // Verify the math is correct
                        const transferBeforeTotal = intCurrentAvailable + intCurrentDamaged;
                        const transferAfterTotal = newAvailable + newDamaged;
                        if (Math.abs(transferBeforeTotal - transferAfterTotal) > 0.001) {
                            console.error('Math error in damaged transfer!', {
                                transferBeforeTotal,
                                transferAfterTotal,
                                intCurrentAvailable,
                                intCurrentDamaged,
                                intItemsToTransfer,
                                newAvailable,
                                newDamaged
                            });
                            // Force correct calculation
                            newAvailable = intCurrentAvailable - intItemsToTransfer;
                            newDamaged = intCurrentDamaged + intItemsToTransfer;
                        }
                        
                        console.log('Damaged transfer calculation:', {
                            currentDamaged,
                            itemsToTransfer,
                            newDamaged,
                            expected: currentDamaged + itemsToTransfer
                        });
                        
                        // Ensure available doesn't go negative (safety check)
                        if (newAvailable < 0) {
                            newAvailable = 0;
                        }
                        if (newDamaged < 0) {
                            newDamaged = 0;
                        }
                        
                        // Verify total stays constant (already verified above, but double-check)
                        const verifyBeforeTotal = currentAvailable + currentDamaged;
                        const verifyAfterTotal = newAvailable + newDamaged;
                        if (Math.abs(verifyBeforeTotal - verifyAfterTotal) > 0.001) {
                            console.error('Total mismatch detected in damaged case! Correcting...', { 
                                verifyBeforeTotal, 
                                verifyAfterTotal, 
                                itemsToTransfer,
                                currentAvailable, 
                                currentDamaged, 
                                newAvailable, 
                                newDamaged 
                            });
                            // Force correction: adjust available to maintain total
                            const correction = verifyBeforeTotal - verifyAfterTotal;
                            newAvailable = newAvailable + correction;
                        }
                    } else {
                        // No items available to mark as damaged (itemsToTransfer is 0)
                        // Keep damaged at current value (no change)
                        newDamaged = currentDamaged;
                        if (currentAvailable === 0) {
                            showCustomPopup('No available items to mark as damaged.', true);
                        } else if (newQuantity > 0) {
                            // User entered a value but we can't transfer (shouldn't happen due to validation)
                            showCustomPopup(`Cannot mark items as damaged. Only ${currentAvailable} available item(s).`, true);
                        }
                    }
                    
                    // Validate: Ensure newDamaged is correctly calculated (additive)
                    // If itemsToTransfer > 0, newDamaged should be currentDamaged + itemsToTransfer
                    if (itemsToTransfer > 0) {
                        const expectedDamaged = currentDamaged + itemsToTransfer;
                        if (newDamaged !== expectedDamaged) {
                            console.warn('Correcting damaged calculation:', {
                                currentDamaged,
                                itemsToTransfer,
                                expected: expectedDamaged,
                                actual: newDamaged
                            });
                            newDamaged = expectedDamaged;
                        }
                    }
                    
                    if (newQuantity < 0) {
                        // If user enters negative (shouldn't happen with min=0, but handle it)
                        showCustomPopup('Cannot mark negative quantity as damaged. Please enter 0 or a positive number.', true);
                        quantityInput.value = 0;
                        newQuantity = 0;
                        newDamaged = currentDamaged;
                    }
                    break;
                case 'repaired':
                    // Office Furniture Inventory Logic for Repaired Items:
                    // The input represents "how many damaged items to repair" (additive)
                    // Scenario: Damaged=1, Repaired=1, user enters 1 (meaning repair 1 more item)
                    // Result: Repaired=1+1=2, Damaged=1-1=0
                    // - User enters how many to repair, this is ADDED to current repaired quantity
                    // - Damaged decreases by the amount entered
                    // - quantityChange = newQuantity (the amount to repair)
                    
                    const itemsToRepair = quantityChange; // This is how many the user wants to repair
                    
                    // Validation: Cannot repair more than available damaged items
                    if (itemsToRepair > currentDamaged) {
                        showCustomPopup(`Cannot repair more items than available. Only ${currentDamaged} damaged item(s) available to repair.`, true);
                        // Set to maximum possible
                        const maxToRepair = currentDamaged;
                        quantityInput.value = maxToRepair;
                        quantityChange = maxToRepair;
                    }
                    
                    // Calculate new repaired quantity: current + items to repair
                    newRepaired = currentRepaired + quantityChange;
                    
                    // Transfer from damaged to repaired
                    // Total = Available + Repaired + Damaged must stay constant
                    // When repairing: Damaged decreases, Repaired increases, Available stays same
                    if (quantityChange > 0) {
                        // Take from damaged items
                        const fromDamaged = Math.min(quantityChange, currentDamaged);
                        
                        if (fromDamaged > 0) {
                            // Explicit transfer: damaged decreases, repaired increases, available increases
                            // Example: Available=10, Repaired=1, Damaged=1, user enters 1 → Available=10+1=11, Repaired=1+1=2, Damaged=1-1=0
                            // Total before: 10 + 1 + 1 = 12
                            // Total after: 11 + 2 + 0 = 13 (needs adjustment to stay constant)
                            // Since repaired items become available, we need to adjust calculation
                            newDamaged = currentDamaged - fromDamaged;
                            
                            // Ensure damaged doesn't go negative (safety check)
                            if (newDamaged < 0) {
                                newDamaged = 0;
                            }
                            
                            // Repaired items become available (they're fixed and ready to sell)
                            // This increases available stock because repaired items are sellable
                            newAvailable += fromDamaged;
                            
                            // Note: To keep total constant when repairing, we need to adjust:
                            // Total = Available + Repaired + Damaged
                            // When repairing: Damaged decreases, Repaired increases, Available increases
                            // But repaired items are part of Available, so to avoid double-counting:
                            // Total should be: Available + Damaged (repaired items are already in Available)
                        }
                    } else if (quantityChange < 0) {
                        // If user enters negative (shouldn't happen with min=0, but handle it)
                        showCustomPopup('Cannot repair negative quantity. Please enter 0 or a positive number.', true);
                        quantityInput.value = 0;
                        quantityChange = 0;
                        newRepaired = currentRepaired;
                    }
                    break;
                case 'disposed':
                    // Office Furniture Inventory Logic for Disposed Items:
                    // The input represents "how many items to dispose" (additive)
                    // Scenario: Disposed=1, user enters 1 (meaning dispose 1 more item)
                    // Result: Disposed=1+1=2, and items are removed from available/damaged/returned
                    // - User enters how many to dispose, this is ADDED to current disposed quantity
                    // - Items are removed from available/damaged/returned (priority: damaged > returned > available)
                    // - Total inventory decreases by the disposed amount
                    
                    // ADDITIVE: Add newQuantity to current disposed quantity
                    const itemsToDispose = newQuantity; // This is how many items to dispose
                    
                    // Validation: Can only dispose items that are available, damaged, or returned
                    const availableToDispose = currentAvailable + currentDamaged;
                    
                    if (itemsToDispose > availableToDispose) {
                        showCustomPopup(`Cannot dispose more items than available. Maximum disposable: ${availableToDispose} (Available: ${currentAvailable}, Damaged: ${currentDamaged})`, true);
                        quantityInput.value = 0;
                        updateTotalQuantity(); // Update display
                        return;
                    }
                    
                    // ADDITIVE: Add itemsToDispose to current disposed quantity
                    newDisposed = currentDisposed + itemsToDispose;
                    
                    // Priority: Dispose from damaged first, then returned, then available
                    let remainingToDispose = itemsToDispose;
                    
                    // Dispose damaged items first
                    if (remainingToDispose > 0 && currentDamaged > 0) {
                        const disposeFromDamaged = Math.min(remainingToDispose, currentDamaged);
                        newDamaged -= disposeFromDamaged;
                        remainingToDispose -= disposeFromDamaged;
                    }
                    
                    
                    // Finally dispose available items
                    if (remainingToDispose > 0) {
                        newAvailable -= Math.min(remainingToDispose, currentAvailable);
            }
            
            // Ensure no negative values
                    newAvailable = Math.max(0, newAvailable);
                    newDamaged = Math.max(0, newDamaged);
                    break;
            }
            
            // Ensure no negative values (but preserve the total: Available + Damaged)
            const beforeTotal = newAvailable + newDamaged;
            newAvailable = Math.max(0, newAvailable);
            newDamaged = Math.max(0, newDamaged);
            newRepaired = Math.max(0, newRepaired);
            newDisposed = Math.max(0, newDisposed);
            
            // Debug: Verify total stays constant for Available + Damaged
            const afterTotal = newAvailable + newDamaged;
            if (statusSelect.value === 'damaged' && Math.abs(beforeTotal - afterTotal) > 0.001) {
                console.warn('Total changed during damaged status update:', { beforeTotal, afterTotal, newAvailable, newDamaged });
            }
            
            // CRITICAL: Ensure total (Available + Damaged) stays constant when moving items between statuses
            // Total = Available + Damaged must remain constant when marking items as damaged or available
            if (statusSelect.value === 'damaged' || statusSelect.value === 'available') {
                const initialTotal = currentAvailable + currentDamaged;
                let finalTotal = newAvailable + newDamaged;
                
                // Force total to stay constant for status changes (damaged <-> available)
                // This ensures items are just moving between statuses, not being added/removed
                if (Math.abs(initialTotal - finalTotal) > 0.001) {
                    const difference = initialTotal - finalTotal;
                    
                    if (difference > 0) {
                        // Total decreased - we lost items somewhere, add back to available
                        newAvailable = newAvailable + difference;
                        console.log('Total decreased - adjusting available:', { 
                            initialTotal, 
                            finalTotal, 
                            difference,
                            newAvailable: newAvailable - difference,
                            adjustedAvailable: newAvailable
                        });
                    } else {
                        // Total increased - we gained items somewhere, subtract from damaged
                        newDamaged = Math.max(0, newDamaged + difference);
                        console.log('Total increased - adjusting damaged:', { 
                            initialTotal, 
                            finalTotal, 
                            difference,
                            newDamaged: newDamaged - difference,
                            adjustedDamaged: newDamaged
                        });
                    }
                    
                    // Recalculate final total after adjustment
                    finalTotal = newAvailable + newDamaged;
                    
                    // Verify it's now correct
                    if (Math.abs(initialTotal - finalTotal) > 0.001) {
                        console.error('Total still incorrect after adjustment!', {
                            statusSelect: statusSelect.value,
                            initialTotal,
                            finalTotal,
                            newAvailable,
                            newDamaged
                        });
                        // Force correction - distribute the difference
                        const remainingDiff = initialTotal - finalTotal;
                        if (remainingDiff > 0) {
                            newAvailable = newAvailable + remainingDiff;
                        } else {
                            newDamaged = Math.max(0, newDamaged - Math.abs(remainingDiff));
                        }
                    }
                }
            }
            
            // Final verification: Ensure total (Available + Damaged) is correct before updating hidden inputs
            if (statusSelect.value === 'damaged' || statusSelect.value === 'available') {
                const verifyInitialTotal = currentAvailable + currentDamaged;
                const verifyFinalTotal = newAvailable + newDamaged;
                
                if (Math.abs(verifyInitialTotal - verifyFinalTotal) > 0.001) {
                    console.error('CRITICAL: Total mismatch before updating hidden inputs!', {
                        status: statusSelect.value,
                        initialTotal: verifyInitialTotal,
                        finalTotal: verifyFinalTotal,
                        difference: verifyInitialTotal - verifyFinalTotal,
                        currentAvailable,
                        currentDamaged,
                        newAvailable,
                        newDamaged
                    });
                    
                    // Force correction one more time
                    const correction = verifyInitialTotal - verifyFinalTotal;
                    if (correction > 0) {
                        newAvailable = newAvailable + correction;
                    } else {
                        newDamaged = Math.max(0, newDamaged - Math.abs(correction));
                    }
                    
                    console.log('Final correction applied:', {
                        correctedAvailable: newAvailable,
                        correctedDamaged: newDamaged,
                        correctedTotal: newAvailable + newDamaged
                    });
                }
            }
            
            // CRITICAL VALIDATION: Available + Damaged cannot exceed Total Quantity
            const totalQuantityInput = document.getElementById('editCurrentTotalQuantity');
            if (totalQuantityInput) {
                // Get the current total quantity (may have been changed by user editing the field)
                const currentTotalQuantity = parseInt(totalQuantityInput.value) || parseInt(totalQuantityInput.getAttribute('data-initial-total')) || (currentAvailable + currentDamaged);
                const calculatedTotal = newAvailable + newDamaged;
                
                if (calculatedTotal > currentTotalQuantity) {
                    // Available + Damaged exceeds Total Quantity - adjust to fit within limit
                    const excess = calculatedTotal - currentTotalQuantity;
                    
                    // Reduce available first (since damaged items are already accounted for)
                    if (newAvailable >= excess) {
                        newAvailable = newAvailable - excess;
                    } else {
                        // If available can't cover all excess, reduce both proportionally
                        const availableReduction = newAvailable;
                        const damagedReduction = excess - availableReduction;
                        newAvailable = 0;
                        newDamaged = Math.max(0, newDamaged - damagedReduction);
                    }
                    
                    showCustomPopup(`Available + Damaged (${calculatedTotal}) cannot exceed Total Quantity (${currentTotalQuantity}). Adjusted to fit within limit.`, true);
                    
                    // Update the quantity input to reflect the adjustment
                    if (statusSelect.value === 'available') {
                        quantityInput.value = newAvailable;
                    } else if (statusSelect.value === 'damaged') {
                        // For damaged, the input is additive, so show the difference
                        const damagedAdded = newDamaged - currentDamaged;
                        quantityInput.value = Math.max(0, damagedAdded);
                    }
                }
            }
            
            // Update all hidden inputs with verified values
            document.getElementById('editAvailableQuantity').value = newAvailable;
            document.getElementById('editDamagedQuantity').value = newDamaged;
            document.getElementById('editRepairedQuantity').value = newRepaired;
            document.getElementById('editDisposedQuantity').value = newDisposed;
            
            // Removed statusDescription update for compact modal
            
            // Update total quantity display
            updateTotalQuantity();
