                    }
                    if (repairedChange !== 0) {
                        const changeClass = repairedChange > 0 ? 'change-positive' : 'change-negative';
                        changesHTML += `<div class="change-item">Repaired: ${currentRepaired} → ${newRepairedQty} <span class="${changeClass}">(${repairedChange > 0 ? '+' : ''}${repairedChange})</span></div>`;
                    }
                    if (disposedChange !== 0) {
                        const changeClass = disposedChange > 0 ? 'change-positive' : 'change-negative';
                        changesHTML += `<div class="change-item">Disposed: ${currentDisposed} → ${newDisposedQty} <span class="${changeClass}">(${disposedChange > 0 ? '+' : ''}${disposedChange})</span></div>`;
                    }
                    changesHTML += `<div class="change-item" style="margin-top: 10px; padding-top: 10px; border-top: 1px solid #ddd;">Total Quantity: ${currentTotal} → ${newTotal}<br><small style="color: #666;">(Available + Damaged, Repaired items are included in Available)</small></div>`;
                    
                    changesList.innerHTML = changesHTML;
                    
                    // Show modal
                    confirmationModal.classList.add('show');
                    
                    // Remove any existing listeners by cloning buttons
                    const confirmBtn = document.getElementById('confirmInventoryChanges');
                    const cancelBtn = document.getElementById('cancelInventoryChanges');
                    
                    const newConfirmBtn = confirmBtn.cloneNode(true);
                    const newCancelBtn = cancelBtn.cloneNode(true);
                    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
                    cancelBtn.parentNode.replaceChild(newCancelBtn, cancelBtn);
                    
                    const closeModal = () => {
                        confirmationModal.classList.remove('show');
                    };
                    
                    newConfirmBtn.addEventListener('click', () => {
                        closeModal();
                        proceedWithSubmission();
                    });
                    
                    newCancelBtn.addEventListener('click', closeModal);
                    
                    // Don't close on outside click - user must explicitly click Cancel or OK
                    
                    // Return early - submission will continue after confirmation
                    return;
                } else {
                    // Fallback to confirm if modal not found
                    let changeMessage = 'Inventory Changes:\n\n';
                    if (availableChange !== 0) changeMessage += `Available: ${currentAvailable} → ${newAvailableQty} (${availableChange > 0 ? '+' : ''}${availableChange})\n`;
                    if (damagedChange !== 0) changeMessage += `Damaged: ${currentDamaged} → ${newDamagedQty} (${damagedChange > 0 ? '+' : ''}${damagedChange})\n`;
                    if (repairedChange !== 0) changeMessage += `Repaired: ${currentRepaired} → ${newRepairedQty} (${repairedChange > 0 ? '+' : ''}${repairedChange})\n`;
                    if (disposedChange !== 0) changeMessage += `Disposed: ${currentDisposed} → ${newDisposedQty} (${disposedChange > 0 ? '+' : ''}${disposedChange})\n`;
                    changeMessage += `\nTotal Quantity: ${currentTotal} → ${newTotal} (Available + Damaged, Repaired items are included in Available)`;
                    
                    if (!confirm(changeMessage + '\n\nProceed with these changes?')) {
                        return;
                    }
                    
                    // Proceed with submission if confirmed
                    proceedWithSubmission();
                }
            });
        }

        // Variations Management
