            { name: 'Magnetic Catch', unit: 'pcs', category: 'Miscellaneous' },
            { name: 'Drawer Lock', unit: 'pcs', category: 'Miscellaneous' },
            { name: 'Cable Organizer', unit: 'pcs', category: 'Miscellaneous' }
        ];

        // Add Material Button
        document.getElementById('addMaterialBtn').addEventListener('click', function(event) {
            event.preventDefault();
            document.getElementById('addMaterialModal').style.display = 'block';
        });

        // Quick Add Common Materials Button
        const quickAddMaterialsBtn = document.getElementById('quickAddMaterialsBtn');
        const quickAddMaterialsModal = document.getElementById('quickAddMaterialsModal');
        const closeQuickAddModal = document.getElementById('closeQuickAddModal');
        const cancelQuickAdd = document.getElementById('cancelQuickAdd');
        const addSelectedMaterialsBtn = document.getElementById('addSelectedMaterials');
        const commonMaterialsList = document.getElementById('commonMaterialsList');

        // Populate common materials list
        function populateCommonMaterials() {
            // Group materials by category
            const groupedMaterials = {};
            commonMaterials.forEach(material => {
                if (!groupedMaterials[material.category]) {
                    groupedMaterials[material.category] = [];
                }
                groupedMaterials[material.category].push(material);
            });

            let html = '';
            Object.keys(groupedMaterials).sort().forEach(category => {
                html += `<div style="margin-bottom: 25px;">`;
                html += `<h4 style="margin: 0 0 12px 0; color: #333; font-size: 1.1em; border-bottom: 2px solid #ddd; padding-bottom: 8px;">${category}</h4>`;
                html += `<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px;">`;
                
                groupedMaterials[category].forEach(material => {
                    html += `
                        <div style="border: 1px solid #ddd; padding: 12px; border-radius: 6px; background: #f9f9f9;">
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                <input type="checkbox" class="material-checkbox" data-name="${material.name}" data-unit="${material.unit}" style="width: 18px; height: 18px; cursor: pointer;">
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; color: #333; margin-bottom: 4px;">${material.name}</div>
                                    <div style="font-size: 0.85em; color: #666;">Unit: ${material.unit}</div>
                                </div>
                            </label>
                        </div>
                    `;
                });
                
                html += `</div></div>`;
            });

            commonMaterialsList.innerHTML = html;
        }

        // Open quick add modal
        quickAddMaterialsBtn.addEventListener('click', function() {
            populateCommonMaterials();
            quickAddMaterialsModal.style.display = 'block';
        });

        // Close quick add modal
        closeQuickAddModal.addEventListener('click', function() {
            quickAddMaterialsModal.style.display = 'none';
        });

        cancelQuickAdd.addEventListener('click', function() {
            quickAddMaterialsModal.style.display = 'none';
        });

        window.addEventListener('click', function(event) {
            if (event.target === quickAddMaterialsModal) {
                quickAddMaterialsModal.style.display = 'none';
            }
        });

        // Add selected materials
        addSelectedMaterialsBtn.addEventListener('click', async function() {
            const checkboxes = document.querySelectorAll('.material-checkbox:checked');
            
            if (checkboxes.length === 0) {
                showCustomPopup('Please select at least one material to add.', true);
                return;
            }

            const materialsToAdd = Array.from(checkboxes).map(cb => ({
                name: cb.getAttribute('data-name'),
                unit: cb.getAttribute('data-unit')
            }));

            // Disable button during processing
            addSelectedMaterialsBtn.disabled = true;
            addSelectedMaterialsBtn.textContent = 'Adding...';

            try {
                let successCount = 0;
                let errorCount = 0;

                // Add materials one by one
                for (const material of materialsToAdd) {
                    try {
                        const formData = new URLSearchParams();
                        formData.append('name', material.name);
                        formData.append('quantity', '0');
                        formData.append('unit', material.unit);

                        const response = await fetch('/Employee/OrderSupport/RawMaterials/Add', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                            },
                            body: formData
                        });

                        if (response.ok) {
                            successCount++;
                        } else {
                            errorCount++;
                        }
                    } catch (error) {
                        console.error('Error adding material:', material.name, error);
                        errorCount++;
                    }
                }

                // Show result and reload page
                if (successCount > 0) {
                    showCustomPopup(`Successfully added ${successCount} material(s). ${errorCount > 0 ? errorCount + ' failed.' : ''}`);
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showCustomPopup('Failed to add materials. They may already exist.', true);
                    addSelectedMaterialsBtn.disabled = false;
                    addSelectedMaterialsBtn.textContent = 'Add Selected Materials';
                }
            } catch (error) {
                console.error('Error adding materials:', error);
                showCustomPopup('An error occurred while adding materials.', true);
                addSelectedMaterialsBtn.disabled = false;
                addSelectedMaterialsBtn.textContent = 'Add Selected Materials';
            }
        });

        // Cancel Add Material
        document.getElementById('cancelAddMaterial').addEventListener('click', function(event) {
            event.preventDefault();
            document.getElementById('addMaterialModal').style.display = 'none';
        });

        // Close modal when clicking on the close button (x)
        document.querySelector('.close-button').addEventListener('click', function() {
            document.getElementById('addMaterialModal').style.display = 'none';
        });

        // Close modal when clicking outside the modal content
        window.onclick = function(event) {
            const modal = document.getElementById('addMaterialModal');
            if (event.target == modal) {
                modal.style.display = 'none';
            }
        }

        // Function to show custom popup
        function showCustomPopup(message, isError = false) {
            const popup = document.getElementById('customPopup');
            const popupMessage = popup.querySelector('.custom-popup-message');
            const popupIcon = popup.querySelector('.custom-popup-icon');

            // Set message and icon
            popupMessage.textContent = message;
            popupIcon.textContent = isError ? '✕' : '✓';
            
            // Set style based on type
            popup.className = 'custom-popup' + (isError ? ' error' : '');
            
            // Show popup
            popup.style.display = 'block';
            
            // Hide popup after 3 seconds
            setTimeout(() => {
                popup.classList.add('hide');
                setTimeout(() => {
                    popup.style.display = 'none';
                    popup.classList.remove('hide');
                }, 500);
            }, 3000);
        }

        // Edit Raw Material Modal Logic
        const editMaterialModal = document.getElementById('editMaterialModal');
        const editMaterialForm = document.getElementById('editMaterialForm');
        const closeEditMaterialModal = document.getElementById('closeEditMaterialModal');
        const cancelEditMaterial = document.getElementById('cancelEditMaterial');

        document.querySelectorAll('.edit-material-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('editMaterialID').value = btn.getAttribute('data-id');
                document.getElementById('editMaterialName').value = btn.getAttribute('data-name');
                document.getElementById('editQuantityAvailable').value = btn.getAttribute('data-quantity');
                document.getElementById('editUnit').value = btn.getAttribute('data-unit');
                editMaterialModal.style.display = 'block';
            });
        });

        closeEditMaterialModal.addEventListener('click', function() {
            editMaterialModal.style.display = 'none';
        });
        cancelEditMaterial.addEventListener('click', function(event) {
            event.preventDefault();
            editMaterialModal.style.display = 'none';
        });
        window.addEventListener('click', function(event) {
            if (event.target == editMaterialModal) {
                editMaterialModal.style.display = 'none';
            }
        });

        // Delete Raw Material Confirmation Modal Logic
        const deleteMaterialConfirmationModal = document.getElementById('deleteMaterialConfirmationModal');
        const cancelMaterialDeleteBtn = document.getElementById('cancelMaterialDelete');
        const confirmMaterialDeleteBtn = document.getElementById('confirmMaterialDelete');
        let deleteMaterialForm = null;

        document.querySelectorAll('.delete-material-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                deleteMaterialForm = this.closest('form');
                deleteMaterialConfirmationModal.style.display = 'flex';
            });
        });

        cancelMaterialDeleteBtn.addEventListener('click', function() {
            deleteMaterialConfirmationModal.style.display = 'none';
            deleteMaterialForm = null;
        });

        confirmMaterialDeleteBtn.addEventListener('click', function() {
            if (deleteMaterialForm) {
                deleteMaterialForm.submit();
            }
            deleteMaterialConfirmationModal.style.display = 'none';
            deleteMaterialForm = null;
        });

        window.addEventListener('click', function(event) {
            if (event.target === deleteMaterialConfirmationModal) {
                deleteMaterialConfirmationModal.style.display = 'none';
                deleteMaterialForm = null;
            }
        });

        // Manage Units Modal Logic
        const manageUnitsBtn = document.getElementById('manageUnitsBtn');
        const manageUnitsModal = document.getElementById('manageUnitsModal');
        const closeManageUnitsModal = document.getElementById('closeManageUnitsModal');
        const closeManageUnitsBtn = document.getElementById('closeManageUnitsBtn');
        const addUnitBtn = document.getElementById('addUnitBtn');
        const newUnitNameInput = document.getElementById('newUnitName');
        const unitsList = document.getElementById('unitsList');

        // Fetch and display units
        async function loadUnits() {
            try {
                const response = await fetch('/api/admin/measurement-units');
                const data = await response.json();
                
                if (data.success && data.units) {
                    if (data.units.length === 0) {
                        unitsList.innerHTML = '<p style="color: #666; text-align: center; padding: 20px;">No units found. Add your first unit above.</p>';
                    } else {
                        unitsList.innerHTML = data.units.map(unit => `
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px; border: 1px solid #ddd; border-radius: 4px; margin-bottom: 10px; background: #f9f9f9;">
                                <span style="font-weight: 500; color: #333;">${unit.UnitName}</span>
                                <button onclick="deleteUnit(${unit.UnitID}, '${unit.UnitName.replace(/'/g, "\\'")}')" style="background-color: #dc3545; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 0.9em;">Delete</button>
                            </div>
                        `).join('');
                    }
                } else {
                    showCustomPopup('Failed to load units.', true);
                }
            } catch (error) {
                console.error('Error loading units:', error);
                showCustomPopup('Error loading units. Check console.', true);
            }
        }

        // Delete unit function
        window.deleteUnit = async function(unitId, unitName) {
            if (!confirm(`Are you sure you want to delete the unit "${unitName}"?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/admin/measurement-units/${unitId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();
                
                if (data.success) {
                    showCustomPopup(data.message);
                    loadUnits();
                    // Reload page to update dropdowns
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showCustomPopup(data.message || 'Failed to delete unit.', true);
                }
            } catch (error) {
                console.error('Error deleting unit:', error);
                showCustomPopup('Error deleting unit. Check console.', true);
            }
        };

        // Open manage units modal
        manageUnitsBtn.addEventListener('click', function() {
            loadUnits();
            manageUnitsModal.style.display = 'block';
        });

        // Close manage units modal
        closeManageUnitsModal.addEventListener('click', function() {
            manageUnitsModal.style.display = 'none';
            newUnitNameInput.value = '';
        });

        closeManageUnitsBtn.addEventListener('click', function() {
            manageUnitsModal.style.display = 'none';
            newUnitNameInput.value = '';
        });

        window.addEventListener('click', function(event) {
            if (event.target === manageUnitsModal) {
                manageUnitsModal.style.display = 'none';
                newUnitNameInput.value = '';
            }
        });

        // Add new unit
        addUnitBtn.addEventListener('click', async function() {
            const unitName = newUnitNameInput.value.trim();
            
            if (!unitName) {
                showCustomPopup('Please enter a unit name.', true);
                return;
            }

            addUnitBtn.disabled = true;
            addUnitBtn.textContent = 'Adding...';

            try {
                const response = await fetch('/api/admin/measurement-units', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ unitName: unitName })
                });

                const data = await response.json();
                
                if (data.success) {
                    showCustomPopup(data.message);
                    newUnitNameInput.value = '';
                    loadUnits();
                    // Reload page to update dropdowns
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showCustomPopup(data.message || 'Failed to add unit.', true);
                    addUnitBtn.disabled = false;
                    addUnitBtn.textContent = 'Add Unit';
                }
            } catch (error) {
                console.error('Error adding unit:', error);
                showCustomPopup('Error adding unit. Check console.', true);
                addUnitBtn.disabled = false;
                addUnitBtn.textContent = 'Add Unit';
            }
        });

        // Allow Enter key to add unit
        newUnitNameInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                addUnitBtn.click();
            }
        });
    </script>
    <% if (locals.error && locals.error.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= error %>', true);
        });
    </script>
    <% } %>
    <% if (locals.success && locals.success.length > 0) { %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showCustomPopup('<%= success %>');
        });
    </script>
    <% } %>

    <!-- Custom Confirmation Modal -->
    <div id="logoutConfirmModal" class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Logout</h3>
            <p>Are you sure you want to log out?</p>
            <div class="modal-buttons">
                <button class="modal-button confirm" id="confirmLogoutBtn">Logout</button>
                <button class="modal-button cancel" id="cancelLogoutBtn">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        // Custom Logout Modal Logic
        const logoutConfirmModal = document.getElementById('logoutConfirmModal');
        const confirmLogoutBtn = document.getElementById('confirmLogoutBtn');
        const cancelLogoutBtn = document.getElementById('cancelLogoutBtn');

        async function handleLogout(event) {
            event.preventDefault();
            logoutConfirmModal.classList.add('show');
        }

        confirmLogoutBtn.addEventListener('click', async () => {
            logoutConfirmModal.classList.remove('show');
            try {
                const response = await fetch('/logout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    window.location.href = '/login';
                } else {
                    console.error('Logout failed');
                    alert('Failed to logout. Please try again.');
                }
            } catch (error) {
                console.error('Error during logout:', error);
                alert('An error occurred during logout. Please try again.');
            }
        });

        cancelLogoutBtn.addEventListener('click', () => {
            logoutConfirmModal.classList.remove('show');
        });

        // Close modal if clicked outside content
        logoutConfirmModal.addEventListener('click', (event) => {
            if (event.target === logoutConfirmModal) {
                logoutConfirmModal.classList.remove('show');
            }
        });
    </script>

</body>
