<% 
    // Get optional parameters with defaults
    const spinnerSize = typeof size !== 'undefined' ? size : 'medium';
    const spinnerText = typeof text !== 'undefined' ? text : 'Loading...';
    const isOverlay = typeof overlay !== 'undefined' ? overlay : false;
    const isFullscreen = typeof fullscreen !== 'undefined' ? fullscreen : false;
    const customClass = typeof className !== 'undefined' ? className : '';
    const spinnerId = typeof id !== 'undefined' ? id : 'admin-loading-spinner';
%>
<div class="admin-loading-spinner <%= spinnerSize %> <%= isOverlay ? 'admin-loading-spinner--overlay' : '' %> <%= isFullscreen ? 'admin-loading-spinner--fullscreen' : '' %> <%= customClass %>" id="<%= spinnerId %>">
    <div class="admin-loading-spinner__container">
        <div class="admin-loading-spinner__spinner"></div>
        <% if (spinnerText && spinnerText !== '') { %>
            <div class="admin-loading-spinner__text"><%= spinnerText %></div>
        <% } %>
    </div>
</div>

<style>
    /* Admin Loading Spinner Styles - Matches Admin Design */
    .admin-loading-spinner {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        min-height: 200px;
        font-family: var(--font-primary, 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif);
    }

    .admin-loading-spinner.hidden {
        display: none;
    }

    .admin-loading-spinner--overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(4px);
        z-index: 1000;
        border-radius: 12px;
    }

    .admin-loading-spinner--fullscreen {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(248, 249, 250, 0.95);
        backdrop-filter: blur(6px);
        z-index: 9999;
        min-height: 100vh;
    }

    .admin-loading-spinner__container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .admin-loading-spinner__spinner {
        width: 40px;
        height: 40px;
        border: 4px solid #f3f4f6;
        border-top-color: var(--primary-color, #F0B21B);
        border-radius: 50%;
        animation: admin-spin 0.8s linear infinite;
    }

    .admin-loading-spinner.small .admin-loading-spinner__spinner {
        width: 24px;
        height: 24px;
        border-width: 3px;
    }

    .admin-loading-spinner.large .admin-loading-spinner__spinner {
        width: 56px;
        height: 56px;
        border-width: 5px;
    }

    .admin-loading-spinner__text {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-light, #7f8c8d);
        text-align: center;
        letter-spacing: -0.01em;
    }

    @keyframes admin-spin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }
</style>
