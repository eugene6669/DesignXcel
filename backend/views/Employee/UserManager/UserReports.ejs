    <script>
        // Tab switching
        function switchTab(tabName) {
            // Update tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');

            // Update tab content
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById(`${tabName}-tab`).classList.add('active');

            // Load data for the active tab
            loadTabData(tabName);
        }

        // Load data for each tab
        async function loadTabData(tabName) {
            switch(tabName) {
                case 'inventory':
                    await loadInventoryData();
                    break;
                case 'sales':
                    await loadSalesData();
                    break;
                case 'masterlist':
                    await loadMasterlistData();
                    break;
            }
        }

        // Inventory Report Functions
        let inventoryFilters = {};
        async function loadInventoryData() {
            try {
                const params = new URLSearchParams(inventoryFilters);
                const response = await fetch(`/Employee/Admin/Reports/Inventory/Data?${params}`);
                const data = await response.json();
                
                if (data.success) {
                    renderInventoryTable(data.data);
                    renderRawMaterialsTable(data.rawMaterials || []);
                    renderInventoryStats(data.stats);
                    renderInventoryChart(data.stats);
                } else {
                    document.getElementById('inventory-tbody').innerHTML = 
                        `<tr><td colspan="7" class="empty-state">${data.error || 'Error loading inventory data'}</td></tr>`;
                }
            } catch (error) {
                console.error('Error loading inventory:', error);
                document.getElementById('inventory-tbody').innerHTML = 
                    `<tr><td colspan="7" class="empty-state">Error loading inventory data</td></tr>`;
            }
        }

        function renderInventoryTable(data) {
            const tbody = document.getElementById('inventory-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="empty-state">No inventory data found</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(item => {
                const statusClass = item.StockQuantity === 0 ? 'badge-danger' : 
                                   item.StockQuantity < 10 ? 'badge-warning' : 
                                   item.IsActive ? 'badge-success' : 'badge-info';
                const statusText = item.StockQuantity === 0 ? 'Out of Stock' : 
                                  item.StockQuantity < 10 ? 'Low Stock' : 
                                  item.IsActive ? 'Active' : 'Inactive';
                
                return `
                    <tr>
                        <td>${item.Name || 'N/A'}</td>
                        <td>${item.SKU || 'N/A'}</td>
                        <td>${item.CategoryName || 'N/A'}</td>
                        <td>${item.StockQuantity || 0}</td>
                        <td>₱${Number(item.Price || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td><span class="badge ${statusClass}">${statusText}</span></td>
                        <td>${item.LastUpdated ? new Date(item.LastUpdated).toLocaleDateString() : 'N/A'}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderRawMaterialsTable(data) {
            const tbody = document.getElementById('raw-materials-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No raw materials data found</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(item => {
                const statusClass = item.QuantityAvailable === 0 ? 'badge-danger' : 
                                   item.QuantityAvailable < 10 ? 'badge-warning' : 
                                   item.IsActive ? 'badge-success' : 'badge-info';
                const statusText = item.QuantityAvailable === 0 ? 'Out of Stock' : 
                                  item.QuantityAvailable < 10 ? 'Low Stock' : 
                                  item.IsActive ? 'Active' : 'Inactive';
                
                return `
                    <tr>
                        <td>${item.Name || 'N/A'}</td>
                        <td>${item.Unit || 'N/A'}</td>
                        <td>${item.QuantityAvailable || 0}</td>
                        <td><span class="badge ${statusClass}">${statusText}</span></td>
                        <td>${item.LastUpdated ? new Date(item.LastUpdated).toLocaleDateString() : 'N/A'}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderCategoriesBreakdown(data) {
            const tbody = document.getElementById('categories-breakdown-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No categories data found</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(item => {
                const categoryValue = parseFloat(item.CategoryValue || 0);
                return `
                    <tr>
                        <td><strong>${item.CategoryName || 'Uncategorized'}</strong></td>
                        <td>${item.ProductCount || 0}</td>
                        <td><span class="badge badge-success">${item.ActiveProducts || 0}</span></td>
                        <td><span class="badge badge-danger">${item.InactiveProducts || 0}</span></td>
                        <td>${item.TotalStock || 0}</td>
                        <td>₱${categoryValue.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderMasterlistSummary(data) {
            const tbody = document.getElementById('masterlist-summary-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="empty-state">No masterlist data found</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(item => {
                return `
                    <tr>
                        <td><strong>${item.RoleName || 'N/A'}</strong></td>
                        <td>${item.TotalCount || 0}</td>
                        <td><span class="badge badge-success">${item.ActiveCount || 0}</span></td>
                        <td><span class="badge badge-danger">${item.InactiveCount || 0}</span></td>
                    </tr>
                `;
            }).join('');
        }

        function renderInventoryStats(stats) {
            if (!stats) return;
            const container = document.getElementById('inventory-stats');
            container.innerHTML = `
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        </svg>
                    </div>
                    <div class="stat-label">Total Products</div>
                    <div class="stat-value">${stats.totalProducts || 0}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 6v6l4 2"/>
                        </svg>
                    </div>
                    <div class="stat-label">Active Products</div>
                    <div class="stat-value">${stats.activeProducts || 0}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        </svg>
                    </div>
                    <div class="stat-label">Low Stock Products</div>
                    <div class="stat-value">${stats.lowStock || 0}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                        </svg>
                    </div>
                    <div class="stat-label">Total Raw Materials</div>
                    <div class="stat-value">${stats.totalRawMaterials || 0}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 6v6l4 2"/>
                        </svg>
                    </div>
                    <div class="stat-label">Active Raw Materials</div>
                    <div class="stat-value">${stats.activeRawMaterials || 0}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        </svg>
                    </div>
                    <div class="stat-label">Low Stock Raw Materials</div>
                    <div class="stat-value">${stats.lowStockRawMaterials || 0}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="2" x2="12" y2="22"/>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                        </svg>
                    </div>
