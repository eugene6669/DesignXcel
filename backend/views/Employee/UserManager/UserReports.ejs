        function renderRevenueChart(stats) {
            const canvas = document.getElementById('sales-revenue-chart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const container = canvas.parentElement;
            const width = container.clientWidth || 600;
            const height = 300;
            canvas.width = width;
            canvas.height = height;

            const padding = 60;
            const chartWidth = width - (padding * 2);
            const chartHeight = height - (padding * 2);

            ctx.clearRect(0, 0, width, height);

            // Chart data
            const revenueData = [
                { label: 'Gross Revenue', value: parseFloat(stats.grossSales || 0), color: '#F0B21B' },
                { label: 'Net Revenue', value: parseFloat(stats.netSales || 0), color: '#10b981' },
                { label: 'Total Revenue', value: parseFloat(stats.totalRevenue || 0), color: '#3b82f6' },
                { label: 'Taxes', value: parseFloat(stats.totalTaxes || 0), color: '#8b5cf6' },
                { label: 'Delivery', value: parseFloat(stats.deliveryRevenues || 0), color: '#06b6d4' }
            ];

            const maxValue = Math.max(...revenueData.map(d => d.value), 1);
            const barWidth = chartWidth / revenueData.length;
            const spacing = barWidth * 0.2;

            // Draw background
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(padding, padding, chartWidth, chartHeight);

            // Draw bars
            revenueData.forEach((item, index) => {
                const x = padding + (index * barWidth) + (spacing / 2);
                const barHeight = maxValue > 0 ? (item.value / maxValue) * chartHeight : 0;
                const y = padding + chartHeight - barHeight;

                // Draw bar
                ctx.fillStyle = item.color;
                ctx.fillRect(x, y, barWidth - spacing, barHeight);

                // Draw value label
                if (item.value > 0) {
                    ctx.fillStyle = '#0f172a';
                    ctx.font = 'bold 10px Inter';
                    ctx.textAlign = 'center';
                    const formattedValue = (item.value / 1000).toFixed(1) + 'K';
                    ctx.fillText(formattedValue, x + (barWidth - spacing) / 2, y - 5);
                }

                // Draw label
                ctx.fillStyle = '#64748b';
                ctx.font = '9px Inter';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'top';
                const labelY = padding + chartHeight + 20;
                
                // Split long labels
                const words = item.label.split(' ');
                let currentLine = '';
                let yOffset = 0;
                words.forEach((word, idx) => {
                    const testLine = currentLine + (idx > 0 ? ' ' : '') + word;
                    const metrics = ctx.measureText(testLine);
                    if (metrics.width > barWidth - spacing && currentLine !== '') {
                        ctx.fillText(currentLine, x + (barWidth - spacing) / 2, labelY + yOffset);
                        currentLine = word;
                        yOffset += 11;
                    } else {
                        currentLine = testLine;
                    }
                });
                if (currentLine !== '') {
                    ctx.fillText(currentLine, x + (barWidth - spacing) / 2, labelY + yOffset);
                }
            });

            // Draw axes
            ctx.strokeStyle = '#e5e7eb';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(padding, padding + chartHeight);
            ctx.lineTo(padding + chartWidth, padding + chartHeight);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(padding, padding);
            ctx.lineTo(padding, padding + chartHeight);
            ctx.stroke();

            // Y axis labels
            ctx.fillStyle = '#64748b';
            ctx.font = '10px Inter';
            ctx.textAlign = 'right';
            ctx.textBaseline = 'middle';
            const ySteps = 5;
            for (let i = 0; i <= ySteps; i++) {
                const value = (maxValue / ySteps) * (ySteps - i);
                const y = padding + (chartHeight / ySteps) * i;
                const formattedValue = (value / 1000).toFixed(1) + 'K';
                ctx.fillText(formattedValue, padding - 10, y);
                
                if (i > 0) {
                    ctx.strokeStyle = '#e5e7eb';
                    ctx.lineWidth = 0.5;
                    ctx.beginPath();
                    ctx.moveTo(padding, y);
                    ctx.lineTo(padding + chartWidth, y);
                    ctx.stroke();
                }
            }
        }


