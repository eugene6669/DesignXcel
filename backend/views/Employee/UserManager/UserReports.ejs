        // Sales Report Functions
        let salesFilters = {};
        async function loadSalesData() {
            try {
                const params = new URLSearchParams(salesFilters);
                const response = await fetch(`/Employee/Admin/Reports/Sales/Data?${params}`);
                const data = await response.json();
                
                if (data.success) {
                    renderSalesTable(data.data);
                    renderSalesStats(data.stats);
                    renderSalesCharts(data.stats);
                } else {
                    document.getElementById('sales-tbody').innerHTML = 
                        `<tr><td colspan="15" class="empty-state">${data.error || 'Error loading sales data'}</td></tr>`;
                }
            } catch (error) {
                console.error('Error loading sales:', error);
                document.getElementById('sales-tbody').innerHTML = 
                    `<tr><td colspan="15" class="empty-state">Error loading sales data</td></tr>`;
            }
        }

        function renderSalesTable(data) {
            const tbody = document.getElementById('sales-tbody');
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="15" class="empty-state">No sales data found</td></tr>';
                return;
            }

            // Debug: Log first order to see what data we're receiving
            if (data.length > 0) {
                console.log('[SALES REPORT FRONTEND] First order data:', data[0]);
                console.log('[SALES REPORT FRONTEND] First order TotalDiscounts:', data[0].TotalDiscounts);
                console.log('[SALES REPORT FRONTEND] First order OrderItems:', data[0].OrderItems);
                console.log('[SALES REPORT FRONTEND] First order OrderItems type:', typeof data[0].OrderItems);
                console.log('[SALES REPORT FRONTEND] First order OrderItems length:', data[0].OrderItems ? data[0].OrderItems.length : 'N/A');
            }

            tbody.innerHTML = data.map(item => {
                const statusClass = item.Status === 'Completed' || item.Status === 'Received' ? 'badge-success' :
                                   item.Status === 'Cancelled' || item.Status === 'Returned' || (item.Status && (item.Status.toLowerCase() === 'returned' || item.Status.toLowerCase() === 'return')) ? 'badge-danger' :
                                   item.Status === 'Pending' ? 'badge-warning' : 'badge-info';
                
                // Use TotalDiscounts directly from API response (calculated from OrderItems)
                // If TotalDiscounts is not available, fallback to 0
                const discount = item.TotalDiscounts || 0;
                
                // Use TotalTaxes directly from API response (calculated from OrderItems)
                // If TotalTaxes is not available, fallback to 0
                const tax = item.TotalTaxes || 0;
                
                // Debug: Log if discount is 0 but we expect it to have a value
                if (item.OrderID && discount === 0 && item.TotalAmount > 0) {
                    console.log(`[SALES REPORT FRONTEND] Order ${item.OrderID} has TotalDiscounts:`, item.TotalDiscounts, 'TotalAmount:', item.TotalAmount);
                }
                
                // Format order items count for display
                let orderItemsCount = item.TotalItems || 0;
                if (item.OrderItems && Array.isArray(item.OrderItems)) {
                    orderItemsCount = item.OrderItems.length;
                }
                
                // Format product names and quantities for display
                let productNamesQuantitiesHtml = 'N/A';
                
                // Debug: Log the item structure
                if (item.OrderID && !item.OrderItems) {
                    console.log(`[SALES REPORT FRONTEND] Order ${item.OrderID} has no OrderItems property. Available keys:`, Object.keys(item));
                }
                
                if (item.OrderItems && Array.isArray(item.OrderItems) && item.OrderItems.length > 0) {
                    productNamesQuantitiesHtml = item.OrderItems.map(orderItem => {
                        const name = orderItem.name || orderItem.Name || 'Unknown Product';
                        const qty = orderItem.quantity || orderItem.Quantity || 0;
                        return `${name} (Qty: ${qty})`;
                    }).join('<br>');
                } else if (item.TotalItems && item.TotalItems > 0) {
                    // Fallback message if OrderItems array is not available
                    productNamesQuantitiesHtml = `${item.TotalItems} item(s) - Details not available`;
                } else if (item.OrderItems && !Array.isArray(item.OrderItems)) {
                    // Handle case where OrderItems might be an object or string
                    console.warn(`[SALES REPORT FRONTEND] Order ${item.OrderID} has OrderItems but it's not an array:`, typeof item.OrderItems, item.OrderItems);
                    productNamesQuantitiesHtml = item.TotalItems ? `${item.TotalItems} item(s) - Details not available` : 'N/A';
                }
                
                return `
                    <tr>
                        <td>${item.OrderID || 'N/A'}</td>
                        <td>${item.ReferenceNumber || 'N/A'}</td>
                        <td>${item.CustomerName || 'N/A'}</td>
                        <td>${item.CustomerEmail || 'N/A'}</td>
                        <td>${item.OrderDate ? new Date(item.OrderDate).toLocaleDateString() : 'N/A'}</td>
                        <td><span class="badge ${statusClass}">${item.Status || 'N/A'}</span></td>
                        <td>${orderItemsCount}</td>
                        <td style="max-width: 300px; word-wrap: break-word; line-height: 1.5;">${productNamesQuantitiesHtml}</td>
                        <td>₱${Number(item.Subtotal || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(item.ExtraDeliveryFee || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(item.DeliveryCost || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(item.TotalAmount || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(discount).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>₱${Number(tax).toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
                        <td>${item.PaymentMethod || 'N/A'}</td>
                    </tr>
                `;
            }).join('');
        }

