<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Login - Design Excellence</title>
    <link rel="stylesheet" href="/css/EmpLogin/EmpLogin.css">

</head>
<body>
    <div class="login-container">
        <div class="login-wrapper">
            <div class="login-left">
                <div class="logo-container">
                    <img src="/img/logo.png" alt="Design Excellence Logo" class="logo">
                    <img src="/img/system-logo.png" alt="System Logo" class="system-logo-side">
                </div>
                
                <h2 class="login-title">Welcome Back!</h2>
                <p class="login-subtitle">Please Sign in to continue</p>
                
                <% if (locals.error && locals.error.length > 0) { %>
                    <div class="error-message"><%= error %></div>
                <% } %>
                
                <form action="/auth/login" method="POST">
                    <div class="input-field">
                        <input 
                            type="text" 
                            name="email"
                            placeholder="Email or username"
                            required
                            autocomplete="username"
                            maxlength="32"
                            value="<%= locals.email || '' %>"
                        >
                    </div>
                    
                    <div class="input-field">
                        <input 
                            type="password"
                            name="password"
                            placeholder="Password"
                            required
                            autocomplete="current-password"
                            id="password"
                        >
                        <span 
                            class="password-toggle"
                            onclick="togglePasswordVisibility()"
                        >
                            👁️‍🗨️
                        </span>
                    </div>
                    
                    <div style="text-align: right; margin-bottom: 20px;">
                        <a href="#" onclick="showForgotPasswordModal(); return false;" style="color: #F0B21B; text-decoration: none; font-size: 14px;">Forgot Password?</a>
                    </div>
                    
                    <button type="submit" class="sign-in-btn">
                        SIGN IN
                    </button>
                </form>
            </div>
            
            <div class="login-right">
                <!-- Yellow architectural image will be provided by CSS background -->
            </div>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    <div id="forgotPasswordModal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 500px;">
            <h3 style="margin-top: 0; color: #1f2937;">Forgot Password</h3>
            <p style="color: #6b7280; margin-bottom: 20px;">Enter your email address and we'll send you a link to reset your password.</p>
            
            <div id="forgotPasswordError" class="error-message" style="display: none; margin-bottom: 15px;"></div>
            <div id="forgotPasswordSuccess" class="success-message" style="display: none; margin-bottom: 15px;"></div>
            
            <form id="forgotPasswordForm" onsubmit="handleForgotPassword(event); return false;">
                <div class="input-field">
                    <input 
                        type="email" 
                        id="forgotPasswordEmail"
                        placeholder="Enter your email"
                        required
                        autocomplete="email"
                        maxlength="32"
                    >
                </div>
                
                <div class="button-group">
                    <button type="button" onclick="hideForgotPasswordModal()">
                        Cancel
                    </button>
                    <button type="submit" id="forgotPasswordSubmitBtn">
                        Send Reset Link
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Reset Password Modal -->
    <div id="resetPasswordModal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 500px;">
            <h3 style="margin-top: 0; color: #1f2937;">Reset Password</h3>
            <p style="color: #6b7280; margin-bottom: 20px;">Enter your new password below.</p>
            
            <div id="resetPasswordError" class="error-message" style="display: none; margin-bottom: 15px;"></div>
            <div id="resetPasswordSuccess" class="success-message" style="display: none; margin-bottom: 15px;"></div>
            
            <form id="resetPasswordForm" onsubmit="handleResetPassword(event); return false;">
                <input type="hidden" id="resetToken" value="">
                
                <div class="input-field">
                    <input 
                        type="password"
                        id="newPassword"
                        placeholder="New Password (min 8 characters)"
                        required
                        autocomplete="new-password"
                        minlength="8"
                    >
                    <span 
                        class="password-toggle"
                        onclick="togglePasswordVisibility('newPassword')"
                    >
                        👁️‍🗨️
                    </span>
                </div>
                
                <div class="input-field">
                    <input 
                        type="password"
                        id="confirmPassword"
                        placeholder="Confirm New Password"
                        required
                        autocomplete="new-password"
                        minlength="8"
                    >
                    <span 
                        class="password-toggle"
                        onclick="togglePasswordVisibility('confirmPassword')"
                    >
                        👁️‍🗨️
                    </span>
                </div>
                
                <div class="button-group">
                    <button type="button" onclick="hideResetPasswordModal()">
                        Cancel
                    </button>
                    <button type="submit" id="resetPasswordSubmitBtn">
                        Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>

    <style>
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.6);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10000;
            backdrop-filter: blur(4px);
        }
        
        .modal-content {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            width: 90%;
            max-width: 500px;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            box-sizing: border-box;
        }
        
        .modal-content h3 {
            margin: 0 0 10px 0;
            color: #1f2937;
            font-size: 24px;
            font-weight: 600;
        }
        
        .modal-content p {
            margin: 0 0 25px 0;
            color: #6b7280;
            font-size: 14px;
            line-height: 1.5;
        }
        
        .modal-content .input-field {
            margin-bottom: 20px;
            position: relative;
            width: 100%;
        }
        
        .modal-content .input-field input {
            width: 100%;
            padding: 14px 45px 14px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
            outline: none;
        }
        
        .modal-content .input-field input:focus {
            border-color: #F0B21B;
        }
        
        .modal-content .input-field .password-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            background: none;
            border: none;
            font-size: 18px;
            padding: 5px;
            z-index: 10;
            user-select: none;
        }
        
        .modal-content .input-field .password-toggle:hover {
            opacity: 0.7;
        }
        
        .modal-content form {
            margin: 0;
            width: 100%;
        }
        
        .modal-content .button-group {
            display: flex;
            gap: 12px;
            margin-top: 25px;
            width: 100%;
        }
        
        .modal-content .button-group button {
            flex: 1;
            padding: 14px 20px;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
        
        .modal-content .button-group button[type="submit"] {
            background: linear-gradient(135deg, #F0B21B 0%, #e0a10b 100%);
            color: #1f2937;
        }
        
        .modal-content .button-group button[type="submit"]:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(240, 178, 27, 0.4);
        }
        
        .modal-content .button-group button[type="submit"]:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        
        .modal-content .button-group button[type="button"] {
            background-color: #6b7280;
            color: white;
        }
        
        .modal-content .button-group button[type="button"]:hover {
            background-color: #4b5563;
        }
        
        .error-message {
            background-color: #fee2e2;
            color: #dc2626;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 20px;
            border-left: 4px solid #dc2626;
            word-wrap: break-word;
            box-sizing: border-box;
        }
        
        .success-message {
            background-color: #d1fae5;
            color: #059669;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 20px;
            border-left: 4px solid #059669;
            word-wrap: break-word;
            box-sizing: border-box;
        }
        
        @media (max-width: 600px) {
            .modal-content {
                padding: 30px 20px;
                margin: 20px;
                max-width: calc(100% - 40px);
            }
            
            .modal-content h3 {
                font-size: 20px;
            }
            
            .modal-content .button-group {
                flex-direction: column;
            }
            
            .modal-content .button-group button {
                width: 100%;
            }
        }
    </style>

    <script>
        function togglePasswordVisibility(inputId) {
            const passwordInput = document.getElementById(inputId || 'password');
            const toggleButton = passwordInput.nextElementSibling;
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleButton.textContent = '👁️';
            } else {
                passwordInput.type = 'password';
                toggleButton.textContent = '👁️‍🗨️';
            }
        }

        function showForgotPasswordModal() {
            document.getElementById('forgotPasswordModal').style.display = 'flex';
            document.getElementById('forgotPasswordError').style.display = 'none';
            document.getElementById('forgotPasswordSuccess').style.display = 'none';
            document.getElementById('forgotPasswordEmail').value = '';
        }

        function hideForgotPasswordModal() {
            document.getElementById('forgotPasswordModal').style.display = 'none';
        }

        async function handleForgotPassword(event) {
            event.preventDefault();
            
            const email = document.getElementById('forgotPasswordEmail').value;
            const errorDiv = document.getElementById('forgotPasswordError');
            const successDiv = document.getElementById('forgotPasswordSuccess');
            const submitBtn = document.getElementById('forgotPasswordSubmitBtn');
            
            // Hide previous messages
            errorDiv.style.display = 'none';
            successDiv.style.display = 'none';
            
            if (!email) {
                errorDiv.textContent = 'Please enter your email address';
                errorDiv.style.display = 'block';
                return;
            }
            
            // Disable button and show loading
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';
            
            try {
                const response = await fetch('/api/auth/forgot-password-user', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email: email })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    successDiv.textContent = result.message || 'Password reset instructions have been sent to your email address.';
                    successDiv.style.display = 'block';
                    document.getElementById('forgotPasswordForm').reset();
                    
                    // Auto close after 3 seconds
                    setTimeout(() => {
                        hideForgotPasswordModal();
                    }, 3000);
                } else {
                    errorDiv.textContent = result.message || 'Failed to send reset email. Please try again.';
                    errorDiv.style.display = 'block';
                }
            } catch (error) {
                console.error('Error:', error);
                errorDiv.textContent = 'An error occurred. Please try again later.';
                errorDiv.style.display = 'block';
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send Reset Link';
            }
        }

        // Close modal when clicking outside
        document.getElementById('forgotPasswordModal').addEventListener('click', function(e) {
            if (e.target === this) {
                hideForgotPasswordModal();
            }
        });

        // Reset Password Modal Functions
        function showResetPasswordModal(token) {
            document.getElementById('resetToken').value = token;
            document.getElementById('resetPasswordModal').style.display = 'flex';
            document.getElementById('resetPasswordError').style.display = 'none';
            document.getElementById('resetPasswordSuccess').style.display = 'none';
            document.getElementById('resetPasswordForm').reset();
            document.getElementById('resetToken').value = token;
        }

        function hideResetPasswordModal() {
            document.getElementById('resetPasswordModal').style.display = 'none';
            document.getElementById('resetToken').value = '';
        }

        async function handleResetPassword(event) {
            event.preventDefault();
            
            const token = document.getElementById('resetToken').value;
            const password = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const errorDiv = document.getElementById('resetPasswordError');
            const successDiv = document.getElementById('resetPasswordSuccess');
            const submitBtn = document.getElementById('resetPasswordSubmitBtn');
            
            // Hide previous messages
            errorDiv.style.display = 'none';
            successDiv.style.display = 'none';
            
            // Validation
            if (!token) {
                errorDiv.textContent = 'Invalid reset link. Please request a new password reset.';
                errorDiv.style.display = 'block';
                return;
            }
            
            if (password.length < 8) {
                errorDiv.textContent = 'Password must be at least 8 characters long.';
                errorDiv.style.display = 'block';
                return;
            }
            
            if (password !== confirmPassword) {
                errorDiv.textContent = 'Passwords do not match.';
                errorDiv.style.display = 'block';
                return;
            }
            
            // Disable button and show loading
            submitBtn.disabled = true;
            submitBtn.textContent = 'Resetting...';
            
            try {
                const response = await fetch('/api/auth/reset-password-user', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ 
                        token: token,
                        password: password,
                        confirmPassword: confirmPassword
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    successDiv.textContent = result.message || 'Password has been reset successfully! You can now login.';
                    successDiv.style.display = 'block';
                    document.getElementById('resetPasswordForm').reset();
                    
                    // Close modal and redirect to login after 3 seconds
                    setTimeout(() => {
                        hideResetPasswordModal();
                        window.location.reload();
                    }, 3000);
                } else {
                    errorDiv.textContent = result.message || 'Failed to reset password. Please try again.';
                    errorDiv.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Reset Password';
                }
            } catch (error) {
                console.error('Error:', error);
                errorDiv.textContent = 'An error occurred. Please try again later.';
                errorDiv.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Reset Password';
            }
        }

        // Check if token is present in URL on page load
        window.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const token = urlParams.get('token');
            
            if (token) {
                // Clean URL
                window.history.replaceState({}, document.title, window.location.pathname);
                // Show reset password modal
                showResetPasswordModal(token);
            }
        });

        // Close reset password modal when clicking outside
        document.getElementById('resetPasswordModal').addEventListener('click', function(e) {
            if (e.target === this) {
                hideResetPasswordModal();
            }
        });
    </script>
</body>
</html>
