# DesignXcel Railway Backend Environment Example
# Copy this file to `.env.railway`, set real values, then deploy.
# Used by frontend build helper scripts as source for `.env.production`.

# -------------------------------
# App
# -------------------------------
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=info

# -------------------------------
# Database (Azure SQL / remote SQL)
# -------------------------------
DB_SERVER=your-sql-server-host
DB_DATABASE=your-database-name
DB_USERNAME=your-database-username
DB_USER=your-database-username
DB_PASSWORD=your-database-password
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# Optional: use this instead of individual DB_* fields
# DB_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=your-db;Persist Security Info=False;User ID=your-user;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;

# -------------------------------
# Auth
# -------------------------------
SESSION_SECRET=replace_with_strong_session_secret
JWT_SECRET=replace_with_strong_jwt_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_EXPIRES_IN=24h

# -------------------------------
# URLs / CORS
# -------------------------------
FRONTEND_URL=https://your-frontend-domain.com
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000
CORS_ORIGINS=https://your-frontend-domain.com,http://localhost:3000
BACKEND_URL=https://your-backend-domain.com

# -------------------------------
# Payments
# -------------------------------
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# -------------------------------
# Email (current backend supports SendGrid + OTP creds)
# -------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
OTP_EMAIL_USER=your_email@example.com
OTP_EMAIL_PASS=your_email_app_password

# -------------------------------
# Optional OAuth
# -------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/auth/google/callback

# -------------------------------
# Security / limits
# -------------------------------
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
